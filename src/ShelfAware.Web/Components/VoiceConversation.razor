@* Multi-turn voice conversation (v2.1, the "own it" side). Push-to-talk PER TURN: EL Scribe STT ->
   IPantryChat WITH conversation history -> EL TTS, looping so follow-ups resolve against what was just
   said ("what am I low on?" -> list -> "add the first two"). A deliberately SEPARATE surface from the
   single-shot PushToTalk (one-shot bark vs. stateful dialogue — same IPantryChat brain behind both).
   No barge-in here: you tap to take each turn. Hands-free barge-in is the ElevenLabs Conversational
   Agent's job, reserved for recipe read-aloud. *@
@using ShelfAware.Core.Chat
@using ShelfAware.Core.Speech
@implements IAsyncDisposable
@inject ISpeechToText Stt
@inject IPantryChat Chat
@inject ITextToSpeech Tts
@inject IJSRuntime JS

<div class="voice-convo">
    @if (!active)
    {
        <button type="button" class="secondary" @onclick="Start" disabled="@(_checked && !_supported)">
            💬 Have a conversation
        </button>
        @if (_checked && !_supported)
        {
            <span class="muted">Voice input isn't supported in this browser.</span>
        }
    }
    else
    {
        <div class="convo-head">
            <strong>Conversation</strong>
            <button type="button" class="icon-btn" @onclick="End" aria-label="End conversation" title="End conversation">✕</button>
        </div>
        <div class="convo-log" role="log" aria-live="polite">
            @if (history.Count == 0 && pendingUser is null)
            {
                <p class="muted">Hold the mic and ask — e.g. “what am I low on?” — then keep going: “add the first two”.</p>
            }
            @foreach (var turn in history)
            {
                <p class="convo-user"><span class="who">You</span> @turn.User</p>
                <p class="convo-bot"><span class="who">Shelf&nbsp;Aware</span> @turn.Assistant</p>
            }
            @if (pendingUser is not null)
            {
                <p class="convo-user"><span class="who">You</span> @pendingUser</p>
            }
            @if (error is not null)
            {
                <p class="error">@error</p>
            }
        </div>
        <button type="button"
                class="mic mic-@State.ToString().ToLowerInvariant()"
                disabled="@Busy"
                @onpointerdown="StartTurnAsync" @onpointerup="EndTurnAsync"
                @onpointerleave="EndTurnAsync" @onpointercancel="EndTurnAsync"
                aria-label="Hold to speak your next turn">
            <span class="mic-glyph" aria-hidden="true">@(State == VoiceState.Recording ? "●" : "🎙")</span>
            <span class="mic-label">@TurnLabel</span>
        </button>
    }
</div>

@code {
    [Parameter] public EventCallback OnApplied { get; set; }

    private enum VoiceState { Idle, Recording, Thinking, Speaking }
    private VoiceState State = VoiceState.Idle;

    private IJSObjectReference? _module;
    private bool _supported;
    private bool _checked;
    private bool active;

    private readonly List<ChatTurn> history = [];
    private string? pendingUser;
    private string? error;

    private bool Busy => State is VoiceState.Thinking or VoiceState.Speaking;

    private string TurnLabel => State switch
    {
        VoiceState.Recording => "Listening…",
        VoiceState.Thinking => "Working…",
        VoiceState.Speaking => "Speaking…",
        _ => history.Count == 0 ? "Hold to ask" : "Hold to reply",
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _module = await JS.InvokeAsync<IJSObjectReference>("import", "/js/voice.js");
        _supported = await _module.InvokeAsync<bool>("isSupported");
        _checked = true;
        StateHasChanged();
    }

    private void Start()
    {
        history.Clear();
        pendingUser = null;
        error = null;
        active = true;
    }

    private async Task End()
    {
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("stopPlayback"); } catch { /* circuit gone */ }
        }
        active = false;
        history.Clear();
        pendingUser = null;
        error = null;
        State = VoiceState.Idle;
    }

    private async Task StartTurnAsync()
    {
        if (_module is null || !_supported || State != VoiceState.Idle) return;
        error = null;
        State = VoiceState.Recording;
        try
        {
            await _module.InvokeVoidAsync("start");
        }
        catch
        {
            State = VoiceState.Idle;
            error = "Couldn't access the microphone — check the browser's mic permission.";
        }
    }

    private async Task EndTurnAsync()
    {
        if (_module is null || State != VoiceState.Recording) return;
        State = VoiceState.Thinking;
        StateHasChanged();

        VoiceCapture? capture;
        try { capture = await _module.InvokeAsync<VoiceCapture?>("stop"); }
        catch { capture = null; }

        if (capture is null || string.IsNullOrEmpty(capture.Audio))
        {
            error = "Didn't catch that — hold the button a beat longer.";
            State = VoiceState.Idle;
            StateHasChanged();
            return;
        }

        var heard = await Stt.TranscribeAsync(new AudioClip(Convert.FromBase64String(capture.Audio), capture.MimeType));
        if (!heard.Success || string.IsNullOrWhiteSpace(heard.Text))
        {
            error = "Sorry — I couldn't make out the audio.";
            State = VoiceState.Idle;
            StateHasChanged();
            return;
        }

        pendingUser = heard.Text;
        StateHasChanged();

        // The multi-turn brain: pass the running history so "add the first two" resolves against the
        // previous reply. The tool-loop is the same tested IPantryChat.
        var result = await Chat.HandleAsync(heard.Text, history);
        history.Add(new ChatTurn(heard.Text, result.Reply));
        pendingUser = null;
        if (result.Success) await OnApplied.InvokeAsync();
        StateHasChanged();

        await SpeakAsync(result.Reply);
        State = VoiceState.Idle;
        StateHasChanged();
    }

    private async Task SpeakAsync(string text)
    {
        if (_module is null || string.IsNullOrWhiteSpace(text)) return;
        var speech = await Tts.SynthesizeAsync(text);
        if (!speech.Success) return; // the state change already applied; the read-back is a bonus
        State = VoiceState.Speaking;
        StateHasChanged();
        await _module.InvokeVoidAsync("play", Convert.ToBase64String(speech.Audio), speech.MediaType);
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("stopPlayback"); await _module.DisposeAsync(); }
            catch { /* circuit already gone */ }
        }
    }

    private sealed record VoiceCapture(string Audio, string MimeType, long Size);
}
