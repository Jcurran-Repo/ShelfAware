@* Multi-series line chart over the report engine's buckets — dependency-free SVG like the LineChart
   sparkline, but a full figure: zero-based value axis, hairline grid, thinned date ticks, hoverable
   point markers with native <title> tooltips. Colors come from the validated --chart-N slots; all
   text wears ink tokens.

   Gap semantics (UnitPrice is the only metric that produces nulls): an empty bucket NEVER reads as
   zero — the table shows a dash and no marker is drawn — but consecutive observations DO connect,
   the convention every price chart uses (and the Trends sparkline already follows). A segment that
   crosses one or more empty buckets is drawn DASHED: the trend line continues, and "no purchases in
   between" stays visible. Items bought less often than the grain (eggs every two weeks on a weekly
   axis) previously degenerated into a bare scatter — Jordan's catch. *@
@using ShelfAware.Core.Reporting

<svg class="report-chart" viewBox="0 0 @F(W) @F(H)" xmlns="http://www.w3.org/2000/svg"
     role="img" aria-label="@AriaLabel" preserveAspectRatio="xMidYMid meet">
    @foreach (var (value, y) in Ticks())
    {
        <line x1="@F(PadL)" y1="@F(y)" x2="@F(W - PadR)" y2="@F(y)"
              stroke="var(--line)" stroke-width="1" />
        @ChartFormat.SvgText(PadL - 6, y + 3.5, "end", ChartFormat.Tick(Unit, value))
    }

    @foreach (var (label, x) in XLabels())
    {
        @ChartFormat.SvgText(x, H - 6, "middle", label)
    }

    @foreach (var (series, si) in Series.Select((s, i) => (s, i)))
    {
        var color = ChartFormat.SeriesColor(series, si);
        @foreach (var segment in Segments(series))
        {
            <line x1="@F(segment.From.X)" y1="@F(segment.From.Y)" x2="@F(segment.To.X)" y2="@F(segment.To.Y)"
                  stroke="@color" stroke-width="2" stroke-linecap="round"
                  stroke-dasharray="@(segment.Bridged ? "5 5" : null)" />
        }
        @foreach (var point in Points(series))
        {
            <circle cx="@F(point.X)" cy="@F(point.Y)" r="3" fill="@color"
                    stroke="var(--surface)" stroke-width="1.5">
                <title>@Buckets[point.Bucket].Label · @series.Label: @ChartFormat.Value(Unit, point.Value)</title>
            </circle>
        }
    }

    <line x1="@F(PadL)" y1="@F(H - PadB)" x2="@F(W - PadR)" y2="@F(H - PadB)"
          stroke="var(--ink-soft)" stroke-width="1" />
</svg>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ReportBucket> Buckets { get; set; } = [];
    [Parameter, EditorRequired] public IReadOnlyList<ReportSeries> Series { get; set; } = [];
    [Parameter] public ReportUnit Unit { get; set; }
    [Parameter] public string AriaLabel { get; set; } = "Report chart";

    private const double W = 720, H = 280;
    private const double PadL = 56, PadR = 12, PadT = 14, PadB = 26;
    private double PlotW => W - PadL - PadR;
    private double PlotH => H - PadT - PadB;

    private readonly record struct PlotPoint(double X, double Y, int Bucket, decimal Value);

    private static string F(double v) => v.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    // DefaultIfEmpty: an empty-series result (a split over a window with no facts) must render an
    // empty frame, not throw — Max() on an empty sequence is an InvalidOperationException.
    private decimal MaxValue =>
        Series.SelectMany(s => s.Values).Select(v => v ?? 0).DefaultIfEmpty(0).Max() is var max && max > 0 ? max : 1;

    /// <summary>The axis always starts at zero — a truncated baseline is the classic way a chart
    /// lies, and nothing here is worth that. NiceStep keeps ticks at 1/2/2.5/5 × 10^k.</summary>
    private decimal TickStep()
    {
        var raw = MaxValue / 4m;
        var magnitude = (decimal)Math.Pow(10, Math.Floor(Math.Log10((double)raw)));
        var normalized = raw / magnitude;
        var nice = normalized <= 1 ? 1 : normalized <= 2 ? 2 : normalized <= 2.5m ? 2.5m : normalized <= 5 ? 5 : 10;
        return nice * magnitude;
    }

    private decimal AxisMax()
    {
        var step = TickStep();
        return Math.Ceiling(MaxValue / step) * step;
    }

    private IEnumerable<(decimal Value, double Y)> Ticks()
    {
        var step = TickStep();
        var top = AxisMax();
        for (var v = 0m; v <= top; v += step) yield return (v, YOf(v));
    }

    private double XOf(int bucket) =>
        Buckets.Count == 1 ? PadL + PlotW / 2 : PadL + (bucket + 0.5) * PlotW / Buckets.Count;

    private double YOf(decimal value) => PadT + (1 - (double)(value / AxisMax())) * PlotH;

    /// <summary>Every non-null observation as a plotted point (the tooltip carriers).</summary>
    private IEnumerable<PlotPoint> Points(ReportSeries series)
    {
        for (var i = 0; i < Buckets.Count && i < series.Values.Count; i++)
        {
            if (series.Values[i] is { } value)
                yield return new PlotPoint(XOf(i), YOf(value), i, value);
        }
    }

    /// <summary>Consecutive observations, pairwise. Bridged = the pair spans one or more empty
    /// buckets, so the segment draws dashed — the trend connects (a price series is an EVENT series;
    /// there is no value between purchases to falsify) while the sparseness stays legible. The
    /// bucket VALUES stay null throughout: the table dashes, and no marker appears in the gap.</summary>
    private IEnumerable<(PlotPoint From, PlotPoint To, bool Bridged)> Segments(ReportSeries series)
    {
        PlotPoint? previous = null;
        foreach (var point in Points(series))
        {
            if (previous is { } from)
                yield return (from, point, Bridged: point.Bucket - from.Bucket > 1);
            previous = point;
        }
    }

    /// <summary>Bucket labels thinned to at most ten, evenly, so long weekly windows never collide.</summary>
    private IEnumerable<(string Label, double X)> XLabels()
    {
        var every = Math.Max(1, (int)Math.Ceiling(Buckets.Count / 10.0));
        for (var i = 0; i < Buckets.Count; i += every)
            yield return (Buckets[i].Label, XOf(i));
    }
}
