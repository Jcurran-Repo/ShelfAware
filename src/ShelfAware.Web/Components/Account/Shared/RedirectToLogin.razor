@inject NavigationManager Navigation

@* Rendered by the router's NotAuthorized fallback. forceLoad: the login page is static SSR
   (excluded from interactive routing), so this must be a full document navigation. *@

@code {
    protected override void OnInitialized()
    {
        var returnUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
        Navigation.NavigateTo($"Account/Login?ReturnUrl={Uri.EscapeDataString(returnUrl)}", forceLoad: true);
    }
}
