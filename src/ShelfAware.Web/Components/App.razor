<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["ShelfAware.Web.styles.css"]" />
    <link rel="manifest" href="manifest.webmanifest" />
    <meta name="theme-color" content="#2563eb" />
    <link rel="icon" type="image/png" href="icons/icon-192.png" />
    <link rel="apple-touch-icon" href="icons/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Shelf Aware" />
    @* No <ImportMap /> (template scaffolding): it renders an INLINE <script type="importmap"> that the
       strict production CSP (script-src 'self' https://esm.sh, no hashes/nonces) blocks on every page.
       Nothing here needs it — every JS module is loaded by explicit URL (JS-interop `import "/js/…"`,
       cookalong's esm.sh dynamic import, ReconnectModal's direct fingerprinted src); no bare or
       relative module specifiers exist. If fingerprinted cross-module imports ever appear, restore it
       WITH a CSP hash/nonce rather than relaxing script-src. *@
    <HeadOutlet @rendermode="PageRenderMode" />
</head>

<body>
    <Routes @rendermode="PageRenderMode" />
    <ReconnectModal />
    <script src="@Assets["js/onboarding.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    // Global InteractiveServer EXCEPT the [ExcludeFromInteractiveRouting] Account pages, which must
    // render via static SSR: auth cookies can only be set on a real HTTP request, never over a
    // circuit. Both outlets must use the same mode. HttpContext is present here because App only
    // renders on the initial document request; the null guard is safety, not an expected path.
    private IComponentRenderMode? PageRenderMode =>
        HttpContext is null || HttpContext.AcceptsInteractiveRouting() ? InteractiveServer : null;
}
