@* Recipe read-aloud (button-controlled — no barge-in here). Synthesizes the recipe name + each step
   to audio (ElevenLabs TTS) and plays them as a step-by-step playlist with pause/resume/prev/next,
   highlighting the step currently being read. One reader is active at a time; the parent renders this
   once for the recipe being read.

   Narration STREAMS: the intro is synthesized and starts playing on its own, and the steps are
   synthesized behind playback and appended as they land. Waiting for the whole recipe first meant a
   ten-step recipe sat silent for eleven round-trips before the first word — which is most of why the
   button reader felt worse than the realtime agent, and it was never the voice's fault. *@
@using ShelfAware.Core.Speech
@using ShelfAware.Core.Chat
@implements IAsyncDisposable
@inject ITextToSpeech Tts
@inject ISpeechToText Stt
@inject IPantryChat Chat
@inject IJSRuntime JS
@inject VoiceCoordinator Coordinator
@inject ILogger<RecipeReadAloud> Logger

<div class="read-aloud panel">
    <div class="ra-head">
        <h3>@(HandsFree ? "🎙 Cooking" : "🔊 Reading"): @Recipe.Name</h3>
        <div class="ra-head-actions">
            <button class="secondary" @onclick="BackToAssistantAsync"
                    aria-label="Stop reading and hand back to the voice assistant" title="Stop reading and talk to the assistant">🎤 Back to assistant</button>
            <button class="icon-btn" @onclick="CloseAsync" aria-label="Stop reading @Recipe.Name" title="Stop reading">✕</button>
        </div>
    </div>

    @if (error is not null)
    {
        <p class="error">@error</p>
    }
    else if (preparing)
    {
        <p class="muted" role="status">Preparing narration…</p>
    }
    else
    {
        @if (steps.Count > 0)
        {
            <ol class="ra-steps">
                @for (var i = 0; i < steps.Count; i++)
                {
                    var stepNo = i + 1;
                    <li class="@(currentIndex == stepNo ? "current" : null)"
                        aria-current="@(currentIndex == stepNo ? "true" : null)">@steps[i].Text</li>
                }
            </ol>
        }
        @* The buttons stay in hands-free too: a mic can be denied, misheard, or simply not wanted, and
           a cook-along that can only be driven by voice is one bad transcript from being stuck. *@
        <div class="ra-controls" role="group" aria-label="Read-aloud controls">
            <button class="secondary" @onclick="PrevAsync" aria-label="Previous step">⏮ Prev</button>
            <button @onclick="TogglePauseAsync">@(paused ? "▶ Resume" : "⏸ Pause")</button>
            <button class="secondary" @onclick="NextAsync" aria-label="Next step">Next ⏭</button>
            @if (finished)
            {
                <button @onclick="ReplayAsync" aria-label="Replay from the start">↻ Replay</button>
            }
        </div>
        <p class="muted small" role="status">@Status</p>

        @if (HandsFree)
        {
            <div class="ra-listen">
                @if (micError is not null)
                {
                    <p class="muted small" role="status">@micError Use the buttons above.</p>
                    <button class="secondary" @onclick="ListenAgainAsync" aria-label="Try the microphone again">🎙 Try again</button>
                }
                else if (voiceStopped)
                {
                    <p class="muted small" role="status">Voice off — the recipe's still here. Use the buttons, or:</p>
                    <button class="secondary" @onclick="ListenAgainAsync" aria-label="Start listening again">🎙 Listen again</button>
                }
                else
                {
                    <p class="listen-state" role="status">
                        <span class="listen-dot listen-@(phase.ToString().ToLowerInvariant())" aria-hidden="true"></span>
                        @PhaseLabel
                    </p>
                    @if (lastHeard is not null)
                    {
                        <p class="muted small">You said: “@lastHeard”</p>
                    }
                    @if (lastReply is not null)
                    {
                        <p class="small">@lastReply</p>
                    }
                    <p class="muted small">Say “next”, “back”, “repeat”, “hold on”, or ask a question.</p>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public Recipe Recipe { get; set; } = null!;
    [Parameter] public EventCallback OnClosed { get; set; }

    /// <summary>Listen between steps instead of running the recipe end to end. Same reader, plus ears.</summary>
    [Parameter] public bool HandsFree { get; set; }

    // Enough turns for a follow-up ("what about butter?" after "can I swap the oil?") without letting a
    // two-hour cook grow the prompt forever.
    private const int MaxHistoryTurns = 6;

    // How long to hold the mic open, what counts as speech in this room, how much quiet means they've
    // finished. Calibrated per device if they've run the wizard (Settings), else the defaults — which are
    // guesses, and the reason the wizard exists.
    private ListeningSettings listening = ListeningSettings.Default;

    private IJSObjectReference? _module;
    private IJSObjectReference? _ear;
    private IJSObjectReference? _voice;
    private DotNetObjectReference<RecipeReadAloud>? _selfRef;

    // Two scopes, deliberately. _cts is the COMPONENT's life: it dies when the reader closes, and the
    // listening loop rides on it. _narration is just this batch of synthesis, cancelled the moment the
    // playlist is complete or abandoned — otherwise shutting the panel at step two leaves the remaining
    // steps synthesizing on the user's key for audio nobody will hear. Linking means closing the reader
    // still kills both; collapsing them into one would cancel the ears the instant synthesis finished.
    private readonly CancellationTokenSource _cts = new();
    private CancellationTokenSource? _narration;

    private List<RecipeStep> steps = [];
    private bool preparing = true;
    private string? error;
    private bool paused;
    private bool finished;
    private bool buffering; // playback caught up to synthesis and is waiting on the next segment
    private int currentIndex; // 0 = intro (recipe name); 1..N = step number being read

    // Hands-free state
    private enum Phase { Reading, Listening, Thinking, Answering, Held }
    private Phase phase = Phase.Reading;
    private bool held;          // they said "hold on" — stay put and keep listening for them
    private bool inListenTurn;      // guards against two loops racing if OnStepFinished re-fires
    private bool listenTurnPending; // a step finished while a loop was unwinding; don't drop its turn
    private bool voiceStopped;  // they said "stop" — mic down, recipe still on screen
    private string? micError;
    private string? lastHeard;
    private string? lastReply;
    private readonly List<ChatTurn> history = [];

    private string Status => finished
        ? "Done."
        : buffering ? "Catching up…"
        : currentIndex == 0 ? "Intro…" : $"Step {currentIndex} of {steps.Count}";

    private string PhaseLabel => phase switch
    {
        Phase.Listening => "Listening…",
        Phase.Thinking => "Thinking…",
        Phase.Answering => "Answering…",
        Phase.Held => "Holding — ignoring the room until you say “I'm back”.",
        _ => "Reading…",
    };

    protected override void OnInitialized() =>
        steps = Recipe.Steps.OrderBy(s => s.Order).ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _module = await JS.InvokeAsync<IJSObjectReference>("import", "/js/readaloud.js");
        _selfRef = DotNetObjectReference.Create(this);

        if (HandsFree) await OpenEarsAsync();

        // Segment 0 = spoken intro (name + blurb); segments 1..N = the steps, so a segment index maps
        // straight onto a step number for highlighting.
        var texts = new List<string> { Intro() };
        texts.AddRange(steps.Select((s, i) => $"Step {i + 1}. {s.Text}"));

        try
        {
            await NarrateAsync(_module, texts);
        }
        catch (OperationCanceledException)
        {
            // The reader was closed mid-narration. Our own cancel — nothing to report.
        }
    }

    /// <summary>
    /// Take the mic for the session. A refusal is not a failure: the reader keeps working on buttons,
    /// which is why they're still on screen in hands-free mode.
    /// </summary>
    private async Task OpenEarsAsync()
    {
        // There's one microphone. If the roaming assistant is up, it must let go before we take it —
        // two loops transcribing the same room would both answer every utterance and bill for it.
        await Coordinator.RequestStandDownAsync();

        // Re-entrant: "Listen again" comes back through here after a stop, and the modules are already
        // loaded by then — only the audio session needs rebuilding (endSession tore it down).
        _ear ??= await JS.InvokeAsync<IJSObjectReference>("import", "/js/cooklisten.js");
        _voice ??= await JS.InvokeAsync<IJSObjectReference>("import", "/js/voice.js");

        if (!await _ear.InvokeAsync<bool>("isSupported"))
        {
            micError = "This browser can't listen.";
            return;
        }

        // Clamped on the way in: this came from the browser's own storage, where anything could be.
        listening = (await _ear.InvokeAsync<ListeningSettings?>("loadSettings") ?? ListeningSettings.Default).Clamped();

        var session = await _ear.InvokeAsync<SessionResult>("startSession");
        if (!session.Ok)
        {
            micError = session.Error == "NotAllowedError"
                ? "No microphone access."
                : "Couldn't open the microphone.";
            Logger.LogInformation("Hands-free cook-along couldn't open the mic: {Error}", session.Error);
        }
    }

    /// <summary>
    /// Play the intro as soon as it exists, then queue the steps behind it. The steps synthesize with
    /// bounded parallelism (a long recipe shouldn't narrate at one round-trip per step, nor hammer the
    /// provider's concurrency limit) but are awaited IN ORDER, so the playlist stays in step order even
    /// though the calls finish out of order.
    /// </summary>
    private async Task NarrateAsync(IJSObjectReference player, IReadOnlyList<string> texts)
    {
        _narration = CancellationTokenSource.CreateLinkedTokenSource(_cts.Token);

        var intro = await Tts.SynthesizeAsync(texts[0], ContextFor(texts, 0), _narration.Token);
        if (!intro.Success)
        {
            error = "Couldn't generate the narration — check that the ElevenLabs key is set.";
            preparing = false;
            StateHasChanged();
            return;
        }

        preparing = false;
        paused = false;
        // autoAdvance: hands-free stops after each step to give the cook a turn; the button reader runs on.
        await player.InvokeVoidAsync("load", new[] { SegmentFor(intro) }, _selfRef, texts.Count > 1, !HandsFree);
        StateHasChanged();
        await player.InvokeVoidAsync("playFrom", 0);

        if (texts.Count == 1) return; // no steps — load(more: false) already told the player that

        var rest = StartSteps(texts, maxConcurrency: 4);
        try
        {
            for (var i = 0; i < rest.Length; i++)
            {
                var clip = await rest[i];
                if (!clip.Success)
                {
                    // Never silently skip a cooking step — the listener's hands are busy and they'd
                    // never know a step went missing. Stop here and say so; the steps are on screen.
                    error = $"Couldn't narrate step {i + 1}. The remaining steps are listed above.";
                    StateHasChanged();
                    break;
                }
                await player.InvokeVoidAsync("append", SegmentFor(clip));
            }
        }
        finally
        {
            // Stop anything still queued (we broke out, or the reader closed), then let the player know
            // the playlist is closed so it can finish instead of waiting for a segment that isn't coming.
            // This cancels the NARRATION only — the component (and its ears) outlive it.
            await _narration.CancelAsync();
            await DrainAsync(rest);
            await TellPlayerAsync("endOfStream");
        }
    }

    private string Intro() =>
        string.IsNullOrWhiteSpace(Recipe.Blurb) ? $"{Recipe.Name}." : $"{Recipe.Name}. {Recipe.Blurb}";

    /// <summary>The neighbouring segments, so the provider can carry intonation across the cut.</summary>
    private static SpeechContext ContextFor(IReadOnlyList<string> texts, int i) =>
        new(Previous: i > 0 ? texts[i - 1] : null,
            Next: i + 1 < texts.Count ? texts[i + 1] : null);

    private static Segment SegmentFor(TextToSpeechResult clip) =>
        new(Convert.ToBase64String(clip.Audio), clip.MediaType);

    /// <summary>
    /// Starts synthesis of segments 1..N and hands back their tasks in order. The gate is deliberately
    /// not disposed: it outlives this method along with the tasks it throttles, and SemaphoreSlim only
    /// holds a disposable wait handle if AvailableWaitHandle is read, which we never do.
    /// </summary>
    private Task<TextToSpeechResult>[] StartSteps(IReadOnlyList<string> texts, int maxConcurrency)
    {
        var token = _narration!.Token;
        var gate = new SemaphoreSlim(maxConcurrency);
        return Enumerable.Range(1, texts.Count - 1).Select(async i =>
        {
            await gate.WaitAsync(token);
            try { return await Tts.SynthesizeAsync(texts[i], ContextFor(texts, i), token); }
            finally { gate.Release(); }
        }).ToArray();
    }

    /// <summary>Observe every task before we walk away, so a cancelled one can't surface later as an
    /// unobserved exception.</summary>
    private static async Task DrainAsync(Task<TextToSpeechResult>[] tasks)
    {
        try { await Task.WhenAll(tasks); }
        catch (OperationCanceledException) { /* expected: we cancelled them */ }
    }

    private async Task TellPlayerAsync(string fn)
    {
        if (_module is null) return;
        try { await _module.InvokeVoidAsync(fn); }
        catch (JSDisconnectedException) { /* circuit already gone — nothing to tell */ }
    }

    private async Task TogglePauseAsync()
    {
        if (_module is null) return;
        paused = await _module.InvokeAsync<bool>("togglePause");
    }

    private async Task NextAsync()
    {
        if (_module is null) return;
        finished = false;
        paused = false;
        await _module.InvokeVoidAsync("next");
    }

    private async Task PrevAsync()
    {
        if (_module is null) return;
        finished = false;
        paused = false;
        await _module.InvokeVoidAsync("prev");
    }

    private async Task ReplayAsync()
    {
        if (_module is null) return;
        finished = false;
        paused = false;
        await _module.InvokeVoidAsync("playFrom", 0);
    }

    private async Task CloseAsync()
    {
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("stop"); } catch { /* circuit gone */ }
        }
        await OnClosed.InvokeAsync();
    }

    // Hand control back to the persistent voice assistant. Stop the narration FIRST so its tail doesn't
    // bleed into the mic, then ping the coordinator, which resumes the layout agent's listening loop.
    private async Task BackToAssistantAsync()
    {
        await CloseAsync();
        await Coordinator.RequestResumeAsync();
    }

    [JSInvokable]
    public Task OnIndex(int i)
    {
        Logger.LogInformation("Cook-along reader moved to segment {Index}.", i);
        currentIndex = i;
        finished = false;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnFinished()
    {
        finished = true;
        paused = false;
        buffering = false;
        return InvokeAsync(StateHasChanged);
    }

    /// <summary>Playback outran synthesis (or caught back up) — say so rather than freezing the step
    /// counter with no explanation.</summary>
    [JSInvokable]
    public Task OnBuffering(bool on)
    {
        buffering = on;
        return InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Hands-free only: a step finished playing and the player did NOT run on, so it's the cook's turn.
    /// </summary>
    [JSInvokable]
    public async Task OnStepFinished(int _)
    {
        if (!HandsFree || micError is not null || voiceStopped || _cts.IsCancellationRequested) return;

        // A step can finish while the previous turn's loop is still unwinding — a command hands control
        // back to playback, and if that clip ends before the loop has finished exiting, its turn arrives
        // to find the door still shut. Remember it rather than dropping it: a dropped turn is a reader
        // that has gone quietly deaf, which looks like the microphone died.
        if (inListenTurn) { listenTurnPending = true; return; }
        await ListenUntilReadingAsync();
    }

    /// <summary>
    /// Keep taking turns until something puts audio back on. Not-hearing costs nothing — the noise gate
    /// drops a quiet window before it ever becomes a speech-to-text call — so it's fine to sit here for
    /// as long as they're chopping.
    /// </summary>
    private async Task ListenUntilReadingAsync()
    {
        if (inListenTurn) return; // one loop at a time

        do
        {
            listenTurnPending = false;
            inListenTurn = true;
            try
            {
                while (!_cts.IsCancellationRequested && !await TakeTurnAsync()) { }
            }
            catch (OperationCanceledException)
            {
                // Reader closed while we were listening. Ours — nothing to report.
                return;
            }
            catch (JSDisconnectedException)
            {
                // Circuit gone; the browser has stopped caring about this reader.
                return;
            }
            finally
            {
                inListenTurn = false;
            }
        }
        // A step finished while we were unwinding, and OnStepFinished found the door shut. Take its turn
        // now rather than leaving the cook talking to a reader that stopped listening.
        while (listenTurnPending && !voiceStopped && micError is null && !_cts.IsCancellationRequested);
    }

    /// <summary>One listening turn. Returns true when the turn handed control back to playback (or ended
    /// the session), false to listen again.</summary>
    private async Task<bool> TakeTurnAsync()
    {
        await SetPhaseAsync(held ? Phase.Held : Phase.Listening);
        await CueAsync(rising: true);

        var window = await _ear!.InvokeAsync<HeardResult>("listen", listening);
        if (_cts.IsCancellationRequested) return true;

        // The room never rose above its own noise floor. No transcript, no cost, no turn.
        if (!window.Heard || window.Audio is null) return false;

        await CueAsync(rising: false);
        await SetPhaseAsync(Phase.Thinking);

        var clip = new AudioClip(Convert.FromBase64String(window.Audio), window.MimeType ?? "audio/webm");
        var stt = await Stt.TranscribeAsync(clip, _cts.Token);
        if (!stt.Success || string.IsNullOrWhiteSpace(stt.Text))
        {
            // Heard something, made nothing of it — a dropped pan, the radio. Listen again rather than
            // guessing, and never wake the brain for it.
            if (!stt.Success) Logger.LogInformation("Cook-along transcription failed: {Error}", stt.Error);
            return false;
        }

        lastHeard = stt.Text;
        return await ApplyAsync(stt.Text);
    }

    /// <summary>Act on one understood utterance. Returns true when playback resumed or we're closing.</summary>
    private async Task<bool> ApplyAsync(string text)
    {
        var command = CookAlongCommands.Match(text);
        var intent = command.Intent;

        // What it heard and what it decided, in one line. A voice loop is otherwise unobservable: when it
        // does the wrong thing you have only the user's account of a conversation nobody recorded.
        Logger.LogInformation(
            "Cook-along heard \"{Transcript}\" -> {Intent}{Step} (reader on segment {Index}, held={Held})",
            text, intent, command.Step is { } s ? $" step {s}" : "", currentIndex, held);

        // Coming back from a hold. If something is genuinely paused mid-sentence (only the on-screen
        // Pause button can cause that — we don't listen while we're talking), any carry-on phrase resumes
        // it. Otherwise the hold was taken during a listening window, nothing is paused, and the command
        // means exactly what it says: "next" is NEXT, not "resume the nothing that's playing".
        if (held && intent is not CookAlongIntent.None)
        {
            held = false;
            lastReply = null;

            if (intent is CookAlongIntent.Next or CookAlongIntent.Resume)
            {
                if (await ResumeAsync())
                {
                    await SetPhaseAsync(Phase.Reading);
                    return true;
                }
                // "I'm back" with nothing to resume just means carry on listening — stay put.
                if (intent is CookAlongIntent.Resume)
                {
                    await SetPhaseAsync(Phase.Listening);
                    return false;
                }
            }
        }
        else if (!held && intent is CookAlongIntent.Resume)
        {
            // "go ahead" while we're already going means the next step.
            intent = CookAlongIntent.Next;
        }

        switch (intent)
        {
            case CookAlongIntent.Next:
                await ResumeReadingAsync("next");
                return true;

            case CookAlongIntent.Back:
                await ResumeReadingAsync("prev");
                return true;

            case CookAlongIntent.Repeat:
                await ResumeReadingAsync("playFrom", currentIndex);
                return true;

            // Segment 0 is the intro and 1..N are the steps, so a step number IS its segment index.
            case CookAlongIntent.GoToStep when command.Step is { } n && n >= 0 && n <= steps.Count:
                await ResumeReadingAsync("playFrom", n);
                return true;

            case CookAlongIntent.GoToStep:
                // A step this recipe doesn't have. The brain has the steps in context and can say so
                // ("there are only seven") far better than we can — this is exactly what it's for.
                return await AskBrainAsync(text);

            case CookAlongIntent.Hold:
                // Hold can't pause a sentence — we aren't listening while we speak, so by the time you
                // can say it, the step has already finished and the reader is waiting anyway. What it
                // CAN do is stop us reacting to the room: while held we ignore anything that isn't a
                // command, so a rustling bag can't wake the brain and answer a question nobody asked.
                held = true;
                await SetPhaseAsync(Phase.Held);
                return false;

            case CookAlongIntent.Stop:
                // "Stop listening" means stop LISTENING — it isn't "throw the recipe away". Someone with
                // their hands full who wants the mic off still wants the steps in front of them. Release
                // the microphone, stop the audio, keep the panel and its buttons.
                await StopListeningAsync();
                return true;

            default:
                // Not a command, so it's a question — unless we're holding, in which case they told us
                // they're busy and the room isn't talking to us.
                if (held) return false;
                // Guard the brain against the kitchen: a single stray syllable is not worth a model call.
                if (!CookAlongCommands.IsWorthAsking(text)) return false;
                return await AskBrainAsync(text);
        }
    }

    /// <summary>
    /// The fall-through, and the whole reason this is a cook-along rather than a voice remote: anything
    /// the grammar doesn't own goes to the SAME brain the assistant uses. The recipe rides in as screen
    /// context — the mechanism that already lets the roaming agent resolve "the second one" — so no new
    /// brain API was needed to make it aware of what's on the hob.
    ///
    /// It can also MOVE us (go_to_step), which is what lets the grammar stay conservative: a phrasing it
    /// doesn't know costs a model call instead of getting the wrong answer. Returns true when it moved.
    /// </summary>
    private async Task<bool> AskBrainAsync(string question)
    {
        await SetPhaseAsync(Phase.Thinking);

        var result = await Chat.HandleAsync(question, history, CookContext(), _cts.Token);
        history.Add(new ChatTurn(question, result.Reply));
        if (history.Count > MaxHistoryTurns) history.RemoveRange(0, history.Count - MaxHistoryTurns);

        // It understood a move the grammar missed. The step IS the answer — reading "sure, here's step
        // four" first would just be latency between them and the thing they asked for.
        if (result.StepTarget is { } step && step >= 0 && step <= steps.Count)
        {
            lastReply = null;
            await ResumeReadingAsync("playFrom", step);
            return true;
        }

        lastReply = result.Reply;

        // NavigateTo is deliberately ignored here. The brain can decide a question is best answered on
        // another page, but yanking someone to the grocery list mid-sear would end the cook-along they're
        // standing in. They can say "stop" if they want to leave.
        await SetPhaseAsync(Phase.Answering);
        var speech = await Tts.SynthesizeAsync(result.Reply, null, _cts.Token);
        if (speech.Success && _voice is not null)
        {
            await _voice.InvokeVoidAsync("play", Convert.ToBase64String(speech.Audio), speech.MediaType);
        }
        return false; // answered — stay on this step and keep listening
    }

    private async Task ResumeReadingAsync(string fn, params object[] args)
    {
        held = false;
        lastReply = null;
        finished = false;
        paused = false;
        await SetPhaseAsync(Phase.Reading);
        Logger.LogInformation("Cook-along telling the reader: {Fn}({Args}).", fn, string.Join(", ", args));
        if (_module is not null) await _module.InvokeVoidAsync(fn, args);
    }

    /// <summary>Resume playback. False when there was nothing playing to resume (the step had already
    /// finished), which is not a failure — it just means the turn isn't over.</summary>
    private async Task<bool> ResumeAsync()
    {
        paused = false;
        if (_module is null) return false;
        return await _module.InvokeAsync<bool>("resume");
    }

    /// <summary>
    /// What the cook is looking at — except they aren't looking at it, which is the point of the last
    /// line. Without it the model writes for a screen and the reader recites a paragraph at someone
    /// holding a hot pan.
    /// </summary>
    private string CookContext()
    {
        var where = currentIndex == 0 ? "the introduction" : $"step {currentIndex} of {steps.Count}";
        var lines = new List<string>
        {
            $"The user is cooking \"{Recipe.Name}\" hands-free and is currently on {where}.",
        };

        if (Recipe.Ingredients.Count > 0)
            lines.Add("Ingredients: " + string.Join(", ", Recipe.Ingredients.Select(i => i.Name)) + ".");

        lines.Add("Steps: " + string.Join(" ", steps.Select((s, i) => $"({i + 1}) {s.Text}")));
        lines.Add("They are listening, not reading, with their hands busy — answer their cooking question "
                  + "in one or two short spoken sentences.");
        // Everything reaching the brain has ALREADY missed the plain-code grammar, so a movement phrasing
        // that gets here is by definition an odd one — garbled, coughed through, or just unlisted. Say so,
        // or it will helpfully answer "up next" instead of doing it.
        lines.Add("If they are asking to MOVE around the recipe rather than asking a question — however "
                  + "oddly it is worded, and even if it sounds garbled — use go_to_step instead of "
                  + "replying. Simple commands are handled before you see them, so anything that reaches "
                  + "you has already been misheard once.");
        return string.Join(' ', lines);
    }

    /// <summary>Put the microphone down but leave the recipe up. Reversible via "Listen again".</summary>
    private async Task StopListeningAsync()
    {
        voiceStopped = true;
        held = false;
        lastHeard = null;
        lastReply = null;

        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("pause"); }
            catch (JSDisconnectedException) { /* circuit gone */ }
        }
        await ReleaseMicAsync();
        await SetPhaseAsync(Phase.Reading);
    }

    private async Task ReleaseMicAsync()
    {
        if (_ear is null) return;
        try { await _ear.InvokeVoidAsync("endSession"); }
        catch (JSDisconnectedException) { /* circuit gone — the browser released it with us */ }
    }

    /// <summary>Take the mic back after a "stop listening" (or a denial they've since fixed).</summary>
    private async Task ListenAgainAsync()
    {
        micError = null;
        voiceStopped = false;
        await OpenEarsAsync();
        if (micError is not null) { StateHasChanged(); return; }
        await ListenUntilReadingAsync();
    }

    private async Task CueAsync(bool rising)
    {
        if (_ear is null) return;
        try { await _ear.InvokeVoidAsync("beep", rising); }
        catch (JSDisconnectedException) { /* circuit gone — the cue is the least of it */ }
    }

    private Task SetPhaseAsync(Phase next)
    {
        phase = next;
        return InvokeAsync(StateHasChanged);
    }

    private sealed record SessionResult(bool Ok, string? Error, double Floor);
    private sealed record HeardResult(bool Heard, string? Audio, string? MimeType, string? Error);

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();

        // Release the microphone first and unconditionally: leaving a browser's recording indicator lit
        // after the panel is gone is alarming, and rightly so.
        if (_ear is not null)
        {
            try
            {
                await _ear.InvokeVoidAsync("endSession");
                await _ear.DisposeAsync();
            }
            catch (JSDisconnectedException) { /* circuit gone — the browser released the mic with it */ }
        }

        if (_voice is not null)
        {
            try
            {
                await _voice.InvokeVoidAsync("stopPlayback");
                await _voice.DisposeAsync();
            }
            catch (JSDisconnectedException) { /* circuit gone */ }
        }

        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("stop");
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException) { /* circuit already gone — nothing to stop */ }
        }

        _selfRef?.Dispose();
        _narration?.Dispose();
        _cts.Dispose();
    }

    private sealed record Segment(string Base64, string Mime);
}
