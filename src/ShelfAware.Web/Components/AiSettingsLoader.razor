@* Reads the visitor's BYOK settings from localStorage on circuit start and applies them to this circuit's
   CircuitAiSettings, so their own provider/key/models drive their AI calls. Renders nothing. In local dev
   with an empty browser store, the server-config (user-secrets) fallback stays in effect. *@
@using ShelfAware.Llm
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject CircuitAiSettings Settings
@inject CircuitVoiceCredentials Voice
@inject ILogger<AiSettingsLoader> Log

@code {
    private IJSObjectReference? _module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "/js/ai-settings.js");
            var stored = await _module.InvokeAsync<StoredSettings?>("resolveActive");
            if (stored is { } s && !string.IsNullOrWhiteSpace(s.ApiKey))
            {
                var provider = Enum.TryParse<AiProvider>(s.Provider, ignoreCase: true, out var p) ? p : AiProvider.Anthropic;
                Settings.Apply(provider, s.ApiKey, s.ExtractionModel, s.ChatModel);
            }

            // Voice credentials (used server-side, per circuit, to call ElevenLabs). Only override the dev
            // fallback when the visitor actually has a key.
            var voice = await _module.InvokeAsync<VoiceCreds?>("voiceCreds");
            if (voice is { } v && !string.IsNullOrWhiteSpace(v.ApiKey))
                Voice.Apply(v.ApiKey, v.AgentId);
        }
        catch (JSDisconnectedException)
        {
            // Circuit went away mid-load — nothing to apply; ignore.
        }
        catch (Exception ex)
        {
            // Best-effort: fall back to the server config. Log so a genuine interop bug is visible.
            Log.LogWarning(ex, "Couldn't load BYOK settings from the browser; using the server-config fallback.");
        }
    }

    private sealed record StoredSettings(string Provider, string ApiKey, string? ExtractionModel, string? ChatModel);
    private sealed record VoiceCreds(string ApiKey, string AgentId);

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { /* circuit already gone */ }
        }
    }
}
