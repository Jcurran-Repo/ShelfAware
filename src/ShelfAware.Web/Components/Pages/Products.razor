@page "/products"
@using ShelfAware.Core.Prediction
@using ShelfAware.Core.Shopping
@inject IHouseholdDbFactory DbFactory
@inject IJSRuntime JS
@inject ILogger<Products> Logger

<PageTitle>Products — Shelf Aware</PageTitle>

<div class="page-head">
    <h1>Products</h1>
    @if (products is not null)
    {
        <span class="muted">Showing @FilteredProducts.Count() of @products.Count</span>
    }
</div>

<section class="panel">
    <h2>Add product</h2>
    <form @onsubmit="AddProduct" @formname="add-product" aria-label="Add product">
        <input placeholder="Name" aria-label="New product name" @bind="newName" />
        <select aria-label="New product category" @bind="newCategory">
            @foreach (var c in Enum.GetValues<Category>())
            {
                <option value="@c">@c</option>
            }
        </select>
        <input placeholder="Default unit (optional)" aria-label="Default unit (optional)" @bind="newUnit" size="14" />
        <button type="submit">Add</button>
    </form>
    @if (addError is not null)
    {
        <p class="error">@addError</p>
    }
</section>

@if (products is null)
{
    <p>Loading…</p>
}
else
{
    var shown = FilteredProducts.ToList();

    @if (tagCounts.Count > 0)
    {
        <div class="tag-cloud" role="group" aria-label="Filter products by tag">
            <span class="muted">Filter by tag:</span>
            @foreach (var (value, count) in tagCounts)
            {
                var active = string.Equals(value, tagFilter, StringComparison.OrdinalIgnoreCase);
                <button type="button" class="tag-chip tag-cloud-chip @(active ? "active" : "")"
                        @onclick="() => ToggleTag(value)" aria-pressed="@active">
                    @value <span class="tag-count">@count</span>
                </button>
            }
            @if (tagFilter is not null)
            {
                <button type="button" class="tag-clear" @onclick="() => ToggleTag(tagFilter!)">Clear ✕</button>
            }
        </div>
    }

    <table>
        <caption class="visually-hidden">Products with category, tracking, purchase count, replenishment status, and next predicted buy date. Use the filter row to narrow the list.</caption>
        <thead>
            <tr>
                <th scope="col">Name</th>
                <th scope="col">Category</th>
                <th scope="col">Tracked</th>
                <th scope="col">Purchases</th>
                <th scope="col">Status</th>
                <th scope="col">Next buy</th>
                <th scope="col"><span class="visually-hidden">Actions</span></th>
            </tr>
            <tr class="filter-row">
                <th><input type="search" placeholder="Search…" aria-label="Search products by name" @bind="searchText" @bind:event="oninput" /></th>
                <th>
                    <select aria-label="Filter by category" @bind="categoryFilter">
                        <option value="">All</option>
                        @foreach (var c in Enum.GetValues<Category>())
                        {
                            <option value="@c">@c</option>
                        }
                    </select>
                </th>
                <th>
                    <select aria-label="Filter by tracking" @bind="trackedFilter">
                        <option value="">All</option>
                        <option value="true">Tracked</option>
                        <option value="false">Untracked</option>
                    </select>
                </th>
                <th></th>
                <th>
                    <select aria-label="Filter by status" @bind="statusFilter">
                        <option value="">All</option>
                        <option value="Overdue">Overdue</option>
                        <option value="DueSoon">Due soon</option>
                        <option value="Stocked">Stocked</option>
                        <option value="Unknown">Still learning</option>
                    </select>
                </th>
                <th></th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in shown)
            {
                var e = estimates[p.Id];
                <tr>
                    <td>
                        <a class="item-name" href="/product/@p.Id">@p.Name</a>
                        @{ var ub = e.UsualBrand; var rs = e.RecommendedSize; }
                        @if (rs is { Length: > 0 } || ub is not null || p.Tags.Count > 0)
                        {
                            <div class="item-meta">
                                @if (rs is { Length: > 0 } sz)
                                {
                                    <span class="size-chip" title="Usual size to buy">@sz</span>
                                }
                                @if (ub is not null)
                                {
                                    <span class="usual-brand">@ub</span>
                                }
                                @foreach (var t in p.Tags.OrderBy(t => t.Value))
                                {
                                    <button type="button" class="tag-chip tag-chip-mini" @onclick="() => ToggleTag(t.Value)" title="Filter by @t.Value">@t.Value</button>
                                }
                            </div>
                        }
                    </td>
                    <td>
                        <select value="@p.Category" aria-label="Category for @p.Name" @onchange="ev => SetCategory(p, (string?)ev.Value)">
                            @foreach (var c in Enum.GetValues<Category>())
                            {
                                <option value="@c">@c</option>
                            }
                        </select>
                    </td>
                    <td><input type="checkbox" checked="@p.IsTracked" aria-label="Track @p.Name" @onchange="ev => SetTracked(p, (bool)ev.Value!)" /></td>
                    <td>@purchaseCounts.GetValueOrDefault(p.Id)</td>
                    <td><span class="chip chip-@ChipClass(e.Status)">@StatusLabel(e.Status)</span></td>
                    <td class="nextbuy">
                        @if (e.NextBuyDate is { } d)
                        {
                            @d.ToString("MMM d")
                            <span class="muted"> (@Relative(e.DaysUntil!.Value))</span>
                        }
                        else
                        {
                            <span class="muted">still learning</span>
                        }
                        <button class="info-btn" popovertarget="est-@p.Id" aria-label="Purchase details for @p.Name"><span aria-hidden="true">ⓘ</span></button>
                        <div popover id="est-@p.Id" class="popover">
                            <strong>@p.Name</strong>
                            <dl>
                                <dt>Last bought</dt>
                                <dd>@(e.LastPurchased?.ToString("yyyy-MM-dd") ?? "never")</dd>
                                <dt>Typical buy</dt>
                                <dd>@e.RecommendedQuantity.ToString("0.##")@(p.DefaultUnit is { } u ? " " + u : "")</dd>
                                <dt>Next buy</dt>
                                <dd>@(e.NextBuyDate is { } nb ? $"{nb:yyyy-MM-dd} ({Relative(e.DaysUntil!.Value)})" : "still learning")</dd>
                                <dt>Est. unit price</dt>
                                <dd>@(e.UnitPrice is { } up ? up.ToString("C") : "unknown")</dd>
                                <dt>Est. cost</dt>
                                <dd>@(e.ExpectedCost is { } cost ? cost.ToString("C") : "unknown")</dd>
                            </dl>
                            <a href="/product/@p.Id">View history →</a>
                        </div>
                    </td>
                    <td class="row-actions">
                        <button class="mark-out" @onclick="() => MarkOut(p)" aria-label="Mark @p.Name out of stock" title="Mark @p.Name out of stock">Out</button>
                        <button class="icon-btn" @onclick="() => Delete(p)" aria-label="Delete @p.Name" title="Delete @p.Name"><span aria-hidden="true">🗑</span></button>
                    </td>
                </tr>
            }
            @if (shown.Count == 0)
            {
                <tr class="empty-row"><td colspan="7">No products match these filters.</td></tr>
            }
        </tbody>
    </table>
    @if (deleteError is not null)
    {
        <p class="error" role="alert">@deleteError</p>
    }
}

@code {
    private List<Product>? products;
    private Dictionary<int, int> purchaseCounts = [];
    private Dictionary<int, PredictionResult> predictions = [];
    private Dictionary<int, ProductEstimate> estimates = [];

    private string newName = "";
    private Category newCategory = Category.Pantry;
    private string newUnit = "";
    private string? addError;
    private string? deleteError;

    private string searchText = "";
    private string categoryFilter = "";
    private string statusFilter = "";
    private string trackedFilter = "";
    private string? tagFilter;
    private List<(string Value, int Count)> tagCounts = [];

    /// <summary>Deep-link from a tag chip elsewhere (e.g. Product Detail) → /products?tag=Condiment.</summary>
    [SupplyParameterFromQuery(Name = "tag")] public string? Tag { get; set; }

    private IEnumerable<Product> FilteredProducts => (products ?? Enumerable.Empty<Product>()).Where(p =>
    {
        if (searchText.Trim() is { Length: > 0 } q && !p.Name.Contains(q, StringComparison.OrdinalIgnoreCase)) return false;
        if (categoryFilter.Length > 0 && p.Category.ToString() != categoryFilter) return false;
        if (trackedFilter.Length > 0 && p.IsTracked != bool.Parse(trackedFilter)) return false;
        if (statusFilter.Length > 0 && (!predictions.TryGetValue(p.Id, out var r) || r.Status.ToString() != statusFilter)) return false;
        if (tagFilter is { Length: > 0 } && !p.Tags.Any(t => string.Equals(t.Value, tagFilter, StringComparison.OrdinalIgnoreCase))) return false;
        return true;
    });

    private void ToggleTag(string value) =>
        tagFilter = string.Equals(value, tagFilter, StringComparison.OrdinalIgnoreCase) ? null : value;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        if (Tag is { Length: > 0 }) tagFilter = Tag; // honor the deep-link on first load
    }

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        products = await db.Products
            .AsNoTracking() // display load; edits save through a fresh context (see Save)
            .Include(p => p.Purchases)
            .Include(p => p.Signals)
            .Include(p => p.Tags)
            .OrderBy(p => p.Name)
            .ToListAsync();
        purchaseCounts = products.ToDictionary(p => p.Id, p => p.Purchases.Count);
        tagCounts = products
            .SelectMany(p => p.Tags)
            .GroupBy(t => t.Value, StringComparer.OrdinalIgnoreCase)
            .Select(g => (Value: g.Key, Count: g.Count()))
            .OrderByDescending(x => x.Count).ThenBy(x => x.Value)
            .ToList();

        // Confirmed unit price per product, keyed by size so the estimate prices the recommended
        // (dominant) size rather than blending across sizes; falls back to the product's overall average.
        var priceLines = await db.ReceiptLines
            .Where(l => l.ProductId != null && l.UnitPrice != null)
            .Select(l => new { Id = l.ProductId!.Value, l.Size, Price = l.UnitPrice!.Value })
            .ToListAsync();
        var priceBySize = priceLines
            .GroupBy(x => (x.Id, Key: SizeKey(x.Size)))
            .ToDictionary(g => g.Key, g => g.Average(x => x.Price));
        var priceByProduct = priceLines
            .GroupBy(x => x.Id)
            .ToDictionary(g => g.Key, g => g.Average(x => x.Price));

        decimal? PriceFor(int productId, string? recommendedSize)
        {
            if (priceBySize.TryGetValue((productId, SizeKey(recommendedSize)), out var sp)) return sp;
            return priceByProduct.TryGetValue(productId, out var ap) ? ap : null;
        }

        var today = DateOnly.FromDateTime(DateTime.Today);
        predictions = products.ToDictionary(p => p.Id, p => ReplenishmentPredictor.Predict(p, today));
        estimates = products.ToDictionary(
            p => p.Id,
            p => ShoppingEstimator.For(p, predictions[p.Id], today, PriceFor(p.Id, predictions[p.Id].RecommendedSize)));
    }

    private static string SizeKey(string? size) => (size ?? "").Trim().ToLowerInvariant();

    private static string Relative(int days) => days switch
    {
        < 0 => $"{-days} day{P(-days)} overdue",
        0 => "today",
        _ => $"in {days} day{P(days)}"
    };

    private static string P(int n) => n == 1 ? "" : "s";

    private static string ChipClass(PredictionStatus s) => s switch
    {
        PredictionStatus.Overdue => "overdue",
        PredictionStatus.DueSoon => "duesoon",
        PredictionStatus.Stocked => "stocked",
        _ => "unknown"
    };

    private static string StatusLabel(PredictionStatus s) => s switch
    {
        PredictionStatus.Overdue => "Overdue",
        PredictionStatus.DueSoon => "Due soon",
        PredictionStatus.Stocked => "Stocked",
        _ => "Still learning"
    };

    private async Task AddProduct()
    {
        addError = null;
        var name = newName.Trim();
        if (name.Length == 0)
        {
            addError = "Name is required.";
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        db.Products.Add(new Product
        {
            Name = name,
            Category = newCategory,
            DefaultUnit = string.IsNullOrWhiteSpace(newUnit) ? null : newUnit.Trim()
        });
        await db.SaveChangesAsync();
        newName = "";
        newUnit = "";
        await LoadAsync();
    }

    private async Task SetCategory(Product p, string? value)
    {
        if (!Enum.TryParse<Category>(value, out var category)) return;
        p.Category = category;
        await Save(p);
    }

    private async Task SetTracked(Product p, bool tracked)
    {
        p.IsTracked = tracked;
        await Save(p);
    }

    private async Task Save(Product p)
    {
        // Write only the product row. Update(p) would walk the loaded graph (Purchases/Signals/Tags) and
        // mark every child Modified as well — needless UPDATEs. Attaching and marking just the root Modified
        // writes the Products row alone.
        await using var db = await DbFactory.CreateDbContextAsync();
        db.Attach(p);
        db.Entry(p).State = EntityState.Modified;
        await db.SaveChangesAsync();
    }

    // Mark a product out of stock from here (always available, unlike the dashboard which only lists
    // items already running low). Records an OutNow signal → the item reads Overdue/"due today" and
    // surfaces on the dashboard, where Restocked clears it.
    private async Task MarkOut(Product p)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        db.InventorySignals.Add(new InventorySignal
        {
            ProductId = p.Id,
            Kind = SignalKind.OutNow,
            SignaledAt = DateTimeOffset.Now
        });
        await db.SaveChangesAsync();
        await LoadAsync();
    }

    private async Task Delete(Product p)
    {
        // One click destroys purchase history — make the user say so.
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete \"{p.Name}\" and its purchase history?")) return;

        deleteError = null;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            await using var tx = await db.Database.BeginTransactionAsync();
            // Confirmed receipt lines reference the product through an OPTIONAL FK with no DB-level
            // ON DELETE action, and they aren't loaded here — so SQLite rejects the delete unless we
            // detach them first. The lines themselves stay (they're the receipt's audit trail); they
            // just no longer point at a product. Required children (purchases, signals, tags, aliases)
            // cascade at the DB level.
            await db.ReceiptLines.Where(l => l.ProductId == p.Id)
                .ExecuteUpdateAsync(s => s.SetProperty(l => l.ProductId, (int?)null));
            db.Products.Remove(p);
            await db.SaveChangesAsync();
            await tx.CommitAsync();
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Deleting product {ProductId} failed.", p.Id);
            deleteError = $"Couldn't delete {p.Name} — it may still be referenced elsewhere. Nothing was removed.";
        }
        await LoadAsync();
    }
}
