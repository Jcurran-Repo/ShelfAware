@page "/"
@implements IDisposable
@using ShelfAware.Core.Chat
@using ShelfAware.Core.Prediction
@using ShelfAware.Core.Shopping
@inject IDbContextFactory<ShelfAwareDbContext> DbFactory
@inject IPantryChat Chat
@inject NavigationManager Nav
@inject VoiceCoordinator Coordinator

<PageTitle>Shelf Aware</PageTitle>

<header class="page-head">
    <h1>Running Low</h1>
    @if (products is not null)
    {
        <div class="summary">
            @if (runningLow.Count == 0)
            {
                <span class="all-good">You're all stocked up.</span>
            }
            else
            {
                @if (overdueCount > 0)
                {
                    <span class="chip chip-overdue">@overdueCount overdue</span>
                }
                @if (dueSoonCount > 0)
                {
                    <span class="chip chip-duesoon">@dueSoonCount due soon</span>
                }
            }
        </div>
    }
</header>

@if (products is null)
{
    <p>Loading…</p>
}
else
{
    @if (runningLow.Count == 0)
    {
        <p class="muted empty-note">Tracked items show up here as they approach their predicted run-out date.</p>
    }
    else
    {
        <ul class="cards">
            @foreach (var p in runningLow)
            {
                var r = predictions[p.Id];
                <li class="card accent-@ChipClass(r.Status)">
                    <div class="card-body">
                        <div class="card-top">
                            <a class="card-name" href="/product/@p.Id">@p.Name</a>
                            <span class="chip chip-@ChipClass(r.Status)">@StatusLabel(r.Status)</span>
                        </div>
                        @{
                            var size = SizeFormat.Normalize(r.RecommendedSize);
                            var brand = ShoppingEstimator.UsualBrandOf(p.Purchases);
                        }
                        @if (size is { Length: > 0 } || brand is not null)
                        {
                            <div class="item-meta">
                                @if (size is { Length: > 0 } sz)
                                {
                                    <span class="size-chip" title="Suggested size to buy">@sz</span>
                                }
                                @if (brand is not null)
                                {
                                    <span class="usual-brand">@brand</span>
                                }
                            </div>
                        }
                        @{
                            var urgency = Urgency(r);
                        }
                        @if (urgency.Length > 0)
                        {
                            <div class="card-urgency">@urgency</div>
                        }
                        @if (r.SignalNote is not null)
                        {
                            <div class="card-note">@if (r.Pinned) { <span aria-hidden="true">📌 </span> }@r.SignalNote</div>
                        }
                        <div class="card-basis muted">@r.Basis</div>
                    </div>
                    <div class="card-actions">
                        <SplitButton PrimaryLabel="Bought today" OnPrimary="() => BoughtToday(p)"
                                     PrimaryAriaLabel="@($"Mark {p.Name} bought today")">
                            <button class="secondary" @onclick="() => Restocked(p)" aria-label="Mark @p.Name restocked">Restocked</button>
                        </SplitButton>
                    </div>
                </li>
            }
        </ul>
    }

    <section class="panel quick-update">
        <h2>Quick update</h2>
        <form @onsubmit="SendChat" @formname="quick-update">
            <input @bind="chatInput" @bind:event="oninput" placeholder="e.g. we're out of dog food, almost out of coffee"
                   aria-label="Quick update — say what you bought or ran low on" disabled="@chatBusy" />
            <button type="submit" disabled="@(chatBusy || string.IsNullOrWhiteSpace(chatInput))">
                @(chatBusy ? "Working…" : "Send")
            </button>
        </form>
        <div role="status" aria-live="polite">
            @if (chatReply is not null)
            {
                <p class="@(chatError ? "error" : "chat-reply")">@chatReply</p>
            }
        </div>
        <div class="voice-divider"><span>or hold to talk</span></div>
        <PushToTalk OnApplied="LoadAsync" />
        <p class="muted small quick-update-hint">For a back-and-forth that keeps listening as you move around, use the 🎙 Assistant in the corner.</p>
    </section>

    <details class="everything-else">
        <summary>Everything else (@everythingElse.Count)</summary>
        @if (everythingElse.Count == 0)
        {
            <p class="muted">No other tracked products yet.</p>
        }
        else
        {
            <table>
                <thead>
                    <tr><th>Item</th><th>Status</th><th>Why</th></tr>
                </thead>
                <tbody>
                    @foreach (var p in everythingElse)
                    {
                        var r = predictions[p.Id];
                        <tr>
                            <td>@p.Name</td>
                            <td><span class="chip chip-@ChipClass(r.Status)">@StatusLabel(r.Status)</span></td>
                            <td class="muted">@(r.Status == PredictionStatus.Unknown ? LearningHint(p) : r.Basis)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </details>
}

@code {
    private List<Product>? products;
    private Dictionary<int, PredictionResult> predictions = [];
    private List<Product> runningLow = [];
    private List<Product> everythingElse = [];

    private DateOnly today;

    private string chatInput = "";
    private string? chatReply;
    private bool chatError;
    private bool chatBusy;

    private int overdueCount => runningLow.Count(p => predictions[p.Id].Status == PredictionStatus.Overdue);
    private int dueSoonCount => runningLow.Count(p => predictions[p.Id].Status == PredictionStatus.DueSoon);

    protected override async Task OnInitializedAsync()
    {
        // The voice assistant now lives in the layout, so it can't call OnApplied directly. It pings the
        // coordinator after a voice data change; the dashboard reloads to reflect it.
        Coordinator.PantryChanged += OnPantryChangedAsync;
        await LoadAsync();
    }

    private async Task OnPantryChangedAsync()
    {
        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose() => Coordinator.PantryChanged -= OnPantryChangedAsync;

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        products = await db.Products
            .Where(p => p.IsTracked)
            .Include(p => p.Purchases)
            .Include(p => p.Signals)
            .OrderBy(p => p.Name)
            .ToListAsync();

        today = DateOnly.FromDateTime(DateTime.Today);
        predictions = products.ToDictionary(p => p.Id, p => ReplenishmentPredictor.Predict(p, today));

        // Running Low = Overdue + DueSoon, signal-pinned first, then most overdue first (§8).
        runningLow = products
            .Where(p => predictions[p.Id].Status is PredictionStatus.Overdue or PredictionStatus.DueSoon)
            .OrderByDescending(p => predictions[p.Id].Pinned)
            .ThenByDescending(p => predictions[p.Id].Status)
            .ThenBy(p => predictions[p.Id].DueDate ?? DateOnly.MaxValue)
            .ThenBy(p => p.Name)
            .ToList();

        everythingElse = products
            .Where(p => predictions[p.Id].Status is PredictionStatus.Stocked or PredictionStatus.Unknown)
            .ToList();
    }

    private async Task BoughtToday(Product p)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        db.PurchaseEvents.Add(new PurchaseEvent
        {
            ProductId = p.Id,
            PurchasedAt = DateOnly.FromDateTime(DateTime.Today),
            Quantity = 1,
            Source = PurchaseSource.Manual
        });
        await db.SaveChangesAsync();
        await LoadAsync();
    }

    private async Task Restocked(Product p)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        db.InventorySignals.Add(new InventorySignal
        {
            ProductId = p.Id,
            Kind = SignalKind.Restocked,
            SignaledAt = DateTimeOffset.Now
        });
        await db.SaveChangesAsync();
        await LoadAsync();
    }

    private async Task SendChat()
    {
        if (chatBusy || string.IsNullOrWhiteSpace(chatInput)) return;
        chatBusy = true;
        chatReply = null;
        try
        {
            var result = await Chat.HandleAsync(chatInput);
            chatReply = result.Reply;
            chatError = !result.Success;
            if (result.Success)
            {
                chatInput = "";
                await LoadAsync(); // reflect new signals/purchases in the lists
                // A navigation tool ran ("show me the grocery list", "read me the ribs recipe") —
                // the reply stays visible for a beat via the aria-live region, then the page changes.
                if (result.NavigateTo is { } url) Nav.NavigateTo(url);
            }
        }
        finally
        {
            chatBusy = false;
        }
    }

    private static string ChipClass(PredictionStatus s) => s switch
    {
        PredictionStatus.Overdue => "overdue",
        PredictionStatus.DueSoon => "duesoon",
        PredictionStatus.Stocked => "stocked",
        _ => "unknown"
    };

    private static string StatusLabel(PredictionStatus s) => s switch
    {
        PredictionStatus.Overdue => "Overdue",
        PredictionStatus.DueSoon => "Due soon",
        PredictionStatus.Stocked => "Stocked",
        _ => "Still learning"
    };

    // Translate the predicted run-out date into plain urgency — the answer to the app's one question.
    private string Urgency(PredictionResult r)
    {
        if (r.DueDate is not { } due) return "";
        var days = due.DayNumber - today.DayNumber;
        return days switch
        {
            < 0 => $"{-days} day{Plural(-days)} overdue",
            0 => "Due today",
            _ => $"Due in {days} day{Plural(days)}"
        };
    }

    private static string Plural(int n) => n == 1 ? "" : "s";

    // Honest thin-data message: how many more purchases until the engine can predict (needs ≥ 2
    // distinct purchase dates, §6.2). PURCHASES only — since the two-stream model, restocks anchor the
    // due date but never feed the rhythm, so counting them here promised predictions that never came.
    private static string LearningHint(Product p)
    {
        var distinctDates = p.Purchases.Select(x => x.PurchasedAt).Distinct().Count();
        var needed = 2 - distinctDates;
        return needed <= 0
            ? "still learning"
            : $"{needed} more purchase{Plural(needed)} to start predicting";
    }
}
