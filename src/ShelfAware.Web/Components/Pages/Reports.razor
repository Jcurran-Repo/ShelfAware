@page "/reports"
@using ShelfAware.Core.Domain
@using ShelfAware.Core.Prediction
@using ShelfAware.Core.Reporting
@using ShelfAware.Core.Settings
@using ShelfAware.Web.Components.Charts
@using ShelfAware.Web.Data
@inject ReportDataService ReportData
@inject IHouseholdDbFactory DbFactory
@inject IAppSettings SettingsStore
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Reports — Shelf Aware</PageTitle>

<div class="report-head">
    <div>
        <h1>Reports</h1>
        <p class="muted">Ready-made reports over your receipts — every number is arithmetic, printable as-is.</p>
    </div>
    <button class="secondary report-print-btn" @onclick="Print" title="Print this report">🖨 Print</button>
</div>

<nav class="report-presets" aria-label="Report presets">
    @foreach (var p in PresetDefs)
    {
        <a class="report-preset-pill @(p.Key == ActivePreset ? "active" : null)"
           aria-current="@(p.Key == ActivePreset ? "page" : null)" href="/reports?preset=@p.Key">
            @p.Title
        </a>
    }
</nav>

@* Only exists on paper — the printed page needs to say what and when it is without the app chrome. *@
<div class="report-print-header">
    <strong>Shelf Aware — @PresetDefs.First(p => p.Key == ActivePreset).Title</strong>
    <span>@RangeCaption · printed @DateTime.Today.ToString("MMM d, yyyy")</span>
</div>

@if (!loaded)
{
    <p>Loading…</p>
}
else if (source is null || source.Purchases.Count == 0)
{
    <div class="card report-empty">
        <p>No purchase history yet — reports read from confirmed receipts.</p>
        <p class="muted">Upload a receipt (or load the sample data from Settings) and this page fills in.</p>
    </div>
}
else
{
    @switch (ActivePreset)
    {
        case "custom":
            <section class="report-section report-builder">
                <h2>Custom report</h2>

                @if (savedReports.Count > 0)
                {
                    <div class="saved-reports" role="list" aria-label="Saved reports">
                        @foreach (var saved in savedReports)
                        {
                            <span class="saved-report" role="listitem">
                                <a class="report-preset-pill" href="/reports?preset=custom&@saved.Query">@saved.Name</a>
                                <button class="saved-report-delete" title="Delete '@saved.Name'"
                                        @onclick="() => DeleteSavedAsync(saved)">✕</button>
                            </span>
                        }
                    </div>
                }

                <div class="builder-grid">
                    <label>Measure
                        <select @bind="draft.Metric">
                            <option value="@ReportMetric.Spend">Spend ($)</option>
                            <option value="@ReportMetric.UnitPrice">Unit price ($ per one)</option>
                            <option value="@ReportMetric.Quantity">Quantity bought</option>
                            <option value="@ReportMetric.PurchaseCount">Times bought</option>
                            <option value="@ReportMetric.MealsCooked">Meals cooked</option>
                            <option value="@ReportMetric.Calories">Calories cooked</option>
                        </select>
                    </label>
                    <label>Split into series
                        <select @bind="draft.Split">
                            <option value="@ReportSplit.None">No split</option>
                            <option value="@ReportSplit.ByCategory">By aisle category</option>
                            <option value="@ReportSplit.ByProduct">By product</option>
                            <option value="@ReportSplit.ByTag">By tag</option>
                            <option value="@ReportSplit.ByRecipe">By recipe</option>
                        </select>
                    </label>
                    <label>Buckets
                        <select @bind="draft.Grain">
                            <option value="@ReportGrain.Weekly">Weekly</option>
                            <option value="@ReportGrain.Monthly">Monthly</option>
                            <option value="@ReportGrain.Quarterly">Quarterly</option>
                        </select>
                    </label>
                    <label>Chart
                        <select @bind="draft.Chart">
                            <option value="@ReportChart.Line">Lines</option>
                            <option value="@ReportChart.Bars">Bars</option>
                            <option value="@ReportChart.StackedBars">Stacked bars</option>
                            <option value="@ReportChart.Table">Table only</option>
                        </select>
                    </label>
                    <label>From <input type="date" @bind="draft.From" /></label>
                    <label>To <input type="date" @bind="draft.To" /></label>
                    <label>Product (optional)
                        <select @bind="draft.ProductId">
                            <option value="">Any product</option>
                            @foreach (var (id, name) in source.Products)
                            {
                                <option value="@id">@name</option>
                            }
                        </select>
                    </label>
                    <label>Tag (optional)
                        <select @bind="draft.Tag">
                            <option value="">Any tag</option>
                            @foreach (var tag in source.Tags)
                            {
                                <option value="@tag">@tag</option>
                            }
                        </select>
                    </label>
                    <label>Aisle (optional)
                        <select @bind="draft.Category">
                            <option value="">Any aisle</option>
                            @foreach (var category in Enum.GetValues<Category>())
                            {
                                <option value="@category">@category</option>
                            }
                        </select>
                    </label>
                    <label>Recipe (optional, meal measures)
                        <select @bind="draft.RecipeId">
                            <option value="">Any recipe</option>
                            @foreach (var (id, name) in MealRecipes)
                            {
                                <option value="@id">@name</option>
                            }
                        </select>
                    </label>
                    <label>Keep top
                        <input type="number" min="1" max="8" @bind="draft.TopN" />
                    </label>
                    <label class="builder-check">
                        <input type="checkbox" @bind="draft.ComparePrevious" /> Compare with the period before
                    </label>
                </div>

                @if (draftProblems.Count > 0)
                {
                    <ul class="builder-problems">
                        @foreach (var problem in draftProblems)
                        {
                            <li>@problem</li>
                        }
                    </ul>
                }

                <div class="builder-actions">
                    <button @onclick="ApplyDraft" disabled="@(draftProblems.Count > 0)">Run report</button>
                    @if (customResult is not null)
                    {
                        <input class="builder-save-name" placeholder="Name this report…" @bind="saveName" />
                        <button class="secondary" @onclick="SaveCurrentAsync"
                                disabled="@string.IsNullOrWhiteSpace(saveName)">Save</button>
                    }
                    @if (saveNote is { } sn)
                    {
                        <span class="muted small">@sn</span>
                    }
                </div>
            </section>

            @if (customResult is { } result)
            {
                <section class="report-section">
                    <h2>@CustomTitle</h2>
                    @if (result.Total is { } total)
                    {
                        <div class="portfolio">
                            <div class="stat">
                                <span class="stat-label">Total · @customSpec!.From.ToString("MMM d") – @customSpec.To.ToString("MMM d")</span>
                                <span class="stat-value">@ChartFormat.Value(result.Unit, total)</span>
                            </div>
                            @if (result.PreviousTotal is { } previous)
                            {
                                <div class="stat">
                                    <span class="stat-label">Period before</span>
                                    <span class="stat-value">@ChartFormat.Value(result.Unit, previous)</span>
                                </div>
                            }
                        </div>
                    }
                    <ChartLegend Series="result.Series" Links="customLinks" />
                    @if (customSpec!.Chart == ReportChart.Line)
                    {
                        <TimeSeriesChart Buckets="result.Buckets" Series="result.Series" Unit="result.Unit"
                                         AriaLabel="@CustomTitle" />
                    }
                    else if (customSpec.Chart is ReportChart.Bars or ReportChart.StackedBars)
                    {
                        <BarChart Buckets="result.Buckets" Series="result.Series" Unit="result.Unit"
                                  Stacked="customSpec.Chart == ReportChart.StackedBars && result.Stackable"
                                  AriaLabel="@CustomTitle" Links="customLinks" />
                    }
                    @if (result.Note is { } note)
                    {
                        <p class="muted small">@note</p>
                    }
                    <ReportDataTable Buckets="result.Buckets" Series="result.Series" Unit="result.Unit"
                                     Additive="result.Additive" Caption="@CustomTitle" />
                </section>
            }
            break;

        case "eat":
            <section class="report-section">
                <h2>What we actually eat</h2>
                @if (source.Meals.Count == 0)
                {
                    <p class="muted">Nothing logged yet — tap <strong>🍽 Ate it</strong> on a recipe when you cook
                        it and this report starts writing itself. (Meals from before the log existed have no
                        dates, so they're honestly not charted.)</p>
                }
                else
                {
                    <ChartLegend Series="mealsByRecipe!.Series" />
                    <BarChart Buckets="mealsByRecipe.Buckets" Series="mealsByRecipe.Series" Unit="mealsByRecipe.Unit"
                              Stacked="mealsByRecipe.Stackable" AriaLabel="Meals cooked per week by recipe" />
                    @if (mealsByRecipe.Note is { } mealNote)
                    {
                        <p class="muted small">@mealNote</p>
                    }
                    <ReportDataTable Buckets="mealsByRecipe.Buckets" Series="mealsByRecipe.Series"
                                     Unit="mealsByRecipe.Unit" Additive="true" Caption="Meals cooked per week by recipe" />
                }
            </section>

            @if (mealCosts.Count > 0)
            {
                <section class="report-section">
                    <h2>Cost per meal</h2>
                    <p class="muted">Each recipe's main ingredients priced at what they cost <em>now</em> (your
                        latest receipt prices) — seasonings and pantry staples not included.</p>
                    <div class="table-scroll">
                        <table>
                            <caption class="visually-hidden">Estimated current cost per cooking of each logged recipe.</caption>
                            <thead>
                                <tr>
                                    <th scope="col">Recipe</th>
                                    <th scope="col" class="num">Cooked</th>
                                    <th scope="col" class="num">Costs about</th>
                                    <th scope="col">Priced from</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in mealCosts)
                                {
                                    <tr>
                                        <td>@row.Name</td>
                                        <td class="num">@(row.TimesCooked)×</td>
                                        <td class="num">@(row.Cost is { } cost ? cost.ToString("C") : "—")</td>
                                        <td class="muted small">@row.PricedMains of @row.TotalMains main ingredients</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
            }
            break;

        case "waist":
            <section class="report-section">
                <h2>Waist watch</h2>
                <p class="muted">Calories cooked per week, from the meals you logged and each recipe's estimated
                    calories per serving. <strong>Ballpark by design</strong> — the estimates are AI guesses per
                    serving, not what anyone's plate held. A trend to glance at, never a nutrition log.</p>
                @if (caloriesByRecipe is null || caloriesByRecipe.Series.All(s => s.Total == 0))
                {
                    <p class="muted">No calorie data yet — it needs logged meals ("🍽 Ate it") on recipes that
                        carry a calorie estimate. Cook something and check back.</p>
                }
                else
                {
                    <div class="portfolio">
                        <div class="stat">
                            <span class="stat-label">This week</span>
                            <span class="stat-value">@ThisWeekCalories.ToString("N0") kcal</span>
                        </div>
                        <div class="stat">
                            <span class="stat-label">Last week</span>
                            <span class="stat-value">@LastWeekCalories.ToString("N0") kcal</span>
                        </div>
                    </div>
                    <ChartLegend Series="caloriesByRecipe.Series" />
                    <BarChart Buckets="caloriesByRecipe.Buckets" Series="caloriesByRecipe.Series"
                              Unit="caloriesByRecipe.Unit" Stacked="caloriesByRecipe.Stackable"
                              AriaLabel="Calories cooked per week by recipe" />
                    @if (caloriesByRecipe.Note is { } kcalNote)
                    {
                        <p class="muted small">@kcalNote</p>
                    }
                    <ReportDataTable Buckets="caloriesByRecipe.Buckets" Series="caloriesByRecipe.Series"
                                     Unit="caloriesByRecipe.Unit" Additive="true" Caption="Calories cooked per week by recipe" />
                }
            </section>
            break;

        case "waste":
            <section class="report-section">
                <h2>Waste watch</h2>
                @if (!trackExpirations)
                {
                    <p class="muted">This report reads the expiration dates you record on purchases — and
                        expiration tracking is switched off for this household. Turn it on in
                        <a href="/settings">Settings</a> and date a few labels; the report fills in from there.</p>
                }
                else if (labelOutcomes.Count == 0)
                {
                    <p class="muted">No dated purchases yet. Add a label date when you review a receipt (or on a
                        product's page) and this report starts keeping score.</p>
                }
                else
                {
                    <p class="muted">What became of each purchase you dated. The app can't see inside the fridge —
                        an item whose label passed without a trace <em>might</em> have been finished quietly, so
                        this reads "worth checking", never "wasted".</p>
                    <div class="portfolio">
                        <div class="stat">
                            <span class="stat-label">Worth checking</span>
                            <span class="stat-value">@QuietCount item@(QuietCount == 1 ? "" : "s")</span>
                        </div>
                        <div class="stat">
                            <span class="stat-label">At stake</span>
                            <span class="stat-value">@QuietSpend.ToString("C")</span>
                        </div>
                        <div class="stat">
                            <span class="stat-label">Finished or replaced in time</span>
                            <span class="stat-value">@SafeCount</span>
                        </div>
                    </div>

                    @if (QuietCount > 0)
                    {
                        <div class="table-scroll">
                            <table>
                                <caption class="visually-hidden">Dated purchases whose label passed with no sign they were finished.</caption>
                                <thead>
                                    <tr>
                                        <th scope="col">Item</th>
                                        <th scope="col" class="num">Bought</th>
                                        <th scope="col" class="num">Label date</th>
                                        <th scope="col" class="num">Paid</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var (purchase, _) in labelOutcomes.Where(o => o.Outcome == LabelOutcome.PassedQuietly))
                                    {
                                        <tr>
                                            <td><a href="/product/@purchase.ProductId">@purchase.ProductName</a></td>
                                            <td class="num">@purchase.PurchasedAt.ToString("MMM d")</td>
                                            <td class="num">@purchase.Label.ToString("MMM d")</td>
                                            <td class="num">@(purchase.Price is { } paid ? paid.ToString("C") : "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    <p class="muted small">Also judged: @OutcomeCount(LabelOutcome.Superseded) replaced in time ·
                        @OutcomeCount(LabelOutcome.MarkedOut) marked out ·
                        @OutcomeCount(LabelOutcome.Overridden) overridden (frozen/kept) ·
                        @OutcomeCount(LabelOutcome.StillAhead) not due yet.</p>
                }
            </section>
            break;

        case "price-watch":
            <section class="report-section">
                <h2>What's costing more?</h2>
                <p class="muted">Your own grocery inflation: each item's paid price, early half of the last
                    3 months vs the late half, weighted by what you actually spend on it.</p>
                @if (priceWatch!.OverallPct is { } pct)
                {
                    <div class="portfolio">
                        <div class="stat">
                            <span class="stat-label">Your groceries vs 3 months ago</span>
                            <span class="stat-value @(pct > 0 ? "change-up" : pct < 0 ? "change-down" : "")">
                                @(pct > 0 ? "▲" : pct < 0 ? "▼" : "→") @Math.Abs(pct).ToString("0.#")%
                            </span>
                        </div>
                        <div class="stat">
                            <span class="stat-label">Based on</span>
                            <span class="stat-value">@priceWatch.ComparedProducts items</span>
                        </div>
                    </div>
                    <p class="muted small">@priceWatch.ComparedProducts of @priceWatch.TotalProducts products were
                        bought in both halves of the window; only those can show a change.</p>
                }
                else
                {
                    <p class="muted">Not enough repeat purchases yet to say anything honest — an inflation figure
                        needs at least @PriceWatch.MinComparedProducts items bought in both halves of the window.
                        Keep shopping; this fills in on its own.</p>
                }

                @if (priceWatch.Movers.Count > 0)
                {
                    <div class="table-scroll">
                        <table>
                            <caption class="visually-hidden">Per-item price change over the window, increases first.</caption>
                            <thead>
                                <tr>
                                    <th scope="col">Item</th>
                                    <th scope="col" class="num">Was</th>
                                    <th scope="col" class="num">Now</th>
                                    <th scope="col" class="num">Change</th>
                                    <th scope="col" class="num">You spent</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var m in priceWatch.Movers)
                                {
                                    <tr>
                                        <td><a href="/product/@m.ProductId">@m.ProductName</a></td>
                                        <td class="num">@m.EarlyUnitPrice.ToString("C")</td>
                                        <td class="num">@m.LateUnitPrice.ToString("C")</td>
                                        <td class="num @(m.ChangePct > 0 ? "change-up" : m.ChangePct < 0 ? "change-down" : "")">
                                            @(m.ChangePct > 0 ? "▲" : m.ChangePct < 0 ? "▼" : "→") @Math.Abs(m.ChangePct).ToString("0.#")%
                                        </td>
                                        <td class="num">@m.Spend.ToString("C")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (topMoverPrices is { } tm)
                {
                    <h3>@tm.Name — what one costs</h3>
                    <TimeSeriesChart Buckets="tm.Result.Buckets" Series="tm.Result.Series" Unit="tm.Result.Unit"
                                     AriaLabel="@($"{tm.Name} unit price by week")" />
                    <ReportDataTable Buckets="tm.Result.Buckets" Series="tm.Result.Series" Unit="tm.Result.Unit"
                                     Additive="false" Caption="@($"{tm.Name} unit price by week")" />
                }
            </section>
            break;

        case "gap":
            <section class="report-section">
                <h2>The gap report</h2>
                <p class="muted">Each item's two rhythms side by side: how long one usually lasts (burn) vs how
                    often you rebuy. A positive gap means you're living without it for days at a time.</p>
                @if (gapRows.Count == 0)
                {
                    <p class="muted">No items have both rhythms yet — the burn rate needs a couple of
                        ran-out-then-rebought cycles. Mark items "Out" when they run out and this fills in.</p>
                }
                else
                {
                    <div class="table-scroll">
                        <table>
                            <caption class="visually-hidden">Rebuy rhythm vs burn rate per item, largest gap first.</caption>
                            <thead>
                                <tr>
                                    <th scope="col">Item</th>
                                    <th scope="col" class="num">One lasts</th>
                                    <th scope="col" class="num">You rebuy every</th>
                                    <th scope="col" class="num">Gap</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in gapRows)
                                {
                                    <tr>
                                        <td><a href="/product/@row.ProductId">@row.Name</a></td>
                                        <td class="num">~@row.Burn.ToString("0.#") days</td>
                                        <td class="num">~@row.Rebuy.ToString("0.#") days</td>
                                        <td class="num @(row.Gap >= 1 ? "change-up" : "")">
                                            @(row.Gap >= 1 ? $"out ~{row.Gap:0.#} days" : "—")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <p class="muted small">Gap = rebuy − burn. "Out ~2 days" means the item is usually gone about
                        two days before it's bought again — the quiet cost the dashboard's Due Soon exists to close.</p>
                }
            </section>
            break;

        default: @* report-card *@
            <section class="report-section">
                <h2>This month</h2>
                <div class="portfolio">
                    <div class="stat">
                        <span class="stat-label">Spend · @Today.ToString("MMMM")</span>
                        <span class="stat-value">@((thisMonth?.Total ?? 0).ToString("C0"))</span>
                    </div>
                    <div class="stat">
                        <span class="stat-label">Spend · @Today.AddMonths(-1).ToString("MMMM")</span>
                        <span class="stat-value">@((lastMonth?.Total ?? 0).ToString("C0"))</span>
                    </div>
                    <div class="stat">
                        <span class="stat-label">Shopping trips · @Today.ToString("MMMM")</span>
                        <span class="stat-value">@tripsThisMonth</span>
                    </div>
                    <div class="stat">
                        <span class="stat-label">Meals cooked · @Today.ToString("MMMM")</span>
                        <span class="stat-value">@((mealsThisMonth?.Total ?? 0).ToString("0"))</span>
                    </div>
                </div>
            </section>

            <section class="report-section">
                <h2>Spend by aisle</h2>
                <ChartLegend Series="categorySpend!.Series" Links="categorySpendLinks" />
                <BarChart Buckets="categorySpend.Buckets" Series="categorySpend.Series" Unit="categorySpend.Unit"
                          Stacked="categorySpend.Stackable" AriaLabel="Monthly spend stacked by category"
                          Links="categorySpendLinks" />
                @if (categorySpend.Note is { } catNote)
                {
                    <p class="muted small">@catNote</p>
                }
                <ReportDataTable Buckets="categorySpend.Buckets" Series="categorySpend.Series"
                                 Unit="categorySpend.Unit" Additive="true" Caption="Monthly spend by category" />
            </section>

            <section class="report-section">
                <h2>Top items · last 30 days</h2>
                <div class="table-scroll">
                    <table>
                        <caption class="visually-hidden">Top items by spend over the last 30 days.</caption>
                        <thead>
                            <tr>
                                <th scope="col">Item</th>
                                <th scope="col" class="num">Spend</th>
                                <th scope="col" class="rank-bar-col"><span class="visually-hidden">Share of total</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (label, total) in topItems)
                            {
                                <tr>
                                    <td>@label</td>
                                    <td class="num">@total.ToString("C")</td>
                                    <td class="rank-bar-col">
                                        <span class="rank-bar" style="width:@(RankWidth(total))%" aria-hidden="true"></span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>

            @if (priceWatch!.Movers.Count > 0)
            {
                <section class="report-section">
                    <h2>Price movers · last 3 months</h2>
                    <div class="table-scroll">
                        <table>
                            <caption class="visually-hidden">Largest price changes over the last three months.</caption>
                            <thead>
                                <tr><th scope="col">Item</th><th scope="col" class="num">Was</th>
                                    <th scope="col" class="num">Now</th><th scope="col" class="num">Change</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var m in priceWatch.Movers.Take(5))
                                {
                                    <tr>
                                        <td><a href="/product/@m.ProductId">@m.ProductName</a></td>
                                        <td class="num">@m.EarlyUnitPrice.ToString("C")</td>
                                        <td class="num">@m.LateUnitPrice.ToString("C")</td>
                                        <td class="num @(m.ChangePct > 0 ? "change-up" : m.ChangePct < 0 ? "change-down" : "")">
                                            @(m.ChangePct > 0 ? "▲" : m.ChangePct < 0 ? "▼" : "→") @Math.Abs(m.ChangePct).ToString("0.#")%
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <p class="muted small">The full list, and your overall grocery inflation, live in the
                        <a href="/reports?preset=price-watch">What's costing more?</a> report.</p>
                </section>
            }
            break;
    }
}

@code {
    [SupplyParameterFromQuery(Name = "preset")] public string? Preset { get; set; }

    private static readonly (string Key, string Title)[] PresetDefs =
    [
        ("report-card", "Monthly report card"),
        ("price-watch", "What's costing more?"),
        ("eat", "What we actually eat"),
        ("waist", "Waist watch"),
        ("waste", "Waste watch"),
        ("gap", "The gap report"),
        ("custom", "Custom report"),
    ];

    private bool loaded;
    private ReportSourceData? source;
    private ReportResult? thisMonth, lastMonth, mealsThisMonth, categorySpend;
    private IReadOnlyDictionary<string, string> categorySpendLinks = new Dictionary<string, string>();
    private IReadOnlyDictionary<string, string> customLinks = new Dictionary<string, string>();
    private int tripsThisMonth;
    private List<(string Label, decimal Total)> topItems = [];
    private decimal topItemMax;
    private PriceWatchResult? priceWatch;
    private (string Name, ReportResult Result)? topMoverPrices;
    private List<(int ProductId, string Name, double Burn, double Rebuy, double Gap)> gapRows = [];

    private static DateOnly Today => DateOnly.FromDateTime(DateTime.Today);
    private string ActivePreset =>
        PresetDefs.Any(p => p.Key == Preset) ? Preset! : "report-card";

    private string RangeCaption => ActivePreset switch
    {
        "price-watch" => $"{Today.AddMonths(-3):MMM d} – {Today:MMM d, yyyy}",
        "eat" or "waist" => $"{Today.AddMonths(-2):MMM d} – {Today:MMM d, yyyy}",
        "gap" or "waste" => "all history",
        "custom" when customSpec is { } s => $"{s.From:MMM d} – {s.To:MMM d, yyyy}",
        _ => $"{SixMonthsBack:MMM yyyy} – {Today:MMM yyyy}",
    };

    private DateOnly SixMonthsBack
    {
        get
        {
            var back = new DateOnly(Today.Year, Today.Month, 1).AddMonths(-5);
            var first = source?.FirstPurchase;
            return first is { } f && f > back ? new DateOnly(f.Year, f.Month, 1) : back;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        // Loads on first visit AND on preset switch (same component instance, new query string —
        // the ProductDetail id-change lesson). The heavy fact load runs once; presets reuse it.
        source ??= await ReportData.LoadAsync();
        BuildActivePreset();
        if (ActivePreset == "gap" && gapRows.Count == 0) await BuildGapRowsAsync();
        if (ActivePreset is "eat" or "waist" && source.Purchases.Count > 0)
        {
            await LoadRecipeMainsAsync();
            BuildMealPresets();
        }
        if (ActivePreset == "waste") await BuildWasteRowsAsync();
        if (ActivePreset == "custom") await EnterCustomAsync();
        loaded = true;
    }

    // ---- Meals: what we eat, what it costs, roughly what it adds up to --------------------------

    private ReportResult? mealsByRecipe, caloriesByRecipe;
    private List<(string Name, int TimesCooked, decimal? Cost, int PricedMains, int TotalMains)> mealCosts = [];
    private bool trackExpirations;
    private List<(LabeledPurchase Purchase, LabelOutcome Outcome)> labelOutcomes = [];

    private decimal ThisWeekCalories => WeekTotal(caloriesByRecipe, 0);
    private decimal LastWeekCalories => WeekTotal(caloriesByRecipe, 1);

    private static decimal WeekTotal(ReportResult? result, int weeksBack)
    {
        if (result is null || result.Buckets.Count <= weeksBack) return 0;
        var index = result.Buckets.Count - 1 - weeksBack;
        return result.Series.Sum(s => index < s.Values.Count ? s.Values[index] ?? 0 : 0);
    }

    private int QuietCount => labelOutcomes.Count(o => o.Outcome == LabelOutcome.PassedQuietly);
    private decimal QuietSpend => labelOutcomes
        .Where(o => o.Outcome == LabelOutcome.PassedQuietly).Sum(o => o.Purchase.Price ?? 0);
    private int SafeCount => labelOutcomes.Count(o =>
        o.Outcome is LabelOutcome.Superseded or LabelOutcome.MarkedOut or LabelOutcome.Overridden);
    private int OutcomeCount(LabelOutcome outcome) => labelOutcomes.Count(o => o.Outcome == outcome);

    private void BuildMealPresets()
    {
        var mealWindow = new ReportSpec
        {
            Metric = ReportMetric.MealsCooked,
            Split = ReportSplit.ByRecipe,
            Grain = ReportGrain.Weekly,
            Chart = ReportChart.StackedBars,
            TopN = 5,
            From = Today.AddMonths(-2),
            To = Today,
        };
        mealsByRecipe = Run(mealWindow);
        caloriesByRecipe = Run(mealWindow with { Metric = ReportMetric.Calories });

        // Cost per meal: main ingredients priced at today's receipt prices via the matched product.
        // The window's cooked recipes only — an uncooked recipe's cost isn't "what we actually eat".
        var cookedCounts = source!.Meals
            .Where(m => m.Date >= mealWindow.From && m.Date <= mealWindow.To)
            .GroupBy(m => m.RecipeId)
            .ToDictionary(g => g.Key, g => g.Count());
        mealCosts = recipeMains
            .Where(r => cookedCounts.ContainsKey(r.RecipeId))
            .Select(r =>
            {
                var priced = r.Mains
                    .Select(m => m.MatchedProduct is { } name
                        && source.CurrentPriceByProductName.TryGetValue(name, out var price) ? price : (decimal?)null)
                    .ToList();
                var pricedCount = priced.Count(p => p is not null);
                return (
                    r.Name,
                    TimesCooked: cookedCounts[r.RecipeId],
                    Cost: pricedCount > 0 ? priced.Sum(p => p ?? 0) : (decimal?)null,
                    PricedMains: pricedCount,
                    TotalMains: r.Mains.Count);
            })
            .OrderByDescending(r => r.TimesCooked)
            .ThenBy(r => r.Name)
            .ToList();
    }

    /// <summary>Recipe main ingredients, loaded once alongside the meal presets (the fact load keeps
    /// Core EF-free, but ingredient rows belong to this page's cost table, not to every report).</summary>
    private List<(int RecipeId, string Name, List<RecipeIngredient> Mains)> recipeMains = [];

    private async Task LoadRecipeMainsAsync()
    {
        if (recipeMains.Count > 0) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var recipes = await db.Recipes.AsNoTracking()
            .Include(r => r.Ingredients)
            .ToListAsync();
        recipeMains = recipes
            .Select(r => (r.Id, r.Name, r.MainIngredients.ToList()))
            .ToList();
    }

    private async Task BuildWasteRowsAsync()
    {
        trackExpirations = await SettingsStore.GetTrackExpirationDatesAsync();
        if (!trackExpirations || labelOutcomes.Count > 0) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var dated = await db.PurchaseEvents.AsNoTracking()
            .Where(p => p.ExpirationDate != null)
            .Select(p => new { p.ProductId, p.Product!.Name, p.PurchasedAt, Label = p.ExpirationDate!.Value })
            .ToListAsync();
        if (dated.Count == 0) return;

        var productIds = dated.Select(d => d.ProductId).Distinct().ToList();
        var purchaseDates = (await db.PurchaseEvents.AsNoTracking()
                .Where(p => productIds.Contains(p.ProductId))
                .Select(p => new { p.ProductId, p.PurchasedAt })
                .ToListAsync())
            .GroupBy(p => p.ProductId)
            .ToDictionary(g => g.Key, g => (IReadOnlyCollection<DateOnly>)g.Select(p => p.PurchasedAt).ToList());
        var signals = (await db.InventorySignals.AsNoTracking()
                .Where(s => productIds.Contains(s.ProductId))
                .Select(s => new { s.ProductId, s.SignaledAt, s.Kind })
                .ToListAsync())
            .GroupBy(s => s.ProductId)
            .ToDictionary(
                g => g.Key,
                g => (IReadOnlyCollection<(DateOnly, SignalKind)>)g
                    .Select(s => (DateOnly.FromDateTime(s.SignaledAt.LocalDateTime), s.Kind)).ToList());

        // Price each dated purchase from the report facts (same paid-then-estimate rule as spend).
        var priceByPurchase = source!.Purchases
            .GroupBy(f => (f.ProductId, f.Date))
            .ToDictionary(g => g.Key, g => g.First().Price);

        labelOutcomes = dated
            .Select(d =>
            {
                var purchase = new LabeledPurchase(d.ProductId, d.Name, d.PurchasedAt, d.Label,
                    priceByPurchase.GetValueOrDefault((d.ProductId, d.PurchasedAt)));
                return (purchase, ExpirationOutcomes.Judge(
                    purchase,
                    purchaseDates.GetValueOrDefault(d.ProductId) ?? [],
                    signals.GetValueOrDefault(d.ProductId) ?? [],
                    Today));
            })
            .OrderByDescending(o => o.Item1.Label)
            .ToList();
    }

    // ---- Custom report builder ----------------------------------------------------------------

    /// <summary>The form's mutable working copy — @bind needs setters, ReportSpec is a value.
    /// Nullable where "not chosen" is a real state the selects need to express.</summary>
    private sealed class Draft
    {
        public ReportMetric Metric { get; set; }
        public ReportSplit Split { get; set; }
        public ReportGrain Grain { get; set; }
        public ReportChart Chart { get; set; }
        public DateOnly From { get; set; }
        public DateOnly To { get; set; }
        public int TopN { get; set; } = 6;
        public Category? Category { get; set; }
        public int? ProductId { get; set; }
        public string? Tag { get; set; }
        public int? RecipeId { get; set; }
        public bool ComparePrevious { get; set; }

        public ReportSpec ToSpec() => new()
        {
            Metric = Metric, Split = Split, Grain = Grain, Chart = Chart,
            From = From, To = To, TopN = TopN,
            Category = Category, ProductId = ProductId,
            Tag = string.IsNullOrWhiteSpace(Tag) ? null : Tag, RecipeId = RecipeId,
            ComparePrevious = ComparePrevious,
        };

        public void CopyFrom(ReportSpec spec)
        {
            Metric = spec.Metric; Split = spec.Split; Grain = spec.Grain; Chart = spec.Chart;
            From = spec.From; To = spec.To; TopN = spec.TopN;
            Category = spec.Category; ProductId = spec.ProductId;
            Tag = spec.Tag; RecipeId = spec.RecipeId;
            ComparePrevious = spec.ComparePrevious;
        }
    }

    private readonly Draft draft = new();
    private ReportSpec? customSpec;
    private ReportResult? customResult;
    private List<SavedReport> savedReports = [];
    private string? saveName;
    private string? saveNote;
    private bool draftInitialized;

    private List<string> draftProblems => ReportSpecRules.Check(draft.ToSpec()).ToList();

    /// <summary>Recipes that can be picked = recipes with at least one logged meal (anything else
    /// has nothing to chart, and the empty result would look like a bug rather than a fact).</summary>
    private IEnumerable<(int Id, string Name)> MealRecipes =>
        source!.Meals.GroupBy(m => m.RecipeId).Select(g => (g.Key, g.First().RecipeName)).OrderBy(r => r.RecipeName);

    private string CustomTitle
    {
        get
        {
            if (customSpec is not { } s) return "Custom report";
            var metric = s.Metric switch
            {
                ReportMetric.Spend => "Spend",
                ReportMetric.UnitPrice => "Unit price",
                ReportMetric.Quantity => "Quantity",
                ReportMetric.PurchaseCount => "Times bought",
                ReportMetric.MealsCooked => "Meals cooked",
                _ => "Calories cooked",
            };
            // A saved report can outlive its subject (a product merged away, a recipe deleted) —
            // name that state rather than rendering "Spend · " with a ghost separator.
            var subject = s.ProductId is { } pid ? source!.Products.FirstOrDefault(p => p.Id == pid).Name ?? "(a former product)"
                : s.Tag is { } tag ? $"“{tag}”"
                : s.Category is { } category ? category.ToString()
                : s.RecipeId is { } rid ? MealRecipes.FirstOrDefault(r => r.Id == rid).Name ?? "(a former recipe)"
                : null;
            return subject is null ? metric : $"{metric} · {subject}";
        }
    }

    /// <summary>Adopt the URL's spec (deep link, saved-report pill, back button). The equality guard
    /// keeps the NavigateTo that ApplyDraft itself issues from re-running the same report.</summary>
    private async Task EnterCustomAsync()
    {
        if (savedReports.Count == 0)
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            savedReports = await db.SavedReports.AsNoTracking().OrderBy(r => r.Name).ToListAsync();
        }

        var query = System.Web.HttpUtility.ParseQueryString(new Uri(Nav.Uri).Query);
        var values = query.AllKeys.Where(k => k is not null)
            .ToDictionary(k => k!, k => (string?)query[k]);
        var defaultFrom = Today.AddMonths(-3);
        var parsed = ReportSpecUrl.FromQuery(values, defaultFrom, Today);

        if (!draftInitialized || (values.ContainsKey("from") && parsed != customSpec))
        {
            draft.CopyFrom(parsed);
            draftInitialized = true;
            if (ReportSpecRules.Check(parsed).Count == 0 && source!.Purchases.Count > 0)
            {
                customSpec = parsed;
                customResult = ReportEngine.Run(parsed, source.Purchases, source.Meals);
                customLinks = SeriesLinksFor(parsed, customResult);
            }
        }
    }

    private void ApplyDraft()
    {
        var spec = draft.ToSpec();
        if (ReportSpecRules.Check(spec).Count > 0) return; // the button is disabled; belt and braces
        customSpec = spec;
        customResult = ReportEngine.Run(spec, source!.Purchases, source.Meals);
        customLinks = SeriesLinksFor(spec, customResult);
        saveNote = null;
        // replace:true — tuning a report shouldn't bury the back button under every attempt.
        Nav.NavigateTo($"/reports?preset=custom&{ReportSpecUrl.ToQuery(spec)}", replace: true);
    }

    private async Task SaveCurrentAsync()
    {
        if (customSpec is not { } spec || string.IsNullOrWhiteSpace(saveName)) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        db.SavedReports.Add(new SavedReport
        {
            Name = saveName.Trim(),
            Query = ReportSpecUrl.ToQuery(spec),
            SavedAt = DateTimeOffset.Now,
        });
        await db.SaveChangesAsync();
        savedReports = await db.SavedReports.AsNoTracking().OrderBy(r => r.Name).ToListAsync();
        saveNote = $"Saved “{saveName.Trim()}”.";
        saveName = null;
    }

    private async Task DeleteSavedAsync(SavedReport report)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var mine = await db.SavedReports.FindAsync(report.Id);
        if (mine is not null)
        {
            db.SavedReports.Remove(mine);
            await db.SaveChangesAsync();
        }
        savedReports.RemoveAll(r => r.Id == report.Id);
    }

    private void BuildActivePreset()
    {
        if (source is null || source.Purchases.Count == 0) return;
        var monthStart = new DateOnly(Today.Year, Today.Month, 1);

        // The three-month price watch serves both its own preset and the report card's teaser.
        priceWatch = PriceWatch.Compute(source.Purchases, Today.AddMonths(-3), Today);

        if (ActivePreset == "price-watch")
        {
            var top = priceWatch.Movers.OrderByDescending(m => Math.Abs(m.ChangePct)).FirstOrDefault();
            if (top is not null && top.ChangePct != 0)
            {
                var result = ReportEngine.Run(
                    new ReportSpec
                    {
                        Metric = ReportMetric.UnitPrice,
                        ProductId = top.ProductId,
                        Grain = ReportGrain.Weekly,
                        From = Today.AddMonths(-3),
                        To = Today,
                    },
                    source.Purchases, source.Meals);
                topMoverPrices = (top.ProductName, result);
            }
            return;
        }

        if (ActivePreset != "report-card") return;

        thisMonth = Run(new ReportSpec { From = monthStart, To = Today });
        lastMonth = Run(new ReportSpec { From = monthStart.AddMonths(-1), To = monthStart.AddDays(-1) });
        mealsThisMonth = Run(new ReportSpec { Metric = ReportMetric.MealsCooked, From = monthStart, To = Today });
        tripsThisMonth = source.Purchases
            .Where(f => f.Date >= monthStart && f.Date <= Today)
            .Select(f => f.Date).Distinct().Count();

        var categorySpec = new ReportSpec
        {
            Split = ReportSplit.ByCategory,
            Chart = ReportChart.StackedBars,
            From = SixMonthsBack,
            To = Today,
        };
        categorySpend = Run(categorySpec);
        categorySpendLinks = SeriesLinksFor(categorySpec, categorySpend);

        var top30 = Run(new ReportSpec
        {
            Split = ReportSplit.ByProduct,
            TopN = 10,
            Chart = ReportChart.Table, // rendered as the ranked table — over the chart cap is fine
            From = Today.AddDays(-29),
            To = Today,
        });
        topItems = top30.Series.Select(s => (s.Label, s.Total)).Where(t => t.Total > 0).ToList();
        topItemMax = topItems.Count > 0 ? topItems.Max(t => t.Total) : 0;
    }

    private ReportResult Run(ReportSpec spec) => ReportEngine.Run(spec, source!.Purchases, source.Meals);

    /// <summary>Where each series can take you: an aisle series opens Products filtered to that
    /// category, a tag series to that tag, a product series to its detail page. Pooled and synthetic
    /// series ("Everything else", "(untagged)") have no destination and stay plain — a link that
    /// opens the wrong thing is worse than no link.</summary>
    private IReadOnlyDictionary<string, string> SeriesLinksFor(ReportSpec spec, ReportResult result)
    {
        var links = new Dictionary<string, string>();
        foreach (var series in result.Series)
        {
            switch (spec.Split)
            {
                case ReportSplit.ByCategory when Enum.TryParse<Category>(series.Label, out _):
                    links[series.Label] = $"/products?category={series.Label}";
                    break;
                case ReportSplit.ByCategory when series.Label == "Everything else":
                    // The pooled small aisles are knowable: every aisle in the window minus the ones
                    // that earned their own series. Products can open exactly that set.
                    var kept = result.Series
                        .Where(s => Enum.TryParse<Category>(s.Label, out _))
                        .Select(s => s.Label)
                        .ToHashSet();
                    var pooled = source!.Purchases
                        .Where(f => f.Date >= spec.From && f.Date <= spec.To)
                        .Select(f => f.Category.ToString())
                        .Distinct()
                        .Where(c => !kept.Contains(c))
                        .OrderBy(c => c)
                        .ToList();
                    if (pooled.Count > 0)
                        links[series.Label] = $"/products?categories={string.Join(',', pooled)}";
                    break;
                case ReportSplit.ByTag when series.Label == "(untagged)":
                    links[series.Label] = "/products?untagged=1";
                    break;
                case ReportSplit.ByTag:
                    links[series.Label] = $"/products?tag={Uri.EscapeDataString(series.Label)}";
                    break;
                case ReportSplit.ByProduct:
                    var product = source!.Products.FirstOrDefault(p => p.Name == series.Label);
                    if (product.Id != 0) links[series.Label] = $"/product/{product.Id}";
                    break;
            }
        }
        return links;
    }

    /// <summary>The gap rows need full products (purchases + signals) for the predictor — loaded only
    /// when the gap preset is actually opened, not on every report visit.</summary>
    private async Task BuildGapRowsAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var products = await db.Products.AsNoTracking()
            .Where(p => p.IsTracked)
            .Include(p => p.Purchases)
            .Include(p => p.Signals)
            .ToListAsync();
        var trackExpirations = await SettingsStore.GetTrackExpirationDatesAsync();

        gapRows = products
            .Select(p => (Product: p, Prediction: ReplenishmentPredictor.Predict(p, Today, trackExpirations)))
            .Where(x => x.Prediction is { RebuyIntervalDays: not null, BurnRateDays: not null })
            .Select(x => (
                x.Product.Id,
                x.Product.Name,
                Burn: x.Prediction.BurnRateDays!.Value,
                Rebuy: x.Prediction.RebuyIntervalDays!.Value,
                Gap: x.Prediction.RebuyIntervalDays.Value - x.Prediction.BurnRateDays.Value))
            .OrderByDescending(x => x.Gap)
            .ThenBy(x => x.Name)
            .ToList();
    }

    private decimal RankWidth(decimal total) =>
        topItemMax > 0 ? Math.Round(total / topItemMax * 100, 1) : 0;

    private async Task Print() => await JS.InvokeVoidAsync("window.print");
