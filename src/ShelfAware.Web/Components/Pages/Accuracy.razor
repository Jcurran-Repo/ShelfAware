@page "/accuracy"
@using System.Text.Json
@using ShelfAware.Core.Evaluation
@using ShelfAware.Core.Prediction
@inject IWebHostEnvironment Env
@inject IDbContextFactory<ShelfAwareDbContext> DbFactory

<PageTitle>Model Accuracy — Shelf Aware</PageTitle>

<h1>Model Accuracy</h1>
<p class="muted">
    Both halves of the app, measured: how well the LLM reads receipts, and how well the
    plain-statistics engine predicts your repurchases.
</p>

<h2>Receipt extraction <span class="muted">— LLM vs hand-labelled receipts</span></h2>

@if (results is null || results.Fixtures.Count == 0)
{
    <section class="panel">
        <p>No eval results yet. Run the harness against labelled fixtures, writing its output here:</p>
        <pre>dotnet run --project tests/ShelfAware.Evals -- &lt;fixtures-dir&gt; src/ShelfAware.Web/wwwroot/eval-results.json</pre>
        <p class="muted">
            Each fixture is a receipt image with a sibling <code>&lt;name&gt;.expected.json</code> listing the
            ground-truth lines. Set the <code>Llm__ApiKey</code> environment variable first.
        </p>
    </section>
}
else
{
    <div class="portfolio">
        @Stat("Line recall", results.Aggregate.Recall, 0.90)
        @Stat("Line precision", results.Aggregate.Precision, 0.90)
        @Stat("Field accuracy", results.Aggregate.FieldAccuracy, 0.85)
    </div>
    <p class="muted">Model @results.Model · generated @results.GeneratedAt.ToString("yyyy-MM-dd HH:mm")</p>

    <div class="table-scroll">
        <table>
            <caption class="visually-hidden">Per-fixture extraction scores.</caption>
            <thead>
                <tr>
                    <th scope="col">Fixture</th>
                    <th scope="col">Expected</th>
                    <th scope="col">Found</th>
                    <th scope="col">Matched</th>
                    <th scope="col">Recall</th>
                    <th scope="col">Precision</th>
                    <th scope="col">Field</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in results.Fixtures)
                {
                    <tr>
                        <td>@f.Name</td>
                        @if (f.Error is { } err)
                        {
                            <td colspan="6" class="error">@err</td>
                        }
                        else
                        {
                            <td>@f.ExpectedLines</td>
                            <td>@f.FoundLines</td>
                            <td>@f.MatchedLines</td>
                            <td>@f.Recall.ToString("P0")</td>
                            <td>@f.Precision.ToString("P0")</td>
                            <td>@f.FieldAccuracy.ToString("P0")</td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<h2>Replenishment prediction <span class="muted">— walk-forward backtest, live from your history</span></h2>

@if (backtest is null || backtest.Samples == 0)
{
    <section class="panel">
        <p class="muted">
            Not enough history yet — the backtest scores products with at least 3 distinct purchase
            dates, predicting each repurchase from only the trips before it.
        </p>
    </section>
}
else
{
    <div class="portfolio">
        <div class="stat">
            <span class="stat-label">Within ±2 days</span>
            <span class="stat-value">@backtest.HitRate.ToString("P0")</span>
            <span class="muted">@backtest.WithinTwoDays of @backtest.Samples predictions</span>
        </div>
        <div class="stat">
            <span class="stat-label">Median error</span>
            <span class="stat-value">@backtest.MedianAbsErrorDays.ToString("0.#") d</span>
            <span class="muted">across @backtest.Products products</span>
        </div>
    </div>
    <p class="muted">
        Walk-forward: every repurchase is predicted using only the history <em>before</em> it (no
        peeking), then scored against the real repurchase date. One honest caveat: the engine predicts
        <em>run-out</em> and the observable truth is the next <em>repurchase</em> — for the rebuy rhythm
        they coincide; when the burn rate drives they can legitimately differ.
    </p>

    <div class="table-scroll">
        <table>
            <caption class="visually-hidden">Per-product prediction backtest scores.</caption>
            <thead>
                <tr>
                    <th scope="col">Product</th>
                    <th scope="col">Predictions</th>
                    <th scope="col">Median error</th>
                    <th scope="col">Within ±2 days</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in backtest.PerProduct)
                {
                    <tr>
                        <td><a href="/product/@p.ProductId">@p.Name</a></td>
                        <td>@p.Samples</td>
                        <td>@p.MedianAbsErrorDays.ToString("0.#") d</td>
                        <td>@p.HitRate.ToString("P0")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private EvalResults? results;
    private PredictionBacktest.Summary? backtest;

    protected override async Task OnInitializedAsync()
    {
        var path = Path.Combine(Env.WebRootPath, "eval-results.json");
        if (File.Exists(path))
        {
            try
            {
                results = JsonSerializer.Deserialize<EvalResults>(
                    File.ReadAllText(path),
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }
            catch
            {
                results = null;
            }
        }

        // The prediction backtest is computed live from the real purchase history — nothing to
        // pre-generate, no API key needed, and it updates itself as receipts land.
        await using var db = await DbFactory.CreateDbContextAsync();
        var products = await db.Products
            .Where(p => p.IsTracked)
            .Include(p => p.Purchases)
            .Include(p => p.Signals)
            .ToListAsync();
        backtest = PredictionBacktest.Run(products);
    }

    private RenderFragment Stat(string label, double value, double target) =>
        @<div class="stat @(value >= target ? "pass" : "fail")">
            <span class="stat-label">@label</span>
            <span class="stat-value">@value.ToString("P0")</span>
            <span class="muted">target @target.ToString("P0")</span>
        </div>;
}
