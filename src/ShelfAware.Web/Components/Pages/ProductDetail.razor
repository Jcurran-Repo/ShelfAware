@page "/product/{Id:int}"
@using ShelfAware.Core.Prediction
@using ShelfAware.Core.Recipes
@using ShelfAware.Core.Shopping
@inject IHouseholdDbFactory DbFactory
@inject IProductSubstituteAdvisor SubAdvisor
@inject ProductRenameService Renamer
@inject ProductMergeService Merger
@inject NavigationManager Nav
@inject ILogger<ProductDetail> Logger

<PageTitle>@(product?.Name ?? "Product") — Shelf Aware</PageTitle>

@if (notFound)
{
    <p>Product not found. <a href="/products">Back to products</a>.</p>
}
else if (product is null)
{
    <p>Loading…</p>
}
else
{
    <div class="page-head">
        @if (renaming)
        {
            <input class="rename-input" @bind="renameValue" @bind:event="oninput" @onkeydown="OnRenameKey"
                   aria-label="New name for @product.Name" />
            <button type="button" @onclick="SaveRename" disabled="@(string.IsNullOrWhiteSpace(renameValue) || renameBusy)">Save</button>
            <button type="button" class="secondary" @onclick="CancelRename" disabled="@renameBusy">Cancel</button>
        }
        else
        {
            <h1>@product.Name</h1>
            <button type="button" class="icon-btn" @onclick="StartRename" aria-label="Rename @product.Name" title="Rename @product.Name"><span aria-hidden="true">✏️</span></button>
            <button type="button" class="icon-btn" @onclick="OpenMerge" aria-label="Merge @product.Name into another product" title="Merge @product.Name into another product"><span aria-hidden="true">⇆</span></button>
        }
        <span class="chip chip-@ChipClass(prediction.Status)">@StatusLabel(prediction.Status)</span>
    </div>
    @if (renameError is not null)
    {
        <p class="error" role="alert">@renameError</p>
    }
    @if (merging)
    {
        <section class="panel merge-panel">
            <h2>Merge into another product</h2>
            <p class="muted">Moves every purchase, receipt line, alias, and signal from
                <strong>@product.Name</strong> onto the product you pick, then deletes
                <strong>@product.Name</strong>. Use it when one item got split — e.g. flavors that
                should be one product. This can't be undone.</p>
            @if (mergeTagOptions.Count > 0)
            {
                <div class="tag-cloud" role="group" aria-label="Narrow the merge candidates by tag">
                    <span class="muted">Narrow by tag:</span>
                    @foreach (var (value, count) in mergeTagOptions)
                    {
                        var active = string.Equals(value, mergeTagFilter, StringComparison.OrdinalIgnoreCase);
                        <button type="button" class="tag-chip tag-cloud-chip @(active ? "active" : "")"
                                @onclick="() => ToggleMergeTag(value)" aria-pressed="@active">
                            @value <span class="tag-count">@count</span>
                        </button>
                    }
                    @if (mergeTagFilter.Length > 0)
                    {
                        <button type="button" class="tag-clear" @onclick="() => ToggleMergeTag(mergeTagFilter)">Clear ✕</button>
                    }
                </div>
            }
            <div class="merge-controls">
                <label>
                    Merge into
                    <select @bind="mergeTargetId" @bind:after="OnMergeTargetChanged" aria-label="Product to merge @product.Name into">
                        <option value="0">— pick a product —</option>
                        @foreach (var candidate in FilteredMergeCandidates)
                        {
                            <option value="@candidate.Id">@candidate.Name</option>
                        }
                    </select>
                </label>
                <label>
                    Label moved purchases' variety as
                    <input @bind="mergeVariety" @bind:event="oninput" placeholder="optional — e.g. Strawberry"
                           aria-label="Variety label for the moved purchases" />
                </label>
            </div>
            <div class="review-actions">
                <button type="button" @onclick="SaveMerge" disabled="@(mergeTargetId == 0 || mergeBusy)">@(mergeBusy ? "Merging…" : "Merge")</button>
                <button type="button" class="secondary" @onclick="CancelMerge" disabled="@mergeBusy">Cancel</button>
            </div>
            @if (mergeError is not null)
            {
                <p class="error" role="alert">@mergeError</p>
            }
        </section>
    }
    <p class="muted">@product.Category@(product.DefaultUnit is { } u ? $" · {u}" : "") · <a href="/products">All products</a></p>
    @if (product.Tags.Count > 0)
    {
        <div class="tag-list detail-tags">
            @foreach (var t in product.Tags.OrderBy(t => t.Value))
            {
                <a class="tag-chip" href="/products?tag=@Uri.EscapeDataString(t.Value)" title="See all @t.Value products">@t.Value</a>
            }
        </div>
    }

    <section class="panel">
        <h2>Current rhythm</h2>
        <dl class="rhythm">
            <dt>Next buy</dt>
            <dd>@(estimate.NextBuyDate is { } d ? $"{d:MMM d, yyyy} ({Relative(estimate.DaysUntil!.Value)})" : "still learning")</dd>
            <dt>Rebuy rhythm</dt>
            <dd>@(prediction.RebuyIntervalDays is { } rb ? $"~every {Math.Round(rb)} days" : "—")</dd>
            @if (prediction.BurnRateDays is { } burn)
            {
                <dt>Burn rate</dt>
                <dd>one lasts ~@Math.Round(burn) days</dd>
            }
            @if (prediction.IntervalSpreadDays is { } sp && Math.Round(sp) >= 1)
            {
                <dt>Consistency</dt>
                <dd>give or take ~@Math.Round(sp) day@(Math.Round(sp) == 1 ? "" : "s")</dd>
            }
            @if (prediction.StockUpFactor is { } su)
            {
                <dt>Stocked up</dt>
                <dd>last buy was ~@su.ToString("0.#")× the usual — due date pushed out to match</dd>
            }
            <dt>Typical buy</dt>
            <dd>@estimate.RecommendedQuantity.ToString("0.##")@(product.DefaultUnit is { } u2 ? $" {u2}" : "")</dd>
            @if (SizeFormat.Normalize(prediction.RecommendedSize) is { Length: > 0 } rs)
            {
                <dt>Recommended size</dt>
                <dd>@rs</dd>
            }
            <dt>Last bought</dt>
            <dd>@(estimate.LastPurchased is { } lb ? lb.ToString("MMM d, yyyy") : "never")</dd>
            <dt>Est. cost / buy</dt>
            <dd>@(estimate.ExpectedCost is { } c ? c.ToString("C") : "unknown")</dd>
        </dl>
        <p class="muted">@prediction.Basis@(prediction.SignalNote is { } note ? $" · {note}" : "")</p>
        @if (prediction.RebuyBurnGapDays is { } gapDays)
        {
            var gap = (int)Math.Round(gapDays);
            if (gap > 0)
            {
                <p class="rhythm-gap">⚠️ You typically run out about <strong>@gap day@(gap == 1 ? "" : "s")</strong> before you restock — worth buying it sooner.</p>
            }
            else if (gap < 0)
            {
                <p class="rhythm-gap">You usually restock about <strong>@(-gap) day@(-gap == 1 ? "" : "s")</strong> before running out — comfortably ahead.</p>
            }
        }
    </section>

    <section class="panel">
        <h2>Also works as</h2>
        <p class="muted">Recipe ingredients this can stand in for — so a recipe stays specific (real cook times) but still counts what you have. Editable.</p>
        <div class="tag-list">
            @foreach (var s in product.Substitutes.OrderBy(s => s.Value))
            {
                <span class="tag-chip">@s.Value<button type="button" class="tag-x" @onclick="() => RemoveSubstitute(s)" aria-label="Remove @s.Value">×</button></span>
            }
            @if (product.Substitutes.Count == 0)
            {
                <span class="muted">None yet — add some, or let the assistant suggest.</span>
            }
        </div>
        <div class="tag-add">
            <input placeholder="e.g. chicken breast" @bind="newSubstitute" @bind:event="oninput"
                   aria-label="Add a substitute this works as" @onkeydown="OnSubstituteKey" />
            <button type="button" @onclick="AddSubstitute" disabled="@string.IsNullOrWhiteSpace(newSubstitute)">Add</button>
            <button type="button" class="secondary" @onclick="SuggestSubstitutes" disabled="@suggesting">@(suggesting ? "Thinking…" : "✨ Suggest")</button>
        </div>
    </section>

    @if (usedInRecipes.Count > 0)
    {
        <section class="panel">
            <h2>Recipes that use this <span class="muted">— @usedInRecipes.Count</span></h2>
            <ul class="recipe-links">
                @foreach (var r in usedInRecipes)
                {
                    <li><a href="/recipes#recipe-@r.Id">@r.Name</a></li>
                }
            </ul>
        </section>
    }

    @if (brandBreakdown.Any(b => b.Brand != Unbranded))
    {
        <section class="panel">
            <h2>Brands bought</h2>
            <ul class="brands">
                @foreach (var b in brandBreakdown)
                {
                    <li>
                        <span class="brand-name">@b.Brand</span>
                        <span class="muted">@b.Count purchase@(b.Count == 1 ? "" : "s")@(b.AvgPrice is { } ap ? $" · avg {Money(ap)}" : "")</span>
                    </li>
                }
            </ul>
        </section>
    }

    @if (varietyBreakdown.Any(v => v.Variety != Unlabeled))
    {
        <section class="panel">
            <h2>Varieties bought</h2>
            <p class="muted">One rhythm for the whole item — every brand and variety counts toward the same cadence; this is just how the buys split.</p>
            <ul class="brands">
                @foreach (var v in varietyBreakdown)
                {
                    <li>
                        <span class="brand-name">@v.Variety</span>
                        <span class="muted">@v.Count purchase@(v.Count == 1 ? "" : "s") · last @v.LastBought.ToString("MMM d, yyyy")@(v.AvgPrice is { } ap ? $" · avg {Money(ap)}" : "")</span>
                    </li>
                }
            </ul>
        </section>
    }

    @if (priceSeries.Count >= 2)
    {
        <section class="panel">
            <h2>Price history @(chartSizeLabel is { } cs ? $"— {cs}" : null)</h2>
            <LineChart Values="priceSeries" W="520" H="140" ShowDots="true"
                       AriaLabel="@($"{product.Name} price per purchase over time{(chartSizeLabel is { } chartSize ? $", {chartSize} size" : "")}")" />
            <p class="muted">
                @priceSeries.Count price points · low @Money(priceSeries.Min()) ·
                high @Money(priceSeries.Max()) · latest @Money(priceSeries[^1])
                @if (chartSizeLabel is not null)
                {
                    <text> · charting the most-bought size — other sizes appear in the purchase list below</text>
                }
            </p>
        </section>
    }

    <section class="panel">
        <h2>Recent purchases <span class="muted">— most recent first</span></h2>
        @if (history.Count == 0)
        {
            <p class="muted">No purchases recorded yet. Upload a receipt or use the dashboard quick update.</p>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th scope="col">Date</th>
                        <th scope="col">Since previous</th>
                        <th scope="col">Qty</th>
                        <th scope="col">Size</th>
                        <th scope="col">Variety</th>
                        <th scope="col">Unit price</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var h in history)
                    {
                        <tr>
                            <td>@h.Date.ToString("MMM d, yyyy")</td>
                            <td>@(h.GapDays is { } g ? $"{g} day{(g == 1 ? "" : "s")}" : "—")</td>
                            <td>@h.Quantity.ToString("0.##")</td>
                            <td>@(SizeFormat.Normalize(h.Size) is { Length: > 0 } s ? s : "—")</td>
                            <td>@(h.Variety is { Length: > 0 } v ? v : "—")</td>
                            <td>@(h.UnitPrice is { } up ? up.ToString("C") : "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
}

@code {
    [Parameter] public int Id { get; set; }

    private Product? product;
    private bool notFound;
    private PredictionResult prediction = null!;
    private ProductEstimate estimate = null!;
    private readonly List<PurchaseRow> history = [];
    private readonly List<decimal> priceSeries = [];
    private string? chartSizeLabel; // the charted size bucket, shown only when the product mixes sizes
    private List<BrandRow> brandBreakdown = [];
    private List<VarietyRow> varietyBreakdown = [];
    private List<RecipeLink> usedInRecipes = [];

    private string newSubstitute = "";
    private bool suggesting;

    private const string Unbranded = "Unbranded";
    private const string Unlabeled = "Unlabeled";

    private record PurchaseRow(DateOnly Date, int? GapDays, decimal Quantity, string? Size, string? Variety, decimal? UnitPrice);
    private record BrandRow(string Brand, int Count, decimal? AvgPrice);
    private record VarietyRow(string Variety, int Count, DateOnly LastBought, decimal? AvgPrice);
    private record RecipeLink(int Id, string Name);

    private int? loadedId;

    // Load in OnParametersSet (not OnInitialized) and reset per-product state, so navigating straight from
    // /product/A to /product/B — where Blazor reuses this component instance — refreshes instead of showing
    // A's data. history/priceSeries persist on the reused instance, so they're cleared here too (they used
    // to just accumulate across navigations).
    protected override async Task OnParametersSetAsync()
    {
        if (loadedId == Id) return; // same product already loaded
        loadedId = Id;

        product = null;
        notFound = false;
        history.Clear();
        priceSeries.Clear();
        chartSizeLabel = null;
        brandBreakdown = [];
        varietyBreakdown = [];
        usedInRecipes = [];

        // Transient edit affordances must not survive a product switch: a merge navigates this SAME
        // reused component instance to the target product, and a panel left open there would offer a
        // stale candidate list — including the product now on screen. (Found live: the panel arrived
        // open on the merge target.) Rename gets the same reset for the same reuse reason.
        renaming = false;
        renameError = null;
        merging = false;
        mergeError = null;
        mergeTargetId = 0;
        mergeVariety = null;
        mergeCandidates = [];

        await using var db = await DbFactory.CreateDbContextAsync();
        product = await db.Products
            .AsNoTracking() // read-only detail view; substitute edits reload via their own context
            .Include(p => p.Purchases)
            .Include(p => p.Signals)
            .Include(p => p.Tags)
            .Include(p => p.Substitutes)
            .FirstOrDefaultAsync(p => p.Id == Id);

        if (product is null)
        {
            notFound = true;
            return;
        }

        // Per-receipt unit price for this product, so each purchase can show what it cost. Size rides
        // along so the est. cost/buy can price the recommended size, not a blend across sizes.
        var priceByReceipt = await db.ReceiptLines
            .Where(l => l.ProductId == Id && l.UnitPrice != null && l.ReceiptId != 0)
            .Select(l => new { l.ReceiptId, l.Size, Price = l.UnitPrice!.Value })
            .ToListAsync();
        var priceLookup = priceByReceipt
            .GroupBy(x => x.ReceiptId)
            .ToDictionary(g => g.Key, g => g.Average(x => x.Price));

        var today = DateOnly.FromDateTime(DateTime.Today);
        prediction = ReplenishmentPredictor.Predict(product, today);

        // Price the recommended (dominant) size specifically; fall back to the overall average.
        // ProductPriceIndex folds the loose/"each" spellings together, so per-each produce
        // prices match a null recommended size.
        var sizePrices = new ProductPriceIndex(priceByReceipt.Select(x => (Id, x.Size, x.Price)));
        estimate = ShoppingEstimator.For(product, prediction, today, sizePrices.PriceFor(Id, prediction.RecommendedSize));

        var pricePoints = new List<PricePoint>();
        var ordered = product.Purchases.OrderBy(p => p.PurchasedAt).ToList();
        for (var i = 0; i < ordered.Count; i++)
        {
            var pe = ordered[i];
            int? gap = i > 0 ? pe.PurchasedAt.DayNumber - ordered[i - 1].PurchasedAt.DayNumber : null;
            decimal? price = pe.ReceiptId is { } rid && priceLookup.TryGetValue(rid, out var pr) ? pr : null;
            if (price is { } pv) pricePoints.Add(new PricePoint(pe.Size, pe.PurchasedAt, pv));
            history.Add(new PurchaseRow(pe.PurchasedAt, gap, pe.Quantity, pe.Size, pe.Variety, price));
        }
        history.Reverse(); // most recent first

        // The chart plots ONE size's prices (the dominant bucket) so it shows a real trend — $/bag next
        // to $/each is a cliff, not a price move. The purchase table below still shows every size's
        // actual price; the caption names the charted size when the product mixes sizes.
        if (PriceSeries.Dominant(pricePoints) is { } series)
        {
            priceSeries.AddRange(series.Points.Select(pt => pt.UnitPrice));
            chartSizeLabel = series.BucketCount > 1 ? series.SizeKey : null;
        }

        // Brand-agnostic product: which brands of this item have been bought, and how often.
        decimal? PriceOf(PurchaseEvent pe) =>
            pe.ReceiptId is { } rid && priceLookup.TryGetValue(rid, out var pr) ? pr : null;
        brandBreakdown = product.Purchases
            .GroupBy(pe => string.IsNullOrWhiteSpace(pe.Brand) ? Unbranded : pe.Brand!.Trim(),
                StringComparer.OrdinalIgnoreCase)
            .Select(g =>
            {
                var prices = g.Select(PriceOf).Where(p => p is not null).Select(p => p!.Value).ToList();
                return new BrandRow(g.Key, g.Count(), prices.Count > 0 ? prices.Average() : null);
            })
            .OrderByDescending(b => b.Count).ThenBy(b => b.Brand)
            .ToList();

        // The variety split (Jordan's drink-mix ask): strawberry vs. grape across EVERY brand — the
        // Kool-Aid strawberry and the Crystal Light strawberry are one variety row. Purchases from
        // before variety tracking (or plain items) group under "Unlabeled"; the section only renders
        // when a real variety exists. The rhythm panel above stays collective on purpose — variety,
        // like brand and size, never splits the cadence.
        varietyBreakdown = product.Purchases
            .GroupBy(pe => string.IsNullOrWhiteSpace(pe.Variety) ? Unlabeled : pe.Variety!.Trim(),
                StringComparer.OrdinalIgnoreCase)
            .Select(g =>
            {
                var prices = g.Select(PriceOf).Where(p => p is not null).Select(p => p!.Value).ToList();
                return new VarietyRow(g.Key, g.Count(), g.Max(pe => pe.PurchasedAt),
                    prices.Count > 0 ? prices.Average() : null);
            })
            .OrderByDescending(v => v.Count).ThenBy(v => v.Variety)
            .ToList();

        // Saved recipes whose ingredient→product map points at this item (grounded match captured at
        // save time). Just links out to the recipe on /recipes — no recipe content duplicated here.
        var productName = product.Name;
        usedInRecipes = (await db.Recipes.Include(r => r.Ingredients).ToListAsync())
            .Where(r => r.Ingredients.Any(i => string.Equals(i.MatchedProduct, productName, StringComparison.OrdinalIgnoreCase)))
            .OrderBy(r => r.Name)
            .Select(r => new RecipeLink(r.Id, r.Name))
            .ToList();
    }

    // Renaming. The service re-points the name-keyed recipe links (RecipeIngredient.MatchedProduct),
    // so "recipes that use this" and the ?uses filter survive the new name; membership doesn't change,
    // so updating the loaded product in place is enough — no full reload.
    private bool renaming;
    private bool renameBusy;
    private string renameValue = "";
    private string? renameError;

    private void StartRename()
    {
        renameValue = product?.Name ?? "";
        renameError = null;
        renaming = true;
    }

    private void CancelRename()
    {
        renaming = false;
        renameError = null;
    }

    private async Task OnRenameKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SaveRename();
        else if (e.Key == "Escape") CancelRename();
    }

    private async Task SaveRename()
    {
        if (product is null || renameBusy || string.IsNullOrWhiteSpace(renameValue)) return;
        renameBusy = true;
        try
        {
            var result = await Renamer.RenameAsync(product.Id, renameValue);
            if (!result.Ok)
            {
                renameError = result.Message;
                return;
            }
            product.Name = renameValue.Trim();
            renaming = false;
            renameError = null;
        }
        finally { renameBusy = false; }
    }

    // Merging (the repair path for variety-split history — see ProductMergeService). The candidate
    // list loads when the panel opens; picking a target pre-fills the variety label from the words
    // this product's name would lose ("Strawberry Drink Mix" → "Drink Mix" suggests "Strawberry").
    // On success we navigate to the surviving product — this page's subject no longer exists.
    private bool merging;
    private bool mergeBusy;
    private int mergeTargetId;
    private string? mergeVariety;
    private string? mergeError;
    private string mergeTagFilter = ""; // "" = any tag
    private List<(string Tag, int Count)> mergeTagOptions = [];
    private List<MergeCandidate> mergeCandidates = [];
    private record MergeCandidate(int Id, string Name, IReadOnlyList<string> Tags);

    // The candidate list can be a whole catalog; the tag filter narrows it to the aisle you're
    // thinking of ("Snack" finds the other drink mixes). "" shows everything.
    private IEnumerable<MergeCandidate> FilteredMergeCandidates =>
        mergeTagFilter.Length == 0
            ? mergeCandidates
            : mergeCandidates.Where(c => c.Tags.Contains(mergeTagFilter, StringComparer.OrdinalIgnoreCase));

    private async Task OpenMerge()
    {
        if (product is null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        mergeCandidates = (await db.Products
            .Where(p => p.Id != product.Id)
            .OrderBy(p => p.Name)
            .Select(p => new { p.Id, p.Name, Tags = p.Tags.Select(t => t.Value).ToList() })
            .ToListAsync())
            .Select(p => new MergeCandidate(p.Id, p.Name, p.Tags))
            .ToList();
        // Same cloud shape as the Products page: each tag with how many CANDIDATES carry it,
        // busiest first — the count tells you whether a chip is worth tapping before you tap it.
        mergeTagOptions = mergeCandidates
            .SelectMany(c => c.Tags)
            .GroupBy(t => t, StringComparer.OrdinalIgnoreCase)
            .Select(g => (Tag: g.Key, Count: g.Count()))
            .OrderByDescending(t => t.Count)
            .ThenBy(t => t.Tag)
            .ToList();
        // Pre-filter to this product's own first tag when it has one — merging repairs a split
        // ITEM, so its kin almost always share a tag. Clearing it is one tap on the active chip.
        mergeTagFilter = product.Tags.OrderBy(t => t.Value).FirstOrDefault() is { } own
            && mergeCandidates.Any(c => c.Tags.Contains(own.Value, StringComparer.OrdinalIgnoreCase))
            ? own.Value : "";
        mergeTargetId = 0;
        mergeVariety = null;
        mergeError = null;
        merging = true;
    }

    private void ToggleMergeTag(string value)
    {
        // Same toggle the Products cloud uses: tapping the active chip clears back to "any".
        mergeTagFilter = string.Equals(value, mergeTagFilter, StringComparison.OrdinalIgnoreCase) ? "" : value;
        // A target hidden by the new filter must not stay silently selected — the user can no
        // longer see what the Merge button would hit.
        if (mergeTargetId != 0 && !FilteredMergeCandidates.Any(c => c.Id == mergeTargetId))
        {
            mergeTargetId = 0;
            mergeVariety = null;
        }
    }

    private void CancelMerge()
    {
        merging = false;
        mergeError = null;
    }

    private void OnMergeTargetChanged()
    {
        if (product is null) return;
        var target = mergeCandidates.FirstOrDefault(c => c.Id == mergeTargetId);
        mergeVariety = target is null ? null
            : ProductMergeService.SuggestVarietyLabel(product.Name, target.Name);
    }

    private async Task SaveMerge()
    {
        if (product is null || mergeBusy || mergeTargetId == 0) return;
        mergeBusy = true;
        try
        {
            var result = await Merger.MergeAsync(product.Id, mergeTargetId, mergeVariety);
            if (!result.Ok)
            {
                mergeError = result.Message;
                return;
            }
            Nav.NavigateTo($"/product/{mergeTargetId}");
        }
        catch (DbUpdateException ex)
        {
            // Reachable: the same source merged from two tabs — the second delete finds zero rows
            // (concurrency exception). A merge that half-happened rolled back; say so instead of
            // letting the exception tear down the circuit.
            Logger.LogError(ex, "Merging product {SourceId} into {TargetId} failed.", product.Id, mergeTargetId);
            mergeError = "The merge didn't complete — the product may have changed or been merged elsewhere. Reload the page and try again.";
        }
        finally { mergeBusy = false; }
    }

    // "Also works as" editing. Each change persists immediately and reloads the list (so removes have ids).
    private async Task OnSubstituteKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddSubstitute();
    }

    private async Task AddSubstitute()
    {
        var value = newSubstitute.Trim();
        newSubstitute = "";
        if (value.Length == 0 || product is null) return;
        if (product.Substitutes.Any(s => string.Equals(s.Value, value, StringComparison.OrdinalIgnoreCase))) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        db.ProductSubstitutes.Add(new ProductSubstitute { ProductId = product.Id, Value = value });
        await db.SaveChangesAsync();
        await ReloadSubstitutes(db);
    }

    private async Task RemoveSubstitute(ProductSubstitute s)
    {
        if (product is null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        if (await db.ProductSubstitutes.FindAsync(s.Id) is { } row)
        {
            db.ProductSubstitutes.Remove(row);
            await db.SaveChangesAsync();
        }
        await ReloadSubstitutes(db);
    }

    private async Task SuggestSubstitutes()
    {
        if (product is null || suggesting) return;
        suggesting = true;
        try
        {
            var ideas = await SubAdvisor.SuggestAsync(product.Name, product.Category.ToString());
            var toAdd = ideas
                .Where(v => !product.Substitutes.Any(s => string.Equals(s.Value, v, StringComparison.OrdinalIgnoreCase)))
                .ToList();
            if (toAdd.Count == 0) return;
            await using var db = await DbFactory.CreateDbContextAsync();
            foreach (var v in toAdd)
                db.ProductSubstitutes.Add(new ProductSubstitute { ProductId = product.Id, Value = v });
            await db.SaveChangesAsync();
            await ReloadSubstitutes(db);
        }
        finally
        {
            suggesting = false;
        }
    }

    private async Task ReloadSubstitutes(ShelfAwareDbContext db)
    {
        if (product is null) return;
        product.Substitutes = await db.ProductSubstitutes
            .Where(s => s.ProductId == product.Id)
            .OrderBy(s => s.Value)
            .ToListAsync();
    }


    private static string Money(decimal amount) => amount.ToString("C");

    private static string Relative(int days) => days switch
    {
        < 0 => $"{-days} day{(days == -1 ? "" : "s")} overdue",
        0 => "today",
        _ => $"in {days} day{(days == 1 ? "" : "s")}"
    };

    private static string ChipClass(PredictionStatus s) => s switch
    {
        PredictionStatus.Overdue => "overdue",
        PredictionStatus.DueSoon => "duesoon",
        PredictionStatus.Stocked => "stocked",
        _ => "unknown"
    };

    private static string StatusLabel(PredictionStatus s) => s switch
    {
        PredictionStatus.Overdue => "Overdue",
        PredictionStatus.DueSoon => "Due soon",
        PredictionStatus.Stocked => "Stocked",
        _ => "Still learning"
    };
