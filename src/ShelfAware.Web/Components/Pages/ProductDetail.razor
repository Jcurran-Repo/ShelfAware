@page "/product/{Id:int}"
@using ShelfAware.Core.Prediction
@using ShelfAware.Core.Recipes
@using ShelfAware.Core.Shopping
@inject IDbContextFactory<ShelfAwareDbContext> DbFactory
@inject IProductSubstituteAdvisor SubAdvisor

<PageTitle>@(product?.Name ?? "Product") — Shelf Aware</PageTitle>

@if (notFound)
{
    <p>Product not found. <a href="/products">Back to products</a>.</p>
}
else if (product is null)
{
    <p>Loading…</p>
}
else
{
    <div class="page-head">
        <h1>@product.Name</h1>
        <span class="chip chip-@ChipClass(prediction.Status)">@StatusLabel(prediction.Status)</span>
    </div>
    <p class="muted">@product.Category@(product.DefaultUnit is { } u ? $" · {u}" : "") · <a href="/products">All products</a></p>
    @if (product.Tags.Count > 0)
    {
        <div class="tag-list detail-tags">
            @foreach (var t in product.Tags.OrderBy(t => t.Value))
            {
                <a class="tag-chip" href="/products?tag=@Uri.EscapeDataString(t.Value)" title="See all @t.Value products">@t.Value</a>
            }
        </div>
    }

    <section class="panel">
        <h2>Current rhythm</h2>
        <dl class="rhythm">
            <dt>Next buy</dt>
            <dd>@(estimate.NextBuyDate is { } d ? $"{d:MMM d, yyyy} ({Relative(estimate.DaysUntil!.Value)})" : "still learning")</dd>
            <dt>Rebuy rhythm</dt>
            <dd>@(prediction.RebuyIntervalDays is { } rb ? $"~every {Math.Round(rb)} days" : "—")</dd>
            @if (prediction.BurnRateDays is { } burn)
            {
                <dt>Burn rate</dt>
                <dd>one lasts ~@Math.Round(burn) days</dd>
            }
            @if (prediction.IntervalSpreadDays is { } sp && Math.Round(sp) >= 1)
            {
                <dt>Consistency</dt>
                <dd>give or take ~@Math.Round(sp) day@(Math.Round(sp) == 1 ? "" : "s")</dd>
            }
            @if (prediction.StockUpFactor is { } su)
            {
                <dt>Stocked up</dt>
                <dd>last buy was ~@su.ToString("0.#")× the usual — due date pushed out to match</dd>
            }
            <dt>Typical buy</dt>
            <dd>@estimate.RecommendedQuantity.ToString("0.##")@(product.DefaultUnit is { } u2 ? $" {u2}" : "")</dd>
            @if (SizeFormat.Normalize(prediction.RecommendedSize) is { Length: > 0 } rs)
            {
                <dt>Recommended size</dt>
                <dd>@rs</dd>
            }
            <dt>Last bought</dt>
            <dd>@(estimate.LastPurchased is { } lb ? lb.ToString("MMM d, yyyy") : "never")</dd>
            <dt>Est. cost / buy</dt>
            <dd>@(estimate.ExpectedCost is { } c ? c.ToString("C") : "unknown")</dd>
        </dl>
        <p class="muted">@prediction.Basis@(prediction.SignalNote is { } note ? $" · {note}" : "")</p>
        @if (prediction.RebuyIntervalDays is { } rbGap && prediction.BurnRateDays is { } burnGap)
        {
            var gap = (int)Math.Round(rbGap - burnGap);
            if (gap > 0)
            {
                <p class="rhythm-gap">⚠️ You typically run out about <strong>@gap day@(gap == 1 ? "" : "s")</strong> before you restock — worth buying it sooner.</p>
            }
            else if (gap < 0)
            {
                <p class="rhythm-gap">You usually restock about <strong>@(-gap) day@(-gap == 1 ? "" : "s")</strong> before running out — comfortably ahead.</p>
            }
        }
    </section>

    <section class="panel">
        <h2>Also works as</h2>
        <p class="muted">Recipe ingredients this can stand in for — so a recipe stays specific (real cook times) but still counts what you have. Editable.</p>
        <div class="tag-list">
            @foreach (var s in product.Substitutes.OrderBy(s => s.Value))
            {
                <span class="tag-chip">@s.Value<button type="button" class="tag-x" @onclick="() => RemoveSubstitute(s)" aria-label="Remove @s.Value">×</button></span>
            }
            @if (product.Substitutes.Count == 0)
            {
                <span class="muted">None yet — add some, or let the assistant suggest.</span>
            }
        </div>
        <div class="tag-add">
            <input placeholder="e.g. chicken breast" @bind="newSubstitute" @bind:event="oninput"
                   aria-label="Add a substitute this works as" @onkeydown="OnSubstituteKey" />
            <button type="button" @onclick="AddSubstitute" disabled="@string.IsNullOrWhiteSpace(newSubstitute)">Add</button>
            <button type="button" class="secondary" @onclick="SuggestSubstitutes" disabled="@suggesting">@(suggesting ? "Thinking…" : "✨ Suggest")</button>
        </div>
    </section>

    @if (usedInRecipes.Count > 0)
    {
        <section class="panel">
            <h2>Recipes that use this <span class="muted">— @usedInRecipes.Count</span></h2>
            <ul class="recipe-links">
                @foreach (var r in usedInRecipes)
                {
                    <li><a href="/recipes#recipe-@r.Id">@r.Name</a></li>
                }
            </ul>
        </section>
    }

    @if (brandBreakdown.Any(b => b.Brand != Unbranded))
    {
        <section class="panel">
            <h2>Brands bought</h2>
            <ul class="brands">
                @foreach (var b in brandBreakdown)
                {
                    <li>
                        <span class="brand-name">@b.Brand</span>
                        <span class="muted">@b.Count purchase@(b.Count == 1 ? "" : "s")@(b.AvgPrice is { } ap ? $" · avg {Money(ap)}" : "")</span>
                    </li>
                }
            </ul>
        </section>
    }

    @if (priceSeries.Count >= 2)
    {
        <section class="panel">
            <h2>Price history</h2>
            <LineChart Values="priceSeries" W="520" H="140" ShowDots="true"
                       AriaLabel="@($"{product.Name} price per purchase over time")" />
            <p class="muted">
                @priceSeries.Count price points · low @Money(priceSeries.Min()) ·
                high @Money(priceSeries.Max()) · latest @Money(priceSeries[^1])
            </p>
        </section>
    }

    <section class="panel">
        <h2>Recent purchases <span class="muted">— most recent first</span></h2>
        @if (history.Count == 0)
        {
            <p class="muted">No purchases recorded yet. Upload a receipt or use the dashboard quick update.</p>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th scope="col">Date</th>
                        <th scope="col">Since previous</th>
                        <th scope="col">Qty</th>
                        <th scope="col">Size</th>
                        <th scope="col">Unit price</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var h in history)
                    {
                        <tr>
                            <td>@h.Date.ToString("MMM d, yyyy")</td>
                            <td>@(h.GapDays is { } g ? $"{g} day{(g == 1 ? "" : "s")}" : "—")</td>
                            <td>@h.Quantity.ToString("0.##")</td>
                            <td>@(SizeFormat.Normalize(h.Size) is { Length: > 0 } s ? s : "—")</td>
                            <td>@(h.UnitPrice is { } up ? up.ToString("C") : "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
}

@code {
    [Parameter] public int Id { get; set; }

    private Product? product;
    private bool notFound;
    private PredictionResult prediction = null!;
    private ProductEstimate estimate = null!;
    private readonly List<PurchaseRow> history = [];
    private readonly List<decimal> priceSeries = [];
    private List<BrandRow> brandBreakdown = [];
    private List<RecipeLink> usedInRecipes = [];

    private string newSubstitute = "";
    private bool suggesting;

    private const string Unbranded = "Unbranded";

    private record PurchaseRow(DateOnly Date, int? GapDays, decimal Quantity, string? Size, decimal? UnitPrice);
    private record BrandRow(string Brand, int Count, decimal? AvgPrice);
    private record RecipeLink(int Id, string Name);

    private int? loadedId;

    // Load in OnParametersSet (not OnInitialized) and reset per-product state, so navigating straight from
    // /product/A to /product/B — where Blazor reuses this component instance — refreshes instead of showing
    // A's data. history/priceSeries persist on the reused instance, so they're cleared here too (they used
    // to just accumulate across navigations).
    protected override async Task OnParametersSetAsync()
    {
        if (loadedId == Id) return; // same product already loaded
        loadedId = Id;

        product = null;
        notFound = false;
        history.Clear();
        priceSeries.Clear();
        brandBreakdown = [];
        usedInRecipes = [];

        await using var db = await DbFactory.CreateDbContextAsync();
        product = await db.Products
            .AsNoTracking() // read-only detail view; substitute edits reload via their own context
            .Include(p => p.Purchases)
            .Include(p => p.Signals)
            .Include(p => p.Tags)
            .Include(p => p.Substitutes)
            .FirstOrDefaultAsync(p => p.Id == Id);

        if (product is null)
        {
            notFound = true;
            return;
        }

        // Per-receipt unit price for this product, so each purchase can show what it cost. Size rides
        // along so the est. cost/buy can price the recommended size, not a blend across sizes.
        var priceByReceipt = await db.ReceiptLines
            .Where(l => l.ProductId == Id && l.UnitPrice != null && l.ReceiptId != 0)
            .Select(l => new { l.ReceiptId, l.Size, Price = l.UnitPrice!.Value })
            .ToListAsync();
        var priceLookup = priceByReceipt
            .GroupBy(x => x.ReceiptId)
            .ToDictionary(g => g.Key, g => g.Average(x => x.Price));

        var today = DateOnly.FromDateTime(DateTime.Today);
        prediction = ReplenishmentPredictor.Predict(product, today);

        // Price the recommended (dominant) size specifically; fall back to the overall average.
        var recommendedKey = SizeKey(prediction.RecommendedSize);
        var recommendedSizePrices = priceByReceipt.Where(x => SizeKey(x.Size) == recommendedKey).Select(x => x.Price).ToList();
        decimal? estPrice = recommendedSizePrices.Count > 0
            ? recommendedSizePrices.Average()
            : priceByReceipt.Count > 0 ? priceByReceipt.Average(x => x.Price) : null;
        estimate = ShoppingEstimator.For(product, prediction, today, estPrice);

        var ordered = product.Purchases.OrderBy(p => p.PurchasedAt).ToList();
        for (var i = 0; i < ordered.Count; i++)
        {
            var pe = ordered[i];
            int? gap = i > 0 ? pe.PurchasedAt.DayNumber - ordered[i - 1].PurchasedAt.DayNumber : null;
            decimal? price = pe.ReceiptId is { } rid && priceLookup.TryGetValue(rid, out var pr) ? pr : null;
            if (price is { } pv) priceSeries.Add(pv); // ascending, for the chart
            history.Add(new PurchaseRow(pe.PurchasedAt, gap, pe.Quantity, pe.Size, price));
        }
        history.Reverse(); // most recent first

        // Brand-agnostic product: which brands of this item have been bought, and how often.
        decimal? PriceOf(PurchaseEvent pe) =>
            pe.ReceiptId is { } rid && priceLookup.TryGetValue(rid, out var pr) ? pr : null;
        brandBreakdown = product.Purchases
            .GroupBy(pe => string.IsNullOrWhiteSpace(pe.Brand) ? Unbranded : pe.Brand!.Trim())
            .Select(g =>
            {
                var prices = g.Select(PriceOf).Where(p => p is not null).Select(p => p!.Value).ToList();
                return new BrandRow(g.Key, g.Count(), prices.Count > 0 ? prices.Average() : null);
            })
            .OrderByDescending(b => b.Count).ThenBy(b => b.Brand)
            .ToList();

        // Saved recipes whose ingredient→product map points at this item (grounded match captured at
        // save time). Just links out to the recipe on /recipes — no recipe content duplicated here.
        var productName = product.Name;
        usedInRecipes = (await db.Recipes.Include(r => r.Ingredients).ToListAsync())
            .Where(r => r.Ingredients.Any(i => string.Equals(i.MatchedProduct, productName, StringComparison.OrdinalIgnoreCase)))
            .OrderBy(r => r.Name)
            .Select(r => new RecipeLink(r.Id, r.Name))
            .ToList();
    }

    // "Also works as" editing. Each change persists immediately and reloads the list (so removes have ids).
    private async Task OnSubstituteKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddSubstitute();
    }

    private async Task AddSubstitute()
    {
        var value = newSubstitute.Trim();
        newSubstitute = "";
        if (value.Length == 0 || product is null) return;
        if (product.Substitutes.Any(s => string.Equals(s.Value, value, StringComparison.OrdinalIgnoreCase))) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        db.ProductSubstitutes.Add(new ProductSubstitute { ProductId = product.Id, Value = value });
        await db.SaveChangesAsync();
        await ReloadSubstitutes(db);
    }

    private async Task RemoveSubstitute(ProductSubstitute s)
    {
        if (product is null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        if (await db.ProductSubstitutes.FindAsync(s.Id) is { } row)
        {
            db.ProductSubstitutes.Remove(row);
            await db.SaveChangesAsync();
        }
        await ReloadSubstitutes(db);
    }

    private async Task SuggestSubstitutes()
    {
        if (product is null || suggesting) return;
        suggesting = true;
        try
        {
            var ideas = await SubAdvisor.SuggestAsync(product.Name, product.Category.ToString());
            var toAdd = ideas
                .Where(v => !product.Substitutes.Any(s => string.Equals(s.Value, v, StringComparison.OrdinalIgnoreCase)))
                .ToList();
            if (toAdd.Count == 0) return;
            await using var db = await DbFactory.CreateDbContextAsync();
            foreach (var v in toAdd)
                db.ProductSubstitutes.Add(new ProductSubstitute { ProductId = product.Id, Value = v });
            await db.SaveChangesAsync();
            await ReloadSubstitutes(db);
        }
        finally
        {
            suggesting = false;
        }
    }

    private async Task ReloadSubstitutes(ShelfAwareDbContext db)
    {
        if (product is null) return;
        product.Substitutes = await db.ProductSubstitutes
            .Where(s => s.ProductId == product.Id)
            .OrderBy(s => s.Value)
            .ToListAsync();
    }

    private static string SizeKey(string? size) => (size ?? "").Trim().ToLowerInvariant();

    private static string Money(decimal amount) => amount.ToString("C");

    private static string Relative(int days) => days switch
    {
        < 0 => $"{-days} day{(days == -1 ? "" : "s")} overdue",
        0 => "today",
        _ => $"in {days} day{(days == 1 ? "" : "s")}"
    };

    private static string ChipClass(PredictionStatus s) => s switch
    {
        PredictionStatus.Overdue => "overdue",
        PredictionStatus.DueSoon => "duesoon",
        PredictionStatus.Stocked => "stocked",
        _ => "unknown"
    };

    private static string StatusLabel(PredictionStatus s) => s switch
    {
        PredictionStatus.Overdue => "Overdue",
        PredictionStatus.DueSoon => "Due soon",
        PredictionStatus.Stocked => "Stocked",
        _ => "Still learning"
    };
}
