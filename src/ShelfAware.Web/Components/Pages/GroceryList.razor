@page "/list"
@using ShelfAware.Core.Chat
@using ShelfAware.Core.Prediction
@using ShelfAware.Core.Shopping
@implements IAsyncDisposable
@inject IHouseholdDbFactory DbFactory
@inject IPantryStore Store
@inject IJSRuntime JS

<PageTitle>Grocery List — Shelf Aware</PageTitle>

<div class="page-head">
    <h1>Grocery List</h1>
    @if (loaded)
    {
        <span class="summary">
            <strong>Next run ≈ @Money(buyNowTotal)</strong>
            @if (buyNowUnknownCount > 0)
            {
                <span class="muted">+@buyNowUnknownCount with no price yet</span>
            }
        </span>
    }
</div>

<section class="panel extras">
    <h2>Extras <span class="muted">— add anything manually, or from a recipe</span></h2>
    <div class="tag-list">
        @foreach (var e in extras)
        {
            <span class="tag-chip">@e.Name<button type="button" class="tag-x" @onclick="() => RemoveExtra(e)" aria-label="Remove @e.Name">×</button></span>
        }
        @if (extras.Count == 0)
        {
            <span class="muted">Nothing extra yet.</span>
        }
    </div>
    <div class="tag-add">
        <input placeholder="+ add an item" @bind="newExtra" @bind:event="oninput" aria-label="Add an item to the grocery list" />
        <button type="button" @onclick="AddExtra" disabled="@string.IsNullOrWhiteSpace(newExtra)">Add</button>
    </div>
</section>

@if (loaded && buyNow.Count > 0)
{
    <div class="list-actions">
        <button class="secondary" @onclick="CopyList">Copy list</button>
        <button class="secondary" @onclick="PrintList">Print</button>
        <button class="secondary" @onclick="DownloadList">Download</button>
        <span class="muted kbd-hint">press <kbd>D</kbd> to download</span>
        @if (copied)
        {
            <span class="muted" role="status">Copied to clipboard</span>
        }
    </div>
}

@if (!loaded)
{
    <p>Loading…</p>
}
else if (buyNow.Count == 0 && comingUp.Count == 0 && learning.Count == 0)
{
    <p class="muted">No tracked products yet. Add some on the <a href="/products">Products</a> page.</p>
}
else
{
    @if (buyNow.Count > 0)
    {
        <h2>Buy now <span class="muted">— @buyNow.Count item@(buyNow.Count == 1 ? "" : "s")</span></h2>
        @ReportTable(buyNow, buyNowTotal, buyNowUnknownCount, canIgnore: true)
    }

    @if (comingUp.Count > 0)
    {
        <h2>Coming up</h2>
        @ReportTable(comingUp, comingUpTotal, comingUpUnknownCount, canIgnore: false)
    }

    @if (buyNow.Count > 0 && comingUp.Count > 0)
    {
        <p class="grand-total"><strong>Everything tracked: @Money(buyNowTotal + comingUpTotal)</strong> <span class="muted">(known prices)</span></p>
    }

    @if (learning.Count > 0)
    {
        <details class="everything-else">
            <summary>Still learning (@learning.Count)</summary>
            <p class="muted">No estimate yet — buy each a couple of times and it'll move up: @string.Join(", ", learning.Select(e => e.Name)).</p>
        </details>
    }
}

@code {
    private bool loaded;
    private List<ProductEstimate> buyNow = [];
    private List<ProductEstimate> comingUp = [];
    private List<ProductEstimate> learning = [];
    private decimal buyNowTotal, comingUpTotal;
    private int buyNowUnknownCount, comingUpUnknownCount;

    private List<GroceryExtra> extras = [];
    private string newExtra = "";

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        extras = await db.GroceryExtras.OrderBy(e => e.Name).ToListAsync();
        var products = await db.Products
            .AsNoTracking() // read-only list
            .Where(p => p.IsTracked)
            .Include(p => p.Purchases)
            .Include(p => p.Signals)
            .Include(p => p.Tags)
            .OrderBy(p => p.Name)
            .ToListAsync();

        var priceLines = await db.ReceiptLines
            .Where(l => l.ProductId != null && l.UnitPrice != null)
            .Select(l => new { Id = l.ProductId!.Value, l.Size, Price = l.UnitPrice!.Value })
            .ToListAsync();
        // Price the recommended (dominant) size specifically, not a blend across every size bought —
        // so a half-gallon-vs-gallon item estimates the size we actually tell you to buy.
        // ProductPriceIndex folds the loose/"each" spellings together (per-each produce matches a
        // null recommended size) and falls back to the product's overall average.
        var prices = new ProductPriceIndex(priceLines.Select(x => (x.Id, x.Size, x.Price)));

        var today = DateOnly.FromDateTime(DateTime.Today);
        var all = products.Select(p =>
        {
            var prediction = ReplenishmentPredictor.Predict(p, today);
            return ShoppingEstimator.For(p, prediction, today, prices.PriceFor(p.Id, prediction.RecommendedSize));
        }).ToList();

        // Both tables ordered by aisle (category) so the whole page matches how you walk a store,
        // then by urgency within each aisle. The date column still carries the chronology.
        buyNow = all
            .Where(e => e.Status is PredictionStatus.Overdue or PredictionStatus.DueSoon)
            .OrderBy(e => e.Category)
            .ThenBy(e => e.DaysUntil ?? int.MaxValue)
            .ThenBy(e => e.Name)
            .ToList();
        comingUp = all
            .Where(e => e.Status == PredictionStatus.Stocked)
            .OrderBy(e => e.Category)
            .ThenBy(e => e.NextBuyDate ?? DateOnly.MaxValue)
            .ThenBy(e => e.Name)
            .ToList();
        learning = all
            .Where(e => e.Status == PredictionStatus.Unknown)
            .OrderBy(e => e.Name)
            .ToList();

        buyNowTotal = buyNow.Sum(e => e.ExpectedCost ?? 0m);
        comingUpTotal = comingUp.Sum(e => e.ExpectedCost ?? 0m);
        buyNowUnknownCount = buyNow.Count(e => e.ExpectedCost is null);
        comingUpUnknownCount = comingUp.Count(e => e.ExpectedCost is null);
        loaded = true;
    }

    private RenderFragment ReportTable(List<ProductEstimate> items, decimal subtotal, int unknownCount, bool canIgnore) =>
        @<div class="table-scroll">
            <table>
                <caption class="visually-hidden">Grocery items with category, replenishment status, next buy date, quantity, and estimated cost.</caption>
                <thead>
                    <tr>
                        <th scope="col">Item</th>
                        <th scope="col">Category</th>
                        <th scope="col">Status</th>
                        <th scope="col">Next buy</th>
                        <th scope="col">Qty</th>
                        <th scope="col">Est. cost</th>
                        @if (canIgnore)
                        {
                            <th scope="col"><span class="visually-hidden">Actions</span></th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in items)
                    {
                        <tr>
                            <td>
                                <a class="item-name" href="/product/@e.ProductId">@e.Name</a>
                                @if (e.RecommendedSize is { Length: > 0 } || e.UsualBrand is not null || e.Tags.Count > 0)
                                {
                                    <div class="item-meta">
                                        @if (e.RecommendedSize is { Length: > 0 } sz)
                                        {
                                            <span class="size-chip" title="Suggested size to buy">@sz</span>
                                        }
                                        @if (e.UsualBrand is { } brand)
                                        {
                                            <span class="usual-brand">@brand</span>
                                        }
                                        @foreach (var t in e.Tags)
                                        {
                                            <a class="tag-chip tag-chip-mini" href="/products?tag=@Uri.EscapeDataString(t)" title="See all @t products">@t</a>
                                        }
                                    </div>
                                }
                            </td>
                            <td>@e.Category</td>
                            <td><span class="chip chip-@ChipClass(e.Status)">@StatusLabel(e.Status)</span></td>
                            <td>
                                @(e.NextBuyDate is { } d ? d.ToString("MMM d") : "—")
                                @if (e.DaysUntil is { } du)
                                {
                                    <span class="muted"> (@Relative(du))</span>
                                }
                            </td>
                            <td>@e.RecommendedQuantity.ToString("0.##")</td>
                            <td>@(e.ExpectedCost is { } c ? Money(c) : "—")</td>
                            @if (canIgnore)
                            {
                                <td class="row-actions">
                                    <button type="button" class="restock-btn" @onclick="() => Restocked(e)"
                                            disabled="@actionBusy"
                                            title="Already have @e.Name at home — clears the reminder and re-anchors its next due date"
                                            aria-label="Mark @e.Name restocked — you already have it">Restocked</button>
                                    <button type="button" class="untrack-btn" @onclick="() => Untrack(e)"
                                            disabled="@actionBusy"
                                            title="Don't want @e.Name for a while — stops suggesting it until you buy it again (history kept)"
                                            aria-label="Untrack @e.Name — stop suggesting it until it's bought again">Untrack</button>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="5" class="subtotal-label">Subtotal@(unknownCount > 0 ? $" ({unknownCount} without a price)" : "")</td>
                        <td class="subtotal">@Money(subtotal)</td>
                        @if (canIgnore)
                        {
                            <td></td>
                        }
                    </tr>
                </tfoot>
            </table>
        </div>;

    private bool actionBusy;

    // Two row actions with genuinely different meanings, both real while staring at the list:
    // • Restocked = "I actually have some" — a status-only signal that clears an OutNow and re-anchors
    //   the due date (§6 two-stream model: it never feeds the cadence), so the item settles into
    //   "Coming up" instead of nagging. Same write as the dashboard's Restocked, via IPantryStore.
    // • Untrack = "don't want it for a while" — stops tracking, so the item leaves the list and
    //   dashboard until a purchase brings it back (any recorded purchase — receipt confirm or
    //   chat/voice — re-tracks automatically; the Products checkbox and set_tracking tool also work).
    //   A restock-based snooze would just re-nag next cycle, hence untrack. History is kept.
    private async Task Restocked(ProductEstimate e)
    {
        if (actionBusy) return;
        actionBusy = true;
        try
        {
            copied = false; // the copied list is now stale
            await Store.RecordSignalAsync(e.ProductId, SignalKind.Restocked);
            await LoadAsync();
        }
        finally { actionBusy = false; }
    }

    private async Task Untrack(ProductEstimate e)
    {
        if (actionBusy) return;
        actionBusy = true;
        try
        {
            copied = false; // the copied list is now stale
            await using var db = await DbFactory.CreateDbContextAsync();
            if (await db.Products.FindAsync(e.ProductId) is { } product)
            {
                product.IsTracked = false;
                await db.SaveChangesAsync();
            }
            await LoadAsync();
        }
        finally { actionBusy = false; }
    }

    private async Task AddExtra()
    {
        var name = newExtra.Trim();
        if (name.Length == 0) return;
        copied = false; // the copied list is now stale
        await using var db = await DbFactory.CreateDbContextAsync();
        var have = await db.GroceryExtras.Select(e => e.Name).ToListAsync();
        if (!have.Any(h => string.Equals(h, name, StringComparison.OrdinalIgnoreCase)))
        {
            db.GroceryExtras.Add(new GroceryExtra { Name = name });
            await db.SaveChangesAsync();
        }
        newExtra = "";
        extras = await db.GroceryExtras.OrderBy(e => e.Name).ToListAsync();
    }

    private async Task RemoveExtra(GroceryExtra e)
    {
        copied = false; // the copied list is now stale
        await using var db = await DbFactory.CreateDbContextAsync();
        // No fallback to the detached `e`: the lookup is household-filtered, so a miss means the row is
        // gone (a double tap) or isn't ours — and removing `e` anyway would delete it keyed on the id
        // alone, unfiltered. Nothing to delete is a no-op, not an error.
        if (await db.GroceryExtras.FindAsync(e.Id) is { } row)
        {
            db.GroceryExtras.Remove(row);
            await db.SaveChangesAsync();
        }
        extras = await db.GroceryExtras.OrderBy(x => x.Name).ToListAsync();
    }

    private bool copied;

    private IJSObjectReference? downloadModule;
    private DotNetObjectReference<GroceryList>? selfRef;

    // Wire the "D" download shortcut once the page is interactive. The module + self-reference are cleaned
    // up in DisposeAsync so the listener doesn't outlive the page.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            downloadModule = await JS.InvokeAsync<IJSObjectReference>("import", "/js/download.js");
            selfRef = DotNetObjectReference.Create(this);
            await downloadModule.InvokeVoidAsync("registerShortcut", selfRef, "d");
        }
        catch (JSDisconnectedException) { /* circuit gone before wiring — nothing to clean up yet */ }
    }

    [JSInvokable]
    public Task OnDownloadShortcut() => DownloadList();

    private async Task CopyList()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", BuildListText());
        copied = true;
    }

    private async Task PrintList() => await JS.InvokeVoidAsync("window.print");

    private async Task DownloadList()
    {
        downloadModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "/js/download.js");
        var name = $"grocery-list-{DateOnly.FromDateTime(DateTime.Today):yyyy-MM-dd}.txt";
        await downloadModule.InvokeVoidAsync("downloadText", name, BuildListText());
    }

    public async ValueTask DisposeAsync()
    {
        if (downloadModule is not null)
        {
            try
            {
                await downloadModule.InvokeVoidAsync("unregister");
                await downloadModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { /* circuit already gone */ }
        }
        selfRef?.Dispose();
    }

    private string BuildListText()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"Grocery List — {DateOnly.FromDateTime(DateTime.Today):yyyy-MM-dd}");
        sb.AppendLine($"Buy now (~{Money(buyNowTotal)}):");
        foreach (var e in buyNow)
        {
            var qualifiers = new List<string>();
            if (e.UsualBrand is { } b) qualifiers.Add(b);
            if (e.RecommendedSize is { Length: > 0 } s) qualifiers.Add(s);
            var q = qualifiers.Count > 0 ? $" ({string.Join(", ", qualifiers)})" : "";
            var cost = e.ExpectedCost is { } c ? $" — {Money(c)}" : "";
            sb.AppendLine($"- {e.Name}{q} ×{e.RecommendedQuantity:0.##}{cost}");
        }
        if (extras.Count > 0)
        {
            sb.AppendLine("Extras:");
            foreach (var x in extras) sb.AppendLine($"- {x.Name}");
        }
        return sb.ToString();
    }

    private static string Money(decimal amount) => amount.ToString("C");

    private static string Relative(int days) => days switch
    {
        < 0 => $"{-days} day{P(-days)} overdue",
        0 => "today",
        _ => $"in {days} day{P(days)}"
    };

    private static string P(int n) => n == 1 ? "" : "s";

    private static string ChipClass(PredictionStatus s) => s switch
    {
        PredictionStatus.Overdue => "overdue",
        PredictionStatus.DueSoon => "duesoon",
        PredictionStatus.Stocked => "stocked",
        _ => "unknown"
    };

    private static string StatusLabel(PredictionStatus s) => s switch
    {
        PredictionStatus.Overdue => "Overdue",
        PredictionStatus.DueSoon => "Due soon",
        PredictionStatus.Stocked => "Stocked",
        _ => "Still learning"
    };
}
