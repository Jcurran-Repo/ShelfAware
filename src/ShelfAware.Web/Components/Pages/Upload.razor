@page "/receipt"
@using ShelfAware.Core.Chat
@using ShelfAware.Core.Extraction
@using ShelfAware.Core.Tagging
@using Microsoft.Extensions.Options
@inject IHouseholdDbFactory DbFactory
@inject IReceiptExtractor Extractor
@inject ITagAdvisor Advisor
@inject AppPaths Paths
@inject IOptions<ShelfAware.Llm.LlmOptions> LlmOptions
@inject ReceiptConfirmationService Confirmer
@inject ILogger<Upload> Logger

<PageTitle>Upload receipt — Shelf Aware</PageTitle>

<h1>Upload receipt</h1>

@if (phase is Phase.Idle or Phase.Error or Phase.Extracting)
{
    @* The InputFile must stay mounted while extracting — IBrowserFile reads stream
       through the DOM element, and unmounting it breaks them mid-read. *@
    <section class="panel">
        <p>
            Photograph paper receipts — several at once is fine, each image is read as its own receipt.
            Screenshots and print-to-PDF order pages also work. For one long receipt split across
            several photos, tick the box below and they'll be merged.
        </p>
        <div hidden="@(phase == Phase.Extracting)">
            <InputFile OnChange="OnFilesSelected" multiple accept="image/jpeg,image/png,image/gif,image/webp,application/pdf" aria-label="Upload receipt images or PDF" />
            @if (selectedFiles.Count > 0)
            {
                <p>@selectedFiles.Count file(s) selected@(selectedFiles.Count > 1 && !combineAsOne ? $" — {selectedFiles.Count} receipts" : "").</p>
                @if (selectedFiles.Count > 1)
                {
                    <label class="combine-check">
                        <input type="checkbox" @bind="combineAsOne" />
                        These are all <strong>one receipt</strong> (multiple photos/pages of a single long receipt)
                    </label>
                }
                <button @onclick="Extract">Extract</button>
            }
        </div>
        @if (batch.Count > 0)
        {
            <ul class="batch-progress" aria-label="Receipt extraction progress">
                @foreach (var b in batch)
                {
                    <li>
                        <span class="batch-icon" aria-hidden="true">@BatchIcon(b.Status)</span>
                        <span class="batch-name">@b.FileName</span>
                        <span class="@(b.Status == BatchStatus.Failed ? "error" : "muted")" role="status">@BatchNote(b)</span>
                    </li>
                }
            </ul>
        }
        @if (phase == Phase.Extracting)
        {
            <p class="spinner">
                @(batch.Count > 0
                    ? $"Reading receipt {Math.Min(batch.Count(x => x.Status is BatchStatus.Done or BatchStatus.Failed) + 1, batch.Count)} of {batch.Count}…"
                    : "Reading your receipt… this usually takes a few seconds.")
            </p>
        }
        @if (phase == Phase.Error)
        {
            <p class="error">@errorMessage</p>
        }
    </section>

    @if (phase == Phase.Idle && pendingReceipts.Count > 0)
    {
        <section class="panel">
            <h2>Waiting for review (@pendingReceipts.Count)</h2>
            <p class="muted">Imports held for your approval, plus any receipt that couldn't be read.</p>
            <ul class="pending-receipts">
                @foreach (var pr in pendingReceipts)
                {
                    <li>
                        <span>
                            <strong>@(pr.Merchant ?? "Unknown merchant")</strong>
                            @if (pr.LineCount == 0)
                            {
                                <span class="error"> · couldn't be read — retry or discard</span>
                            }
                            else
                            {
                                <span class="muted"> · @(pr.PurchasedAt?.ToString("MMM d, yyyy") ?? "no date") · @pr.LineCount item(s)</span>
                            }
                        </span>
                        <span class="pending-actions">
                            @if (pr.LineCount == 0)
                            {
                                <button @onclick="() => RetryPending(pr.Id)" disabled="@(retryingId is not null)"
                                        aria-label="Retry reading receipt from @(pr.Merchant ?? "unknown merchant")">
                                    @(retryingId == pr.Id ? "Retrying…" : "Retry")
                                </button>
                            }
                            else
                            {
                                <button @onclick="() => ReviewPending(pr.Id)">Review</button>
                            }
                            <button class="secondary" @onclick="() => DiscardPending(pr.Id)" disabled="@(retryingId is not null)" aria-label="Discard receipt from @(pr.Merchant ?? "unknown merchant")">Discard</button>
                        </span>
                    </li>
                }
            </ul>
            @if (pendingError is not null)
            {
                <p class="error" role="alert">@pendingError</p>
            }
        </section>
    }
}
else if (phase == Phase.Review && receipt is not null)
{
    <section class="panel">
        <p>
            <strong>@(receipt.Merchant ?? "Unknown merchant")</strong> — @reviewLines.Count item(s). Review and correct before confirming.
        </p>
        <p class="review-date">
            <label for="receipt-date"><strong>Purchase date</strong></label>
            <input id="receipt-date" type="date" @bind="reviewDate"
                   max="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")" />
            @if (receipt.PurchasedAt is null)
            {
                <span class="error">No date detected — set the actual purchase date so refill timing stays accurate.</span>
            }
            else
            {
                <span class="muted">Detected from the receipt. Correct it if it's wrong — this drives the refill predictions.</span>
            }
        </p>
        @if (reviewLines.Count == 0)
        {
            <p class="error">No purchasable items were found — this may not be a receipt. You can discard it below.</p>
        }
        <div class="table-scroll table-scroll--capped">
        <table>
            <thead>
                <tr>
                    <th scope="col">Receipt text</th>
                    <th scope="col">Item</th>
                    <th scope="col">Brand</th>
                    <th scope="col">Size</th>
                    <th scope="col">Qty</th>
                    <th scope="col">Category</th>
                    <th scope="col">Tags</th>
                    <th scope="col">Product match</th>
                    <th scope="col"><span class="visually-hidden">Actions</span></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var line in reviewLines)
                {
                    <tr class="@(line.Confidence < 0.6m ? "low-confidence" : "")">
                        <td class="raw">
                            @line.RawText
                            <div>
                                <span class="chip chip-@(line.Confidence < 0.6m ? "duesoon" : "stocked")"
                                      title="How confident the extraction was in this line">
                                    @line.Confidence.ToString("P0") sure
                                </span>
                            </div>
                        </td>
                        <td><input @bind="line.NormalizedName" aria-label="Item name for @line.RawText" /></td>
                        <td><input @bind="line.Brand" size="12" placeholder="—" aria-label="Brand for @line.RawText" /></td>
                        <td><input @bind="line.Size" size="8" placeholder="—" aria-label="Size for @line.RawText" /></td>
                        <td><input type="number" step="0.01" min="0.01" @bind="line.Quantity" size="5" aria-label="Quantity for @line.RawText" /></td>
                        <td>
                            <select @bind="line.Category" aria-label="Category for @line.RawText">
                                @foreach (var c in Enum.GetValues<Category>())
                                {
                                    <option value="@c">@c</option>
                                }
                            </select>
                        </td>
                        <td class="tags-cell">
                            <div class="tag-list">
                                @foreach (var t in line.Tags)
                                {
                                    <span class="tag-chip">@t<button type="button" class="tag-x" @onclick="() => line.Tags.Remove(t)" aria-label="Remove tag @t">×</button></span>
                                }
                            </div>
                            <div class="tag-add">
                                <input list="known-tags" placeholder="+ tag" size="9" @bind="line.NewTag" @bind:event="oninput" aria-label="Add a tag to @line.RawText" />
                                <button type="button" @onclick="() => AddTag(line)" disabled="@(line.Checking || string.IsNullOrWhiteSpace(line.NewTag))">@(line.Checking ? "…" : "Add")</button>
                            </div>
                            @if (line.Suggestion is { } sug)
                            {
                                <div class="tag-warning" role="status">
                                    “@line.PendingTag” looks like “<strong>@sug</strong>”.
                                    <button type="button" @onclick="() => UseSuggestion(line)">Use “@sug”</button>
                                    <button type="button" class="secondary" @onclick="() => AddAnyway(line)">Add “@line.PendingTag” anyway</button>
                                </div>
                            }
                        </td>
                        <td>
                            <select @bind="line.ProductId" aria-label="Product match for @line.RawText">
                                <option value="0">➕ create new product</option>
                                @foreach (var p in products)
                                {
                                    <option value="@p.Id">@p.Name</option>
                                }
                            </select>
                            @if (line.AliasMatched)
                            {
                                <span role="img" aria-label="Matched a previous receipt line from this merchant" title="Matched a previous receipt line from this merchant">🔗</span>
                            }
                            @if (line.ProductId > 0 && products.FirstOrDefault(p => p.Id == line.ProductId) is { IsTracked: false })
                            {
                                <div class="muted small" role="status">Currently ignored — this purchase starts tracking it again.</div>
                            }
                        </td>
                        <td><button class="secondary" @onclick="() => reviewLines.Remove(line)" aria-label="Remove line @line.RawText"><span aria-hidden="true">✕</span></button></td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
        <datalist id="known-tags">
            @foreach (var t in allKnownTags)
            {
                <option value="@t" />
            }
        </datalist>
        <p class="verify-for-eval">
            <label>
                <input type="checkbox" @bind="verifiedForEval"
                       aria-label="I checked every line — use this receipt for accuracy checks" />
                I checked every line — use this receipt for accuracy checks
            </label>
            <span class="muted">Verified receipts become ground truth for the “Your receipts” accuracy
            check on the Accuracy page. Only tick it if you really read each line.</span>
        </p>
        <div class="review-actions">
            <button @onclick="ConfirmAll" disabled="@(reviewLines.Count == 0 || confirming)">@(confirming ? "Saving…" : "Confirm all")</button>
            <button class="secondary" @onclick="Discard" disabled="@confirming">Discard receipt</button>
        </div>
        @if (confirmError is not null)
        {
            <p class="error" role="alert">@confirmError</p>
        }
    </section>
}
else if (phase == Phase.Done)
{
    <section class="panel">
        <p>✅ @confirmSummary</p>
        <button @onclick="Reset">Upload another</button>
    </section>
}

@code {
    private enum Phase { Idle, Extracting, Review, Done, Error }

    private const long MaxUploadBytes = 25 * 1024 * 1024;

    private Phase phase = Phase.Idle;
    private string? errorMessage;
    private List<IBrowserFile> selectedFiles = [];
    private Receipt? receipt;
    private DateOnly reviewDate = DateOnly.FromDateTime(DateTime.Today);
    private List<ReviewLine> reviewLines = [];
    private List<Product> products = [];
    private string confirmSummary = "";
    private string? confirmError;
    private bool confirming;
    // The user's explicit "I checked every line" opt-in — makes the confirmed lines extraction ground
    // truth (Receipt.VerifiedForEval). Off by default and reset per review; never set by machine confirms.
    private bool verifiedForEval;

    private List<PendingRow> pendingReceipts = [];
    private record PendingRow(int Id, string? Merchant, DateOnly? PurchasedAt, int LineCount);
    private int? retryingId;
    private string? pendingError;

    private class ReviewLine
    {
        public required string RawText { get; set; }
        public string NormalizedName { get; set; } = "";
        public string? Brand { get; set; }
        public string? Size { get; set; }
        public decimal Quantity { get; set; } = 1;
        public Category Category { get; set; }
        public decimal Confidence { get; set; }
        public decimal? UnitPrice { get; set; }
        public List<string> Tags { get; set; } = [];
        public string? NewTag { get; set; }           // the in-progress "add tag" input
        public string? PendingTag { get; set; }        // a new tag awaiting the user's dedup decision
        public string? Suggestion { get; set; }        // the existing tag PendingTag looks like
        public bool Checking { get; set; }             // an async synonym check is running
        public int ProductId { get; set; }            // 0 = create new
        public bool AliasMatched { get; set; }
    }

    // Tag universe for suggestions + dedup: seed vocabulary ∪ tags already stored on products.
    private List<string> allKnownTags = [];

    protected override async Task OnInitializedAsync() => await LoadPendingAsync();

    // Everything PendingReview: receipts the importer queued (Smart/Review mode), abandoned manual
    // reviews, AND zero-line receipts whose extraction failed — those used to be filtered out and were
    // invisible forever (the only recovery was reading the server logs).
    private async Task LoadPendingAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        pendingReceipts = await db.Receipts
            .Where(r => r.Status == ReceiptStatus.PendingReview)
            .OrderBy(r => r.Id)
            .Select(r => new PendingRow(r.Id, r.Merchant, r.PurchasedAt, r.Lines.Count))
            .ToListAsync();
    }

    // Load a queued receipt into the SAME editable review table the manual upload uses, so it can be
    // edited + confirmed (or discarded) — reusing ConfirmAll, which already works off the receipt id.
    private Task ReviewPending(int receiptId) => LoadReviewAsync(receiptId);

    // ONE review pre-fill for both entry paths (fresh extraction and auto-import queue): lines come
    // from the stored receipt — tags and the model's suggestion are persisted on ReceiptLine now —
    // with the product pre-filled by trust order: learned alias → model suggestion → matcher → new.
    private async Task LoadReviewAsync(int receiptId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var r = await db.Receipts.Include(x => x.Lines).FirstOrDefaultAsync(x => x.Id == receiptId);
        if (r is null || r.Status != ReceiptStatus.PendingReview) { await LoadPendingAsync(); return; }

        receipt = r;
        reviewDate = r.PurchasedAt ?? DateOnly.FromDateTime(DateTime.Today);
        products = await db.Products.OrderBy(p => p.Name).ToListAsync();
        var stored = await db.ProductTags.Select(t => t.Value).Distinct().ToListAsync();
        allKnownTags = TagVocabulary.Seed.Concat(stored).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(t => t).ToList();

        var merchant = r.Merchant ?? "";
        var aliases = await db.ProductAliases.Where(a => a.Merchant == merchant).ToListAsync();
        reviewLines = r.Lines.Select(l =>
        {
            var alias = aliases.FirstOrDefault(a => a.RawText == l.RawText);
            Product? match = null;
            if (alias is null)
            {
                // Size is metadata, not identity — match on item name only (all sizes roll up).
                match = l.SuggestedProduct is { Length: > 0 }
                    ? products.FirstOrDefault(p => string.Equals(p.Name, l.SuggestedProduct, StringComparison.OrdinalIgnoreCase))
                    : null;
                match ??= ProductMatcher.Resolve(l.NormalizedName, products);
            }
            return new ReviewLine
            {
                RawText = l.RawText,
                NormalizedName = l.NormalizedName,
                Brand = l.Brand,
                Size = l.Size,
                Quantity = l.Quantity,
                Category = l.Category,
                Confidence = l.Confidence,
                UnitPrice = l.UnitPrice,
                Tags = ReceiptConfirmationService.DeserializeTags(l.TagsJson),
                ProductId = alias?.ProductId ?? match?.Id ?? 0,
                AliasMatched = alias is not null,
            };
        }).ToList();

        confirmError = null;
        verifiedForEval = false; // a fresh review starts unasserted
        phase = Phase.Review;
    }

    private async Task DiscardPending(int receiptId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var r = await db.Receipts.FirstOrDefaultAsync(x => x.Id == receiptId);
        if (r is not null)
        {
            r.Status = ReceiptStatus.Discarded;
            await db.SaveChangesAsync();
        }
        await LoadPendingAsync();
    }

    // Re-extract a failed (zero-line) receipt from the audit copy saved at import time — a transient
    // API blip during an auto-scan used to park the file permanently with no way back but the logs.
    private async Task RetryPending(int receiptId)
    {
        if (retryingId is not null) return;
        retryingId = receiptId;
        pendingError = null;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var r = await db.Receipts.Include(x => x.Lines).FirstOrDefaultAsync(x => x.Id == receiptId);
            if (r is null) { await LoadPendingAsync(); return; }

            var folder = Path.Combine(Paths.DataDir, r.ImagePath);
            var files = Directory.Exists(folder)
                ? Directory.GetFiles(folder, "page-*.*").OrderBy(f => f, StringComparer.OrdinalIgnoreCase).ToList()
                : [];
            if (files.Count == 0)
            {
                pendingError = "The saved copy of this receipt is missing — discard it and re-upload.";
                return;
            }

            var attachments = new List<ReceiptAttachment>();
            foreach (var file in files)
            {
                attachments.Add(new ReceiptAttachment(await File.ReadAllBytesAsync(file), MediaTypeFor(file)));
            }

            List<string> productNames;
            List<string> tagHints;
            await using (var pdb = await DbFactory.CreateDbContextAsync())
            {
                productNames = await pdb.Products.OrderBy(p => p.Name).Select(p => p.Name).Distinct().ToListAsync();
                var stored = await pdb.ProductTags.Select(t => t.Value).Distinct().ToListAsync();
                tagHints = TagVocabulary.Seed.Concat(stored)
                    .Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(t => t).ToList();
            }

            var result = await Extractor.ExtractAsync(attachments, productNames, tagHints);
            if (!result.Success || result.Receipt is null)
            {
                pendingError = $"Still couldn't read it. ({result.Error})";
                return;
            }

            r.RawModelJson = result.RawModelJson;
            r.Merchant = result.Receipt.Merchant;
            r.PurchasedAt = result.Receipt.PurchaseDate;
            db.ReceiptLines.RemoveRange(r.Lines);
            r.Lines = MapLines(result.Receipt);
            await db.SaveChangesAsync();

            await LoadReviewAsync(r.Id); // straight into the normal review flow
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Retry of pending receipt {ReceiptId} failed.", receiptId);
            pendingError = "Retry failed — please try again, or discard the receipt.";
        }
        finally
        {
            retryingId = null;
        }
    }

    private static string MediaTypeFor(string path) => Path.GetExtension(path).ToLowerInvariant() switch
    {
        ".png" => "image/png",
        ".gif" => "image/gif",
        ".webp" => "image/webp",
        ".pdf" => "application/pdf",
        _ => "image/jpeg",
    };

    private const int MaxFiles = 20;

    private bool combineAsOne;

    private enum BatchStatus { Waiting, Reading, Done, Failed }

    private sealed class BatchItem
    {
        public required string FileName { get; init; }
        public BatchStatus Status { get; set; } = BatchStatus.Waiting;
        public string? Merchant { get; set; }
        public DateOnly? PurchasedAt { get; set; }
        public int LineCount { get; set; }
        public bool InQueue { get; set; } // a receipt row exists, so the pending list's Retry applies
    }

    private List<BatchItem> batch = [];

    private static string BatchIcon(BatchStatus s) => s switch
    {
        BatchStatus.Reading => "📖",
        BatchStatus.Done => "✅",
        BatchStatus.Failed => "⚠️",
        _ => "⏳",
    };

    private static string BatchNote(BatchItem b) => b.Status switch
    {
        BatchStatus.Waiting => "waiting…",
        BatchStatus.Reading => "reading…",
        BatchStatus.Done => $"{b.Merchant ?? "Unknown merchant"} · {(b.PurchasedAt is { } d ? d.ToString("MMM d, yyyy") : "no date")} · {b.LineCount} item{(b.LineCount == 1 ? "" : "s")} — in the review queue below",
        _ => b.InQueue
            ? "couldn't be read — retry it from the queue below"
            : "something went wrong reading this file — try selecting it again",
    };

    private void OnFilesSelected(InputFileChangeEventArgs e)
    {
        try
        {
            selectedFiles = e.GetMultipleFiles(MaxFiles).ToList();
        }
        catch (InvalidOperationException)
        {
            selectedFiles = [];
            errorMessage = $"Please select up to {MaxFiles} files at a time.";
            phase = Phase.Error;
            return;
        }
        batch = []; // a fresh selection supersedes the last batch's progress readout
        combineAsOne = false;
        errorMessage = null;
        if (phase == Phase.Error) phase = Phase.Idle;
    }

    // Several files are several receipts (the stack-of-paper-receipts case) unless the user said
    // they're pages of ONE long receipt. A single file keeps today's flow: straight into review.
    private Task Extract() => selectedFiles.Count > 1 && !combineAsOne ? ExtractBatchAsync() : ExtractCombinedAsync();

    private async Task ExtractCombinedAsync()
    {
        phase = Phase.Extracting;
        errorMessage = null;
        StateHasChanged();

        var folderName = NewReceiptFolderName();
        var folder = Path.Combine(Paths.ReceiptsDir, folderName);

        try
        {
            Directory.CreateDirectory(folder);
            var attachments = new List<ReceiptAttachment>();
            var index = 0;
            foreach (var file in selectedFiles)
            {
                var attachment = await ReadForExtractionAsync(file);
                attachments.Add(attachment);
                await File.WriteAllBytesAsync(Path.Combine(folder, $"page-{index++}.{ExtFor(attachment.MediaType)}"), attachment.Data);
            }

            // Load existing products first so the model can match lines against them (LLM-assisted matching).
            await LoadCatalogAsync();
            var result = await Extractor.ExtractAsync(attachments, products.Select(p => p.Name).Distinct().ToList(), allKnownTags);
            receipt = await PersistExtractionAsync(folderName, result);

            if (!result.Success || result.Receipt is null)
            {
                errorMessage = $"Sorry — that receipt couldn't be read. The image was kept for review. ({result.Error})";
                phase = Phase.Error;
                return;
            }

            // The stored lines carry everything review needs (tags + suggestion included), so the
            // fresh-extraction path and the auto-import queue share one pre-fill.
            await LoadReviewAsync(receipt.Id);
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Receipt extraction failed.");
            errorMessage = "Sorry — something went wrong while reading the receipt. Please try again.";
            phase = Phase.Error;
        }
        finally
        {
            selectedFiles = [];
            combineAsOne = false;
        }
    }

    // Each image is its OWN receipt, extracted one at a time so the user sees progress per receipt
    // rather than one long silence. Every read lands in the PendingReview queue below, exactly like
    // auto-imports — review each when the batch finishes. Failures are non-fatal: the audit copy and
    // raw model output are kept, and the row gets the usual Retry.
    private async Task ExtractBatchAsync()
    {
        phase = Phase.Extracting;
        errorMessage = null;
        batch = selectedFiles.Select(f => new BatchItem { FileName = f.Name }).ToList();
        StateHasChanged();

        try
        {
            await LoadCatalogAsync();
            var productNames = products.Select(p => p.Name).Distinct().ToList();

            for (var i = 0; i < selectedFiles.Count; i++)
            {
                var item = batch[i];
                item.Status = BatchStatus.Reading;
                StateHasChanged();
                try
                {
                    var folderName = NewReceiptFolderName();
                    Directory.CreateDirectory(Path.Combine(Paths.ReceiptsDir, folderName));
                    var attachment = await ReadForExtractionAsync(selectedFiles[i]);
                    await File.WriteAllBytesAsync(
                        Path.Combine(Paths.ReceiptsDir, folderName, $"page-0.{ExtFor(attachment.MediaType)}"), attachment.Data);

                    var result = await Extractor.ExtractAsync([attachment], productNames, allKnownTags);
                    var saved = await PersistExtractionAsync(folderName, result);
                    item.InQueue = true;

                    if (result.Success && result.Receipt is not null)
                    {
                        item.Status = BatchStatus.Done;
                        item.Merchant = saved.Merchant;
                        item.PurchasedAt = saved.PurchasedAt;
                        item.LineCount = saved.Lines.Count;
                    }
                    else
                    {
                        item.Status = BatchStatus.Failed;
                    }
                }
                catch (OperationCanceledException) { throw; }
                catch (Exception ex)
                {
                    // One bad file must not sink the rest of the stack — mark it and keep going.
                    Logger.LogError(ex, "Batch extraction failed for {FileName}.", item.FileName);
                    item.Status = BatchStatus.Failed;
                }
                StateHasChanged();
            }
        }
        finally
        {
            selectedFiles = [];
            await LoadPendingAsync(); // the batch just filled the review queue
            phase = Phase.Idle;
        }
    }

    /// <summary>Persist ANY extraction outcome as a PendingReview receipt — a successful read keeps its
    /// lines; a failed one keeps the audit copy + raw model output so the queue's Retry can re-extract.</summary>
    private async Task<Receipt> PersistExtractionAsync(string folderName, ExtractionResult result)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var r = new Receipt
        {
            ImagePath = Path.Combine("receipts", folderName),
            RawModelJson = result.RawModelJson,
            Status = ReceiptStatus.PendingReview,
        };
        if (result.Success && result.Receipt is not null)
        {
            r.Merchant = result.Receipt.Merchant;
            r.PurchasedAt = result.Receipt.PurchaseDate;
            r.Lines = MapLines(result.Receipt);
        }
        db.Receipts.Add(r);
        await db.SaveChangesAsync();
        return r;
    }

    private static List<ReceiptLine> MapLines(ExtractedReceipt extracted) => extracted.Lines.Select(l => new ReceiptLine
    {
        RawText = l.RawText,
        NormalizedName = l.NormalizedName,
        Brand = l.Brand,
        Size = l.Size,
        Quantity = l.Quantity,
        UnitPrice = l.UnitPrice,
        Category = l.Category,
        Confidence = l.Confidence,
        TagsJson = ReceiptConfirmationService.SerializeTags(l.Tags),
        SuggestedProduct = l.SuggestedProductName,
    }).ToList();

    // Products + tag vocabulary for LLM-assisted matching and tag reuse during extraction.
    private async Task LoadCatalogAsync()
    {
        await using var pdb = await DbFactory.CreateDbContextAsync();
        products = await pdb.Products.OrderBy(p => p.Name).ToListAsync();
        var stored = await pdb.ProductTags.Select(t => t.Value).Distinct().ToListAsync();
        allKnownTags = TagVocabulary.Seed.Concat(stored)
            .Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(t => t).ToList();
    }

    private static string NewReceiptFolderName() => $"{DateTime.UtcNow:yyyyMMdd-HHmmss}-{Guid.NewGuid():N}"[..40];

    // Browser-side resize for images (longest edge capped per Llm:MaxImageEdgePx, DESIGN.md §5);
    // PDFs pass through as-is.
    private async Task<ReceiptAttachment> ReadForExtractionAsync(IBrowserFile file)
    {
        if (file.ContentType == "application/pdf")
            return new ReceiptAttachment(await ReadAllAsync(file.OpenReadStream(MaxUploadBytes)), "application/pdf");
        var maxEdge = LlmOptions.Value.MaxImageEdgePx;
        var resized = await file.RequestImageFileAsync("image/jpeg", maxEdge, maxEdge);
        return new ReceiptAttachment(await ReadAllAsync(resized.OpenReadStream(MaxUploadBytes)), "image/jpeg");
    }

    private static string ExtFor(string mediaType) => mediaType == "application/pdf" ? "pdf" : "jpg";

    // Persistence lives in ReceiptConfirmationService — the ONE confirm path shared with the
    // auto-importer. The service is idempotent (an already-confirmed receipt is a no-op) and the
    // `confirming` flag keeps a double-click from even reaching it.
    private async Task ConfirmAll()
    {
        if (receipt is null || confirming) return;
        confirming = true;
        confirmError = null;
        try
        {
            var lines = reviewLines.Select(l => new ReceiptConfirmationService.ConfirmLine(
                l.RawText, l.NormalizedName, l.Brand, l.Size, l.Quantity, l.Category, l.Tags, l.ProductId)).ToList();
            // Use the user-confirmed receipt date (not the upload date) so refill intervals are accurate
            // even when many receipts are uploaded in one sitting. writeAliases: a human reviewed these
            // pairings, so they're allowed to become sticky merchant aliases.
            var outcome = await Confirmer.ConfirmAsync(receipt.Id, reviewDate, lines, writeAliases: true,
                verifiedForEval: verifiedForEval);

            var merchant = receipt.Merchant ?? "";
            confirmSummary = outcome.AlreadyConfirmed
                ? "These purchases were already recorded."
                : $"Recorded {outcome.Purchases} purchases" +
                  (outcome.NewProducts > 0 ? $" ({outcome.NewProducts} new product{(outcome.NewProducts == 1 ? "" : "s")})" : "") +
                  $" from {(merchant.Length > 0 ? merchant : "unknown merchant")} on {reviewDate:yyyy-MM-dd}." +
                  (outcome.Retracked > 0 ? $" Started tracking {outcome.Retracked} previously ignored item{(outcome.Retracked == 1 ? "" : "s")} again." : "");
            await LoadPendingAsync(); // a queued receipt just left the pending list
            phase = Phase.Done;
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex)
        {
            // One SaveChanges in a single transaction, so a failure persists nothing: keep the receipt in
            // review so the user can adjust a line and retry instead of losing the extraction to a crash.
            Logger.LogError(ex, "Confirming receipt {ReceiptId} failed.", receipt.Id);
            confirmError = "Couldn't save these purchases — nothing was recorded. Adjust a line and try again, or discard the receipt.";
        }
        finally
        {
            confirming = false;
        }
    }

    // Two-stage tag dedup so the cloud doesn't fragment: cheap plain-code near-duplicate first, then an
    // LLM synonym check only when that finds nothing. Either way the user can override and add it anyway.
    private async Task AddTag(ReviewLine line)
    {
        line.Suggestion = null;
        line.PendingTag = null;
        var tag = (line.NewTag ?? "").Trim();
        if (tag.Length == 0) return;
        if (line.Tags.Any(t => string.Equals(t, tag, StringComparison.OrdinalIgnoreCase))) { line.NewTag = ""; return; }

        var universe = allKnownTags.Concat(line.Tags).Distinct(StringComparer.OrdinalIgnoreCase).ToList();

        // Picked an existing tag verbatim → just add its canonical form, no dedup needed.
        var exact = universe.FirstOrDefault(t => string.Equals(t, tag, StringComparison.OrdinalIgnoreCase));
        if (exact is not null) { AddNewTag(line, exact); return; }

        // Stage 1: instant plain-code near-duplicate (casing / plural / typo).
        if (TagVocabulary.FindNearDuplicate(tag, universe) is { } near)
        {
            line.PendingTag = tag;
            line.Suggestion = near;
            return;
        }

        // Stage 2: LLM synonym check (Soda ≈ Soft Drink) — only when the cheap check is clean.
        line.Checking = true;
        try
        {
            if (await Advisor.FindSynonymAsync(tag, universe) is { } synonym)
            {
                line.PendingTag = tag;
                line.Suggestion = synonym;
                return;
            }
        }
        finally
        {
            line.Checking = false;
        }

        AddNewTag(line, tag); // genuinely new
    }

    private void UseSuggestion(ReviewLine line)
    {
        if (line.Suggestion is { } s) AddNewTag(line, s);
        line.Suggestion = null;
        line.PendingTag = null;
    }

    private void AddAnyway(ReviewLine line)
    {
        if (line.PendingTag is { } t) AddNewTag(line, t);
        line.Suggestion = null;
        line.PendingTag = null;
    }

    private void AddNewTag(ReviewLine line, string tag)
    {
        if (!line.Tags.Any(t => string.Equals(t, tag, StringComparison.OrdinalIgnoreCase))) line.Tags.Add(tag);
        if (!allKnownTags.Any(t => string.Equals(t, tag, StringComparison.OrdinalIgnoreCase))) allKnownTags.Add(tag);
        line.NewTag = "";
    }

    private async Task Discard()
    {
        if (receipt is not null)
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var dbReceipt = await db.Receipts.FirstAsync(r => r.Id == receipt.Id);
            dbReceipt.Status = ReceiptStatus.Discarded;
            await db.SaveChangesAsync();
        }
        await LoadPendingAsync();
        Reset();
    }

    private void Reset()
    {
        phase = Phase.Idle;
        receipt = null;
        reviewLines = [];
        selectedFiles = [];
        batch = [];
        combineAsOne = false;
        errorMessage = null;
        confirmError = null;
    }

    private static async Task<byte[]> ReadAllAsync(Stream stream)
    {
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        return ms.ToArray();
    }
}
