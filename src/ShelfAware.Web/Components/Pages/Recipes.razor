@page "/recipes"
@implements IDisposable
@using System.Text.Json
@using ShelfAware.Core.Chat
@using ShelfAware.Core.Prediction
@using ShelfAware.Core.Recipes
@using ShelfAware.Core.Settings
@inject IHouseholdDbFactory DbFactory
@inject IPantryStore Store
@inject IAppSettings Settings
@inject IRecipeAdvisor Advisor
@inject IRecipeAdapter Adapter
@inject IIngredientAlternativesAdvisor AltAdvisor
@inject ShelfAware.Core.Speech.IVoiceCredentials Voice
@inject VoiceCoordinator Coordinator
@inject NavigationManager Nav
@inject ILogger<Recipes> Logger

<PageTitle>Recipes — Shelf Aware</PageTitle>

<div class="page-head">
    <h1>Recipes</h1>
</div>

<p class="recipe-disclaimer" role="note">
    ⚠️ Ideas only — <strong>always check ingredient labels yourself</strong>. This is not allergy-safe or
    medical advice; the “won’t eat” list is a best-effort filter, not a guarantee.
</p>

<section class="panel">
    <h2>Foods I won’t eat</h2>
    <p class="muted">Allergies or dislikes — recipes will avoid these. Applies to every suggestion.</p>
    <div class="tag-list">
        @foreach (var f in excludedFoods)
        {
            <span class="tag-chip">@f.Value<button type="button" class="tag-x" @onclick="() => RemoveExcluded(f)" aria-label="Remove @f.Value">×</button></span>
        }
        @if (excludedFoods.Count == 0)
        {
            <span class="muted">Nothing excluded yet.</span>
        }
    </div>
    <div class="tag-add">
        <input placeholder="e.g. mushrooms" @bind="newExcluded" @bind:event="oninput"
               aria-label="Add a food you won't eat" />
        <button type="button" @onclick="AddExcluded" disabled="@string.IsNullOrWhiteSpace(newExcluded)">Add</button>
    </div>
</section>

<section class="panel">
    <h2>What can I make?</h2>
    <form @onsubmit="Suggest" @formname="recipe-request">
        <input @bind="request" @bind:event="oninput" placeholder="e.g. I'm feeling Mediterranean tonight"
               aria-label="Describe what you're in the mood for" disabled="@suggesting" />
        <button type="submit" disabled="@(suggesting || string.IsNullOrWhiteSpace(request))">
            @(suggesting ? "Thinking…" : "Get ideas")
        </button>
    </form>
    @if (suggestError is not null)
    {
        <p class="error">@suggestError</p>
    }

    @if (suggestions.Count > 0)
    {
        <div class="suggestions-head">
            <p class="muted small">
                Ideas for &ldquo;@suggestedFor&rdquo; — @suggestedAt.ToString("MMM d")
                <span class="muted"> · kept until you clear or get new ideas</span>
            </p>
            <button type="button" class="secondary" @onclick="ClearSuggestions" aria-label="Clear these recipe ideas">Clear ideas</button>
        </div>
        <div class="recipe-suggestions">
            @foreach (var s in suggestions)
            {
                <article class="recipe-card">
                    <div class="recipe-card-top">
                        <h3>@s.Name</h3>
                        <button class="secondary" @onclick="() => Save(s)" disabled="@savedNames.Contains(s.Name)">
                            @(savedNames.Contains(s.Name) ? "Saved ✓" : "Save")
                        </button>
                    </div>
                    <p class="muted">@s.Blurb</p>
                    @if (s.CaloriesPerServing is { } cal)
                    {
                        <p class="recipe-cal">~@cal cal / serving <span class="muted">(est.)</span></p>
                    }
                    <ul class="ingredient-list">
                        @foreach (var i in s.Ingredients.Where(i => i.IsMain))
                        {
                            var haveIt = HaveSuggested(i);
                            <li class="@(haveIt ? "have" : "grab")">
                                @(haveIt ? "✓" : "🛒") @Qty(i.Quantity, i.Name)
                                @if (!haveIt && MaybeHave(i.Name, i.MatchedProduct) is { } outItem)
                                {
                                    @if (outItem.Untracked)
                                    {
                                        <span class="maybe-have">you have this as <strong>@outItem.Name</strong>, but it's untracked</span>
                                        <button type="button" class="restock-btn" @onclick="() => TrackIt(outItem.Id)"
                                                disabled="@restockBusy"
                                                title="Track @outItem.Name again so recipes and the grocery list can see it"
                                                aria-label="Track @outItem.Name again">Track it</button>
                                    }
                                    else
                                    {
                                        <span class="maybe-have">you may still have <strong>@outItem.Name</strong> — it just looks run-out</span>
                                        <button type="button" class="restock-btn" @onclick="() => Restocked(outItem.Id)"
                                                disabled="@restockBusy"
                                                title="Still have @outItem.Name at home — clears the run-out and this goes green"
                                                aria-label="Mark @outItem.Name restocked — you still have it">Restocked</button>
                                    }
                                }
                            </li>
                        }
                        @{ var seasonings = s.Ingredients.Where(i => !i.IsMain).Select(i => i.Name).ToList(); }
                        @if (seasonings.Count > 0)
                        {
                            <li class="muted">+ @string.Join(", ", seasonings)</li>
                        }
                    </ul>
                    @{ var grab = s.Ingredients.Where(i => i.IsMain && !HaveSuggested(i)).ToList(); }
                    @if (grab.Count > 0)
                    {
                        <p class="recipe-grab">Grab: <strong>@string.Join(", ", grab.Select(g => g.Name))</strong></p>
                    }
                    else
                    {
                        <p class="recipe-grab all-good">You’ve got everything for this. 🎉</p>
                    }
                    @if (s.Steps.Count > 0)
                    {
                        <details class="recipe-steps">
                            <summary>Steps (@s.Steps.Count)</summary>
                            <ol>
                                @foreach (var step in s.Steps)
                                {
                                    <li>@step</li>
                                }
                            </ol>
                        </details>
                    }
                </article>
            }
        </div>
    }
</section>

<section class="panel">
    <div class="page-head">
        <h2>Saved recipes <span class="muted">— @displayed.Count</span></h2>
        @if (PickPool.Count > 0)
        {
            <button @onclick="PickForMe">🎲 Pick for me</button>
        }
    </div>
    @if (filterProductName is not null)
    {
        <p class="filter-banner" role="status">Showing recipes that use <strong>@filterProductName</strong> — <a href="/recipes">show all</a></p>
    }
    @if (readingRecipe is not null)
    {
        <RecipeReadAloud Recipe="readingRecipe" @key="readingRecipe.Id" OnClosed="StopReading" />
    }
    @if (cookingRecipe is not null)
    {
        <CookAlong Recipe="cookingRecipe" @key="cookingRecipe.Id" OnClosed="StopCooking" OnUnavailable="HandleCookUnavailable" />
    }
    @if (picked is not null)
    {
        <p class="picked-banner">Tonight: <strong>@picked.Name</strong>@(picked.Blurb is { Length: > 0 } pb ? $" — {pb}" : "")</p>
    }
    @if (extraNote is not null)
    {
        <p class="chat-reply" role="status">@extraNote</p>
    }
    @if (adaptNote is not null)
    {
        <p class="chat-reply" role="status">@adaptNote</p>
    }
    @if (displayed.Count == 0)
    {
        <p class="muted">
            @(filterProductName is null
                ? "None yet — get some ideas above and hit Save on the ones you like."
                : $"No saved recipes use {filterProductName} yet.")
        </p>
    }
    else
    {
        <ul class="saved-recipes">
            @foreach (var (r, kind) in renderList)
            {
                if (kind == RowKind.ParentReference)
                {
                    <li id="recipe-@r.Id" class="recipe-reference">
                        <div class="saved-top">
                            <strong>@r.Name</strong>
                            <span class="chip variant-chip" title="Original recipe — the adapted version that uses this item is below">for reference</span>
                        </div>
                        <p class="muted small">You’ve adapted this to use what you have — the matching version is below.</p>
                    </li>
                    continue;
                }
                var isVariant = kind == RowKind.Variant;
                var makeable = Makeable(r);
                <li id="recipe-@r.Id" class="@(isVariant ? "recipe-variant" : null)">
                    <div class="saved-top">
                        <strong>@r.Name</strong>
                        <span class="chip chip-@(makeable ? "stocked" : "unknown")">@(makeable ? "Ready to make" : "Missing items")</span>
                        @if (isVariant)
                        {
                            <span class="chip variant-chip" title="Adapted to use what you have">🔀 adapted</span>
                        }
                        <span class="saved-actions">
                            @if (r.Steps.Count > 0)
                            {
                                @if (CookAlongAvailable)
                                {
                                    <SplitButton PrimaryLabel="🎙 Cook-along" MainClass="secondary" OnPrimary="() => StartCooking(r)"
                                                 PrimaryAriaLabel="@($"Hands-free cook-along for {r.Name}")">
                                        <button class="secondary" @onclick="() => StartReading(r)" aria-label="Read @r.Name aloud">🔊 Read it to me</button>
                                    </SplitButton>
                                }
                                else
                                {
                                    <button class="secondary" @onclick="() => StartReading(r)" aria-label="Read @r.Name aloud">🔊 Read it to me</button>
                                }
                            }
                            <button class="secondary" @onclick="() => MarkEaten(r)" aria-label="Mark @r.Name eaten">Ate it</button>
                            @if (!makeable)
                            {
                                <button class="secondary" @onclick="() => AddMissingToList(r)" aria-label="Add missing ingredients for @r.Name to the grocery list">Add missing to list</button>
                            }
                            <button class="secondary" @onclick="() => AdaptRecipe(r)" disabled="@(adaptingId == r.Id)"
                                    aria-label="Adapt @r.Name to use what you have">@(adaptingId == r.Id ? "Adapting…" : "🔀 Adapt to what I have")</button>
                            <button class="icon-btn" @onclick="() => DeleteSaved(r)" aria-label="Delete @r.Name" title="Delete @r.Name"><span aria-hidden="true">🗑</span></button>
                        </span>
                    </div>
                    @if (r.Blurb is { Length: > 0 })
                    {
                        <p class="muted">@r.Blurb</p>
                    }
                    @if (r.EstimatedCaloriesPerServing is { } cal)
                    {
                        <p class="recipe-cal">~@cal cal / serving <span class="muted">(est.)</span></p>
                    }
                    <ul class="ingredient-list">
                        @foreach (var i in r.MainIngredients)
                        {
                            var have = Have(i);
                            <li class="@(have ? "have" : "grab")">
                                <span class="ingredient-name">@(have ? "✓" : "🛒") @Qty(i.Quantity, i.Name)</span>
                                <button type="button" class="alt-swap" @onclick="() => ToggleAlternatives(i)"
                                        aria-label="Swap @i.Name for something else" title="Swap this ingredient">⇄</button>
                                @if (!have && MaybeHave(i.Name, i.MatchedProduct) is { } outItem)
                                {
                                    @if (outItem.Untracked)
                                    {
                                        <span class="maybe-have">you have this as <strong>@outItem.Name</strong>, but it's untracked</span>
                                        <button type="button" class="restock-btn" @onclick="() => TrackIt(outItem.Id)"
                                                disabled="@restockBusy"
                                                title="Track @outItem.Name again so recipes and the grocery list can see it"
                                                aria-label="Track @outItem.Name again">Track it</button>
                                    }
                                    else
                                    {
                                        <span class="maybe-have">you may still have <strong>@outItem.Name</strong> — it just looks run-out</span>
                                        <button type="button" class="restock-btn" @onclick="() => Restocked(outItem.Id)"
                                                disabled="@restockBusy"
                                                title="Still have @outItem.Name at home — clears the run-out and this goes green"
                                                aria-label="Mark @outItem.Name restocked — you still have it">Restocked</button>
                                    }
                                }
                                @if (openAltFor == i.Id)
                                {
                                    var cloud = CloudFor(i);
                                    <div class="alt-cloud" role="group" aria-label="Swap @i.Name">
                                        @if (generatingAltFor == i.Id)
                                        {
                                            <span class="muted small">Finding swaps…</span>
                                        }
                                        else if (cloud.Count == 0)
                                        {
                                            <span class="muted small">No good swaps for this one.</span>
                                        }
                                        else
                                        {
                                            @foreach (var alt in cloud)
                                            {
                                                var altHave = HaveForm(alt);
                                                <button type="button" class="alt-bubble @(altHave ? "have" : "grab")"
                                                        disabled="@(adaptingId == r.Id)"
                                                        @onclick="() => AdaptToChoice(r, i, alt)"
                                                        title="Make a version with @alt">@(altHave ? "✓" : "🛒") @alt</button>
                                            }
                                        }
                                    </div>
                                }
                            </li>
                        }
                        @{ var extras = r.Seasonings.Select(i => i.Name).ToList(); }
                        @if (extras.Count > 0)
                        {
                            <li class="muted">+ @string.Join(", ", extras)</li>
                        }
                    </ul>
                    @if (r.TimesEaten > 0)
                    {
                        <p class="muted small">eaten @r.TimesEaten×</p>
                    }
                    @if (r.Steps.Count > 0)
                    {
                        <details class="recipe-steps">
                            <summary>Steps (@r.Steps.Count)</summary>
                            <ol>
                                @foreach (var step in r.Steps.OrderBy(s => s.Order))
                                {
                                    <li>@step.Text</li>
                                }
                            </ol>
                        </details>
                    }
                </li>
            }
        </ul>
    }
</section>

@code {
    private List<ExcludedFood> excludedFoods = [];
    private string newExcluded = "";

    private string request = "";
    private bool suggesting;
    private string? suggestError;
    private List<RecipeSuggestion> suggestions = [];
    // What the current batch was generated for and when — shown above the cards, persisted with them.
    private string suggestedFor = "";
    private DateTimeOffset suggestedAt;

    /// <summary>The persisted shape of a "Get ideas" batch (SettingKeys.LastRecipeSuggestions): an AI
    /// call's results are too expensive to evaporate on navigation or a server restart, so the latest
    /// batch is kept per household until replaced or cleared. Have/grab marks are NOT stored — they
    /// recompute live against the current pantry on every render, so an old batch stays truthful.</summary>
    private sealed record SuggestionSnapshot(string Request, DateTimeOffset GeneratedAt, List<RecipeSuggestion> Suggestions);

    private List<Recipe> savedRecipes = [];
    private HashSet<string> savedNames = new(StringComparer.OrdinalIgnoreCase);

    // The originals actually rendered — all of them, or just those using a product when ?uses is set.
    private List<Recipe> displayed = [];
    // Flattened for rendering: originals and their adapted variants, grouped. Under a ?uses filter a
    // variant can match on its own ingredients while its original doesn't (Adapt swaps the main), so a
    // non-matching original may appear as a ParentReference — shown for context only, not as a result.
    private enum RowKind { Original, Variant, ParentReference }
    private List<(Recipe Recipe, RowKind Kind)> renderList = [];
    private Dictionary<int, string> productNamesById = [];
    private string? filterProductName;
    private int? adaptingId;      // the recipe currently being adapted (button shows a spinner)
    private string? adaptNote;    // result of the last Adapt
    private int? openAltFor;      // RecipeIngredient.Id whose swap bubble-cloud is open (one at a time)
    private int? generatingAltFor; // RecipeIngredient.Id whose alternates are being generated

    private List<PantryProduct> onHand = [];
    // Every tracked edible product with its curated substitutes — the swap clouds draw stand-ins from
    // the whole matrix, including out-of-stock items (they render as "grab" bubbles).
    private List<PantryProduct> cloudProducts = [];
    // Tracked edible products the engine thinks you've RUN OUT of — the exact items the on-hand list
    // silently drops. Surfaced on red ingredient rows so "why is this red?" answers itself, with a
    // one-tap Restocked to correct the engine when the shelf disagrees.
    private List<(int Id, PantryProduct Product)> outOfStock = [];
    // Edible products the user UNTRACKED — the third way a red row can lie ("I own that!"). Surfaced
    // with a one-tap Track-it; used for the hint only, never for on-hand or the swap clouds.
    private List<(int Id, PantryProduct Product)> untrackedEdible = [];
    private bool restockBusy;

    private Recipe? picked;
    private string? extraNote;
    private Recipe? readingRecipe;
    private Recipe? cookingRecipe;
    private bool cookAutoStarted; // this cook-along was opened by the voice chain (so we may fall back)
    private readonly Random rng = new();

    /// <summary>Deep link from the chat's read_recipe tool (/recipes?read={id}) — auto-starts a hands-free
    /// read of the recipe: the listening cook-along agent when it's configured (so the whole voice chain,
    /// including leaving by voice, stays hands-free), else the button-controlled read-aloud.</summary>
    [SupplyParameterFromQuery(Name = "read")] public int? ReadId { get; set; }

    /// <summary>Deep link from open_page(page="recipes", product_name) (/recipes?uses={id}) — scopes the
    /// saved list to recipes that use that product, the middle step of the hands-free navigation chain.</summary>
    [SupplyParameterFromQuery(Name = "uses")] public int? UsesProductId { get; set; }

    // Hands-free cook-along only shows when the visitor has set an ElevenLabs agent id (per circuit; empty = hidden).
    private bool CookAlongAvailable => !string.IsNullOrEmpty(Voice.AgentId);

    // Adapt a recipe to what's on hand and save it as a variant (on-demand — one AI call per click).
    private async Task AdaptRecipe(Recipe r)
    {
        if (adaptingId is not null) return;
        adaptingId = r.Id;
        adaptNote = null;
        try
        {
            var result = await Adapter.AdaptToOnHandAsync(r.Id);
            adaptNote = result.Message;
            await LoadAsync(); // pull in the new variant
        }
        finally
        {
            adaptingId = null;
        }
    }

    // Open/close an ingredient's swap bubble-cloud. On first open, generate its alternate forms once and
    // cache them on the ingredient (AlternativesJson) so re-opening costs no AI call.
    private async Task ToggleAlternatives(RecipeIngredient i)
    {
        if (openAltFor == i.Id) { openAltFor = null; return; }
        openAltFor = i.Id;
        if (!string.IsNullOrEmpty(i.AlternativesJson)) return;

        generatingAltFor = i.Id;
        try
        {
            var alts = await AltAdvisor.SuggestAsync(i.Name);
            var json = JsonSerializer.Serialize(alts);
            await using var db = await DbFactory.CreateDbContextAsync();
            if (await db.RecipeIngredients.FindAsync(i.Id) is { } row)
            {
                row.AlternativesJson = json;
                await db.SaveChangesAsync();
            }
            i.AlternativesJson = json; // reflect immediately without a full reload
        }
        finally
        {
            generatingAltFor = null;
        }
    }

    private static List<string> AlternativesOf(RecipeIngredient i) =>
        string.IsNullOrEmpty(i.AlternativesJson) ? [] : JsonSerializer.Deserialize<List<string>>(i.AlternativesJson) ?? [];

    // The cloud shows the user's own stand-in products (their curated "also works as" matrix) first,
    // then the AI-generated generic forms that aren't already represented by one.
    private List<string> CloudFor(RecipeIngredient i) =>
        SwapCloud.Merge(SwapCloud.CuratedStandIns(i.Name, cloudProducts), AlternativesOf(i));

    // Green when an on-hand product covers this alternate form (same matcher the ingredients use).
    private bool HaveForm(string form) => IngredientMatcher.IsSatisfied(form, null, onHand);

    // Picking a bubble adapts the recipe to that specific form for this ingredient, saved as a variant.
    private async Task AdaptToChoice(Recipe r, RecipeIngredient i, string form)
    {
        if (adaptingId is not null) return;
        adaptingId = r.Id;
        adaptNote = null;
        try
        {
            var result = await Adapter.AdaptToOnHandAsync(r.Id, new IngredientSwap(i.Name, form));
            adaptNote = result.Message;
            openAltFor = null;
            await LoadAsync();
        }
        finally
        {
            adaptingId = null;
        }
    }

    // Only one voice surface at a time — starting one closes the other. cookAutoStarted resets on any
    // manual start; the deep-link path sets it true afterwards so only that case auto-falls-back.
    private void StartReading(Recipe r) { cookAutoStarted = false; cookingRecipe = null; readingRecipe = r; }
    private void StopReading() => readingRecipe = null;
    private void StartCooking(Recipe r) { cookAutoStarted = false; readingRecipe = null; cookingRecipe = r; }
    private void StopCooking() => cookingRecipe = null;

    // The voice chain's auto-started cook-along couldn't connect (e.g. bad wifi). Fall back to the plain
    // reader so the recipe still gets read instead of dead-ending on an error the user can't tap away.
    private void HandleCookUnavailable()
    {
        if (cookAutoStarted && cookingRecipe is { } r) StartReading(r);
    }

    // A saved recipe is makeable when every MAIN ingredient is covered by something on hand — by food
    // family, not exact product name, so a recipe calling for chicken breast counts when you have chicken
    // tenderloins or any chicken (IngredientMatcher). Seasonings/staples are ignored.
    private bool Makeable(Recipe r) => r.IsMakeableWith(onHand);

    private bool Have(RecipeIngredient i) => i.IsSatisfiedBy(onHand);

    // Pre-save cards: the model's grounding is trusted only when POSITIVE — it misses spelling gaps a
    // human wouldn't ("lean ground beef" vs "93% Lean Ground Beef"), so a null matched_product falls
    // back to the same plain-code matcher the saved list uses. The two views can never disagree.
    private bool HaveSuggested(SuggestedIngredient i) =>
        i.Have || IngredientMatcher.IsSatisfied(i.Name, null, onHand);

    // The first product that would cover this ingredient but is invisible to on-hand — predicted
    // run-out (tracked), or untracked entirely — so a red mark can explain itself. Null = a genuine
    // gap. Run-out is checked first: for a tracked item that's the precise story, and the untracked
    // pool only matters when nothing the engine watches would cover the row.
    private (int Id, string Name, bool Untracked)? MaybeHave(string ingredientName, string? matchedProduct)
    {
        foreach (var (id, product) in outOfStock)
        {
            if (IngredientMatcher.IsSatisfied(ingredientName, matchedProduct, [product]))
                return (id, product.Name, false);
        }
        foreach (var (id, product) in untrackedEdible)
        {
            if (IngredientMatcher.IsSatisfied(ingredientName, matchedProduct, [product]))
                return (id, product.Name, true);
        }
        return null;
    }

    // Same status-only write as the dashboard/grocery-list Restocked (§6 two-stream model: it clears
    // the run-out and re-anchors the due date, never feeds the cadence). Reload flips the row green.
    private async Task Restocked(int productId)
    {
        if (restockBusy) return;
        restockBusy = true;
        try
        {
            await Store.RecordSignalAsync(productId, SignalKind.Restocked);
            await LoadAsync();
        }
        finally { restockBusy = false; }
    }

    // One tap to let the engine watch a product again (the same write as the Products-grid checkbox and
    // the set_tracking chat tool). The reload recomputes the row honestly: green if the item's in stock,
    // the run-out hint if its history says it ran dry — exactly what tracking it re-enables.
    private async Task TrackIt(int productId)
    {
        if (restockBusy) return;
        restockBusy = true;
        try
        {
            await Store.SetTrackingAsync(productId, tracked: true);
            await LoadAsync();
        }
        finally { restockBusy = false; }
    }

    // "2 lbs chicken breast" when the recipe gives a quantity, else just the name.
    private static string Qty(string? quantity, string name) =>
        string.IsNullOrWhiteSpace(quantity) ? name : $"{quantity} {name}";

    // "Pick for me" pool: saved recipes you've eaten before AND can make right now — the reliable
    // "I can definitely eat this, just tell me" set.
    private List<Recipe> PickPool => savedRecipes.Where(r => r.TimesEaten > 0 && Makeable(r)).ToList();

    private void PickForMe()
    {
        var pool = PickPool;
        picked = pool.Count > 0 ? pool[rng.Next(pool.Count)] : null;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        await RestoreSuggestionsAsync();
    }

    // Bring back the household's last "Get ideas" batch so the page reopens where it left off.
    // A snapshot that no longer parses (shape changed between builds) is discarded, not fatal.
    private async Task RestoreSuggestionsAsync()
    {
        var json = await Settings.GetAsync(SettingKeys.LastRecipeSuggestions);
        if (string.IsNullOrEmpty(json)) return;
        try
        {
            if (JsonSerializer.Deserialize<SuggestionSnapshot>(json) is { Suggestions.Count: > 0 } snapshot)
            {
                suggestions = snapshot.Suggestions;
                suggestedFor = snapshot.Request;
                suggestedAt = snapshot.GeneratedAt;
            }
        }
        catch (JsonException ex)
        {
            Logger.LogWarning(ex, "Stored recipe suggestions no longer parse — discarding the snapshot.");
            await Settings.SetAsync(SettingKeys.LastRecipeSuggestions, null);
        }
    }

    // Re-derive the ?uses filter and consume any ?read command whenever the query changes. This runs
    // after OnInitializedAsync has loaded the data AND on every later query-only navigation — the
    // read_recipe deep link usually arrives as the latter: the voice chain is often already ON /recipes
    // ("recipes that use chicken" → "read the second one"), and a same-component navigation never
    // re-runs OnInitializedAsync, which is where this handling used to live (the auto-start silently
    // never fired).
    protected override void OnParametersSet()
    {
        ApplyFilter();
        ConsumeReadDeepLink();
    }

    /// <summary>Deep link from the chat's read_recipe tool (/recipes?read={id}) — auto-starts a hands-free
    /// read: the listening cook-along agent when it's configured (voice "next"/"back"/"stop"/"go to the
    /// assistant", so the whole chain stays hands-free), else the button-controlled read-aloud (also the
    /// later fallback if cook-along can't connect — HandleCookUnavailable). ?read is a one-shot command,
    /// not view state, so it's stripped from the URL once consumed: a repeat of the same request still
    /// changes the query (null → id), and a refresh doesn't surprise-relaunch a mic session. Interactive
    /// only — during prerender there's no circuit to run a voice surface on, and navigating would turn
    /// into a redirect that eats the parameter before the interactive run could see it.</summary>
    private void ConsumeReadDeepLink()
    {
        if (!RendererInfo.IsInteractive || ReadId is not { } id) return;
        if (savedRecipes.FirstOrDefault(r => r.Id == id) is { Steps.Count: > 0 } target)
        {
            if (CookAlongAvailable) { StartCooking(target); cookAutoStarted = true; }
            else StartReading(target);
        }
        Nav.NavigateTo(UsesProductId is { } u ? $"/recipes?uses={u}" : "/recipes", replace: true);
    }

    private void ApplyFilter()
    {
        filterProductName = UsesProductId is { } pid && productNamesById.TryGetValue(pid, out var n) ? n : null;
        var topLevel = savedRecipes.Where(r => !r.IsVariant);

        if (filterProductName is not { } name)
        {
            // No filter: every original followed by all its adapted variants (most recent first).
            displayed = topLevel.ToList();
            renderList = displayed
                .SelectMany(p => new[] { (p, RowKind.Original) }
                    .Concat(VariantsOf(p).Select(v => (v, RowKind.Variant))))
                .ToList();
            PublishScreenContext();
            return;
        }

        // Filtered to a product: a recipe "uses" it when an ingredient is grounded to that product. Match
        // each ADAPTED VARIANT on its OWN ingredients — Adapt swaps the main, so a variant usually uses a
        // product its original never did. Only recipes that actually use the product are results; a
        // non-matching original rides along solely as a muted reference so its matching variant isn't
        // orphaned.
        bool Uses(Recipe r) => r.Ingredients.Any(i => string.Equals(i.MatchedProduct, name, StringComparison.OrdinalIgnoreCase));

        var rows = new List<(Recipe Recipe, RowKind Kind)>();
        var results = new List<Recipe>();
        foreach (var p in topLevel)
        {
            var matchingVariants = VariantsOf(p).Where(Uses).ToList();
            if (Uses(p))
            {
                rows.Add((p, RowKind.Original));
                results.Add(p);
            }
            else if (matchingVariants.Count > 0)
            {
                rows.Add((p, RowKind.ParentReference)); // context only — this original doesn't use the product
            }
            else
            {
                continue; // neither the original nor any variant uses the product
            }
            foreach (var v in matchingVariants)
            {
                rows.Add((v, RowKind.Variant));
                results.Add(v);
            }
        }
        displayed = results;
        renderList = rows;
        PublishScreenContext();
    }

    // A recipe's adapted variants, most recent first.
    private IEnumerable<Recipe> VariantsOf(Recipe original) =>
        savedRecipes.Where(v => v.IsVariantOf(original)).OrderByDescending(v => v.SavedAt);

    // Tell the roaming voice agent what's on screen and in what order, so "read me the second one"
    // resolves to the right recipe. Cleared on navigate-away so it can't leak to another page.
    private void PublishScreenContext()
    {
        // Reference-only rows are context, not results — keep them out of the positional list the voice
        // agent uses for "read me the second one".
        var listed = renderList.Where(x => x.Kind != RowKind.ParentReference).Select(x => x.Recipe).ToList();
        Coordinator.ScreenContext = listed.Count == 0
            ? null
            : (filterProductName is { } fn ? $"The user is viewing recipes that use {fn}. " : "The user is viewing the Recipes page. ")
              + "Recipes listed, in display order:\n"
              + string.Join("\n", listed.Select((r, i) => $"{i + 1}. {r.Name}"));
    }

    public void Dispose() => Coordinator.ScreenContext = null;

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        excludedFoods = await db.ExcludedFoods.OrderBy(f => f.Value).ToListAsync();
        // SQLite can't ORDER BY a DateTimeOffset column — sort client-side.
        savedRecipes = (await db.Recipes.AsNoTracking().Include(r => r.Ingredients).Include(r => r.Steps).ToListAsync())
            .OrderByDescending(r => r.SavedAt).ToList();
        savedNames = savedRecipes.Select(r => r.Name).ToHashSet(StringComparer.OrdinalIgnoreCase);
        // Id → name for the ?uses filter (all products, tracked or not — a recipe may point at an
        // item that's since been untracked).
        productNamesById = await db.Products.Select(p => new { p.Id, p.Name }).ToDictionaryAsync(x => x.Id, x => x.Name);

        // "Likely on hand" = tracked, EDIBLE products the engine doesn't think you've run out of. Edible
        // only so a family match ("chicken") can't be satisfied by "Chicken Jerky Dog Treats" or a
        // chicken-scented cleaner — recipes only reason over food. Untracked products load too, but ONLY
        // to power the "you have this, but it's untracked" hint — every other pool filters them out.
        var products = await db.Products.AsNoTracking()
            .Include(p => p.Purchases).Include(p => p.Signals).Include(p => p.Substitutes).ToListAsync();
        var today = DateOnly.FromDateTime(DateTime.Today);
        onHand = PantryOnHand.EdibleInStock(products, today)
            .Select(p => new PantryProduct(p.Name, p.Substitutes.Select(s => s.Value).ToList()))
            .OrderBy(x => x.Name)
            .ToList();
        cloudProducts = products
            .Where(p => p.IsTracked && p.Category.IsEdible())
            .Select(p => new PantryProduct(p.Name, p.Substitutes.Select(s => s.Value).ToList()))
            .OrderBy(x => x.Name)
            .ToList();
        outOfStock = PantryOnHand.EdibleOutOfStock(products, today)
            .Select(p => (p.Id, Product: new PantryProduct(p.Name, p.Substitutes.Select(s => s.Value).ToList())))
            .OrderBy(x => x.Product.Name)
            .ToList();
        untrackedEdible = PantryOnHand.EdibleUntracked(products)
            .Select(p => (p.Id, Product: new PantryProduct(p.Name, p.Substitutes.Select(s => s.Value).ToList())))
            .OrderBy(x => x.Product.Name)
            .ToList();

        ApplyFilter(); // keep the ?uses view in sync after any reload
    }

    private async Task AddExcluded()
    {
        var value = newExcluded.Trim();
        if (value.Length == 0) return;
        if (!excludedFoods.Any(f => string.Equals(f.Value, value, StringComparison.OrdinalIgnoreCase)))
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            db.ExcludedFoods.Add(new ExcludedFood { Value = value });
            await db.SaveChangesAsync();
        }
        newExcluded = "";
        await LoadAsync();
    }

    private async Task RemoveExcluded(ExcludedFood f)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        db.ExcludedFoods.Remove(await db.ExcludedFoods.FindAsync(f.Id) ?? f);
        await db.SaveChangesAsync();
        await LoadAsync();
    }

    private async Task Suggest()
    {
        if (suggesting || string.IsNullOrWhiteSpace(request)) return;
        suggesting = true;
        suggestError = null;
        try
        {
            // onHand grounds the suggestions in real catalog items. The card's have/grab marks trust the
            // model's matched_product only when POSITIVE; a null falls back to the plain-code matcher
            // (HaveSuggested), so the pre-save card always agrees with what saving would show.
            // The previous batch stays on screen (and in storage) until this one actually succeeds.
            var fresh = (await Advisor.SuggestAsync(request, onHand.Select(p => p.Name).ToList(), excludedFoods.Select(f => f.Value).ToList())).ToList();
            if (fresh.Count == 0)
            {
                suggestError = "No ideas came back — try rephrasing.";
            }
            else
            {
                suggestions = fresh;
                suggestedFor = request;
                suggestedAt = DateTimeOffset.Now;
                await Settings.SetAsync(SettingKeys.LastRecipeSuggestions,
                    JsonSerializer.Serialize(new SuggestionSnapshot(suggestedFor, suggestedAt, suggestions)));
            }
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Recipe suggestion failed for request \"{Request}\".", request);
            suggestError = "Couldn't get ideas just now — please try again.";
        }
        finally
        {
            suggesting = false;
        }
    }

    private async Task ClearSuggestions()
    {
        suggestions = [];
        suggestedFor = "";
        await Settings.SetAsync(SettingKeys.LastRecipeSuggestions, null);
    }

    private async Task Save(RecipeSuggestion s)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        db.Recipes.Add(new Recipe
        {
            Name = s.Name,
            Blurb = s.Blurb,
            SavedAt = DateTimeOffset.Now,
            Ingredients = s.Ingredients.Select(i => new RecipeIngredient { Name = i.Name, IsMain = i.IsMain, MatchedProduct = i.MatchedProduct, Quantity = i.Quantity }).ToList(),
            Steps = s.Steps.Select((t, idx) => new RecipeStep { Order = idx + 1, Text = t }).ToList(),
            EstimatedCaloriesPerServing = s.CaloriesPerServing,
        });
        await db.SaveChangesAsync();
        await LoadAsync();
    }

    private async Task MarkEaten(Recipe r)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var rec = await db.Recipes.FindAsync(r.Id);
        if (rec is null) return;
        rec.TimesEaten++;
        await db.SaveChangesAsync();
        await LoadAsync();
    }

    // Send the main ingredients you don't currently have to the grocery list's manual "extras" section.
    private async Task AddMissingToList(Recipe r)
    {
        var missing = r.MissingMains(onHand).Select(i => i.Name).ToList();
        if (missing.Count == 0) { extraNote = "You already have everything for this."; return; }

        await using var db = await DbFactory.CreateDbContextAsync();
        var have = await db.GroceryExtras.Select(e => e.Name).ToListAsync();
        var added = 0;
        foreach (var name in missing)
        {
            if (!have.Any(h => string.Equals(h, name, StringComparison.OrdinalIgnoreCase)))
            {
                db.GroceryExtras.Add(new GroceryExtra { Name = name });
                have.Add(name);
                added++;
            }
        }
        await db.SaveChangesAsync();
        extraNote = added > 0
            ? $"Added {added} item{(added == 1 ? "" : "s")} to your grocery list."
            : "Those are already on your grocery list.";
    }

    private async Task DeleteSaved(Recipe r)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        db.Recipes.Remove(await db.Recipes.FindAsync(r.Id) ?? r);
        await db.SaveChangesAsync();
        await LoadAsync();
    }
}
