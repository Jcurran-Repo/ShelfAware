@page "/recipes"
@implements IDisposable
@using ShelfAware.Core.Prediction
@using ShelfAware.Core.Recipes
@using ShelfAware.Llm
@using Microsoft.Extensions.Options
@inject IDbContextFactory<ShelfAwareDbContext> DbFactory
@inject IRecipeAdvisor Advisor
@inject IOptions<ElevenLabsOptions> ElOptions
@inject VoiceCoordinator Coordinator

<PageTitle>Recipes — Shelf Aware</PageTitle>

<div class="page-head">
    <h1>Recipes</h1>
</div>

<p class="recipe-disclaimer" role="note">
    ⚠️ Ideas only — <strong>always check ingredient labels yourself</strong>. This is not allergy-safe or
    medical advice; the “won’t eat” list is a best-effort filter, not a guarantee.
</p>

<section class="panel">
    <h2>Foods I won’t eat</h2>
    <p class="muted">Allergies or dislikes — recipes will avoid these. Applies to every suggestion.</p>
    <div class="tag-list">
        @foreach (var f in excludedFoods)
        {
            <span class="tag-chip">@f.Value<button type="button" class="tag-x" @onclick="() => RemoveExcluded(f)" aria-label="Remove @f.Value">×</button></span>
        }
        @if (excludedFoods.Count == 0)
        {
            <span class="muted">Nothing excluded yet.</span>
        }
    </div>
    <div class="tag-add">
        <input placeholder="e.g. mushrooms" @bind="newExcluded" @bind:event="oninput"
               aria-label="Add a food you won't eat" />
        <button type="button" @onclick="AddExcluded" disabled="@string.IsNullOrWhiteSpace(newExcluded)">Add</button>
    </div>
</section>

<section class="panel">
    <h2>What can I make?</h2>
    <form @onsubmit="Suggest" @formname="recipe-request">
        <input @bind="request" @bind:event="oninput" placeholder="e.g. I'm feeling Mediterranean tonight"
               aria-label="Describe what you're in the mood for" disabled="@suggesting" />
        <button type="submit" disabled="@(suggesting || string.IsNullOrWhiteSpace(request))">
            @(suggesting ? "Thinking…" : "Get ideas")
        </button>
    </form>
    @if (suggestError is not null)
    {
        <p class="error">@suggestError</p>
    }

    @if (suggestions.Count > 0)
    {
        <div class="recipe-suggestions">
            @foreach (var s in suggestions)
            {
                <article class="recipe-card">
                    <div class="recipe-card-top">
                        <h3>@s.Name</h3>
                        <button class="secondary" @onclick="() => Save(s)" disabled="@savedNames.Contains(s.Name)">
                            @(savedNames.Contains(s.Name) ? "Saved ✓" : "Save")
                        </button>
                    </div>
                    <p class="muted">@s.Blurb</p>
                    @if (s.CaloriesPerServing is { } cal)
                    {
                        <p class="recipe-cal">~@cal cal / serving <span class="muted">(est.)</span></p>
                    }
                    <ul class="ingredient-list">
                        @foreach (var i in s.Ingredients.Where(i => i.IsMain))
                        {
                            <li class="@(i.Have ? "have" : "grab")">@(i.Have ? "✓" : "🛒") @i.Name</li>
                        }
                        @{ var seasonings = s.Ingredients.Where(i => !i.IsMain).Select(i => i.Name).ToList(); }
                        @if (seasonings.Count > 0)
                        {
                            <li class="muted">+ @string.Join(", ", seasonings)</li>
                        }
                    </ul>
                    @{ var grab = s.ToGrab.ToList(); }
                    @if (grab.Count > 0)
                    {
                        <p class="recipe-grab">Grab: <strong>@string.Join(", ", grab.Select(g => g.Name))</strong></p>
                    }
                    else
                    {
                        <p class="recipe-grab all-good">You’ve got everything for this. 🎉</p>
                    }
                    @if (s.Steps.Count > 0)
                    {
                        <details class="recipe-steps">
                            <summary>Steps (@s.Steps.Count)</summary>
                            <ol>
                                @foreach (var step in s.Steps)
                                {
                                    <li>@step</li>
                                }
                            </ol>
                        </details>
                    }
                </article>
            }
        </div>
    }
</section>

<section class="panel">
    <div class="page-head">
        <h2>Saved recipes <span class="muted">— @displayed.Count</span></h2>
        @if (PickPool.Count > 0)
        {
            <button @onclick="PickForMe">🎲 Pick for me</button>
        }
    </div>
    @if (filterProductName is not null)
    {
        <p class="filter-banner" role="status">Showing recipes that use <strong>@filterProductName</strong> — <a href="/recipes">show all</a></p>
    }
    @if (readingRecipe is not null)
    {
        <RecipeReadAloud Recipe="readingRecipe" @key="readingRecipe.Id" OnClosed="StopReading" />
    }
    @if (cookingRecipe is not null)
    {
        <CookAlong Recipe="cookingRecipe" @key="cookingRecipe.Id" OnClosed="StopCooking" OnUnavailable="HandleCookUnavailable" />
    }
    @if (picked is not null)
    {
        <p class="picked-banner">Tonight: <strong>@picked.Name</strong>@(picked.Blurb is { Length: > 0 } pb ? $" — {pb}" : "")</p>
    }
    @if (extraNote is not null)
    {
        <p class="chat-reply" role="status">@extraNote</p>
    }
    @if (displayed.Count == 0)
    {
        <p class="muted">
            @(filterProductName is null
                ? "None yet — get some ideas above and hit Save on the ones you like."
                : $"No saved recipes use {filterProductName} yet.")
        </p>
    }
    else
    {
        <ul class="saved-recipes">
            @foreach (var r in displayed)
            {
                var makeable = Makeable(r);
                <li id="recipe-@r.Id">
                    <div class="saved-top">
                        <strong>@r.Name</strong>
                        <span class="chip chip-@(makeable ? "stocked" : "unknown")">@(makeable ? "Ready to make" : "Missing items")</span>
                        <span class="saved-actions">
                            @if (r.Steps.Count > 0)
                            {
                                @if (CookAlongAvailable)
                                {
                                    <SplitButton PrimaryLabel="🎙 Cook-along" MainClass="secondary" OnPrimary="() => StartCooking(r)"
                                                 PrimaryAriaLabel="@($"Hands-free cook-along for {r.Name}")">
                                        <button class="secondary" @onclick="() => StartReading(r)" aria-label="Read @r.Name aloud">🔊 Read it to me</button>
                                    </SplitButton>
                                }
                                else
                                {
                                    <button class="secondary" @onclick="() => StartReading(r)" aria-label="Read @r.Name aloud">🔊 Read it to me</button>
                                }
                            }
                            <button class="secondary" @onclick="() => MarkEaten(r)" aria-label="Mark @r.Name eaten">Ate it</button>
                            @if (!makeable)
                            {
                                <button class="secondary" @onclick="() => AddMissingToList(r)" aria-label="Add missing ingredients for @r.Name to the grocery list">Add missing to list</button>
                            }
                            <button class="icon-btn" @onclick="() => DeleteSaved(r)" aria-label="Delete @r.Name" title="Delete @r.Name"><span aria-hidden="true">🗑</span></button>
                        </span>
                    </div>
                    @if (r.Blurb is { Length: > 0 })
                    {
                        <p class="muted">@r.Blurb</p>
                    }
                    @if (r.EstimatedCaloriesPerServing is { } cal)
                    {
                        <p class="recipe-cal">~@cal cal / serving <span class="muted">(est.)</span></p>
                    }
                    <ul class="ingredient-list">
                        @foreach (var i in r.Ingredients.Where(i => i.IsMain))
                        {
                            var have = i.MatchedProduct is not null && onHandSet.Contains(i.MatchedProduct);
                            <li class="@(have ? "have" : "grab")">@(have ? "✓" : "🛒") @i.Name</li>
                        }
                        @{ var extras = r.Ingredients.Where(i => !i.IsMain).Select(i => i.Name).ToList(); }
                        @if (extras.Count > 0)
                        {
                            <li class="muted">+ @string.Join(", ", extras)</li>
                        }
                    </ul>
                    @if (r.TimesEaten > 0)
                    {
                        <p class="muted small">eaten @r.TimesEaten×</p>
                    }
                    @if (r.Steps.Count > 0)
                    {
                        <details class="recipe-steps">
                            <summary>Steps (@r.Steps.Count)</summary>
                            <ol>
                                @foreach (var step in r.Steps.OrderBy(s => s.Order))
                                {
                                    <li>@step.Text</li>
                                }
                            </ol>
                        </details>
                    }
                </li>
            }
        </ul>
    }
</section>

@code {
    private List<ExcludedFood> excludedFoods = [];
    private string newExcluded = "";

    private string request = "";
    private bool suggesting;
    private string? suggestError;
    private List<RecipeSuggestion> suggestions = [];

    private List<Recipe> savedRecipes = [];
    private HashSet<string> savedNames = new(StringComparer.OrdinalIgnoreCase);

    // The saved recipes actually rendered — all of them, or just those using a product when ?uses is set.
    private List<Recipe> displayed = [];
    private Dictionary<int, string> productNamesById = [];
    private string? filterProductName;

    private List<string> onHand = [];
    private HashSet<string> onHandSet = new(StringComparer.OrdinalIgnoreCase);

    private Recipe? picked;
    private string? extraNote;
    private Recipe? readingRecipe;
    private Recipe? cookingRecipe;
    private bool cookAutoStarted; // this cook-along was opened by the voice chain (so we may fall back)
    private readonly Random rng = new();

    /// <summary>Deep link from the chat's read_recipe tool (/recipes?read={id}) — auto-starts a hands-free
    /// read of the recipe: the listening cook-along agent when it's configured (so the whole voice chain,
    /// including leaving by voice, stays hands-free), else the button-controlled read-aloud.</summary>
    [SupplyParameterFromQuery(Name = "read")] public int? ReadId { get; set; }

    /// <summary>Deep link from open_page(page="recipes", product_name) (/recipes?uses={id}) — scopes the
    /// saved list to recipes that use that product, the middle step of the hands-free navigation chain.</summary>
    [SupplyParameterFromQuery(Name = "uses")] public int? UsesProductId { get; set; }

    // Hands-free cook-along only shows when an ElevenLabs agent is configured (empty id = hidden).
    private bool CookAlongAvailable => !string.IsNullOrEmpty(ElOptions.Value.AgentId);

    // Only one voice surface at a time — starting one closes the other. cookAutoStarted resets on any
    // manual start; the deep-link path sets it true afterwards so only that case auto-falls-back.
    private void StartReading(Recipe r) { cookAutoStarted = false; cookingRecipe = null; readingRecipe = r; }
    private void StopReading() => readingRecipe = null;
    private void StartCooking(Recipe r) { cookAutoStarted = false; readingRecipe = null; cookingRecipe = r; }
    private void StopCooking() => cookingRecipe = null;

    // The voice chain's auto-started cook-along couldn't connect (e.g. bad wifi). Fall back to the plain
    // reader so the recipe still gets read instead of dead-ending on an error the user can't tap away.
    private void HandleCookUnavailable()
    {
        if (cookAutoStarted && cookingRecipe is { } r) StartReading(r);
    }

    // A saved recipe is makeable when every MAIN ingredient mapped to a product you currently have on hand
    // (seasonings/staples are ignored — plain-code check over the mapping captured at save time).
    private bool Makeable(Recipe r)
    {
        var mains = r.Ingredients.Where(i => i.IsMain).ToList();
        return mains.Count > 0 && mains.All(i => i.MatchedProduct is not null && onHandSet.Contains(i.MatchedProduct));
    }

    // "Pick for me" pool: saved recipes you've eaten before AND can make right now — the reliable
    // "I can definitely eat this, just tell me" set.
    private List<Recipe> PickPool => savedRecipes.Where(r => r.TimesEaten > 0 && Makeable(r)).ToList();

    private void PickForMe()
    {
        var pool = PickPool;
        picked = pool.Count > 0 ? pool[rng.Next(pool.Count)] : null;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        if (ReadId is { } id && savedRecipes.FirstOrDefault(r => r.Id == id) is { Steps.Count: > 0 } target)
        {
            // The voice chain wants this read hands-free. Prefer the listening cook-along agent (voice
            // "next"/"back"/"stop"/"go to the assistant"); fall back to the button-controlled reader when
            // the ElevenLabs agent isn't configured (or, later, if it can't connect — HandleCookUnavailable).
            if (CookAlongAvailable) { StartCooking(target); cookAutoStarted = true; }
            else StartReading(target);
        }
    }

    // Re-derive the ?uses filter whenever the query changes (navigating between filtered views without a
    // full page reload); the first run happens after OnInitializedAsync has loaded the data.
    protected override void OnParametersSet() => ApplyFilter();

    private void ApplyFilter()
    {
        filterProductName = UsesProductId is { } pid && productNamesById.TryGetValue(pid, out var n) ? n : null;
        displayed = filterProductName is { } name
            ? savedRecipes.Where(r => r.Ingredients.Any(i => string.Equals(i.MatchedProduct, name, StringComparison.OrdinalIgnoreCase))).ToList()
            : savedRecipes;
        PublishScreenContext();
    }

    // Tell the roaming voice agent what's on screen and in what order, so "read me the second one"
    // resolves to the right saved recipe. Cleared on navigate-away so it can't leak to another page.
    private void PublishScreenContext() =>
        Coordinator.ScreenContext = displayed.Count == 0
            ? null
            : (filterProductName is { } fn ? $"The user is viewing recipes that use {fn}. " : "The user is viewing the Recipes page. ")
              + "Recipes listed, in display order:\n"
              + string.Join("\n", displayed.Select((r, i) => $"{i + 1}. {r.Name}"));

    public void Dispose() => Coordinator.ScreenContext = null;

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        excludedFoods = await db.ExcludedFoods.OrderBy(f => f.Value).ToListAsync();
        // SQLite can't ORDER BY a DateTimeOffset column — sort client-side.
        savedRecipes = (await db.Recipes.Include(r => r.Ingredients).Include(r => r.Steps).ToListAsync())
            .OrderByDescending(r => r.SavedAt).ToList();
        savedNames = savedRecipes.Select(r => r.Name).ToHashSet(StringComparer.OrdinalIgnoreCase);
        // Id → name for the ?uses filter (all products, tracked or not — a recipe may point at an
        // item that's since been untracked).
        productNamesById = await db.Products.Select(p => new { p.Id, p.Name }).ToDictionaryAsync(x => x.Id, x => x.Name);

        // "Likely on hand" = tracked products the engine doesn't think you've run out of.
        var products = await db.Products.Where(p => p.IsTracked).Include(p => p.Purchases).Include(p => p.Signals).ToListAsync();
        var today = DateOnly.FromDateTime(DateTime.Today);
        onHand = products
            .Where(p => ReplenishmentPredictor.Predict(p, today).Status != PredictionStatus.Overdue)
            .Select(p => p.Name)
            .OrderBy(n => n)
            .ToList();
        onHandSet = onHand.ToHashSet(StringComparer.OrdinalIgnoreCase);

        ApplyFilter(); // keep the ?uses view in sync after any reload
    }

    private async Task AddExcluded()
    {
        var value = newExcluded.Trim();
        if (value.Length == 0) return;
        if (!excludedFoods.Any(f => string.Equals(f.Value, value, StringComparison.OrdinalIgnoreCase)))
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            db.ExcludedFoods.Add(new ExcludedFood { Value = value });
            await db.SaveChangesAsync();
        }
        newExcluded = "";
        await LoadAsync();
    }

    private async Task RemoveExcluded(ExcludedFood f)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        db.ExcludedFoods.Remove(await db.ExcludedFoods.FindAsync(f.Id) ?? f);
        await db.SaveChangesAsync();
        await LoadAsync();
    }

    private async Task Suggest()
    {
        if (suggesting || string.IsNullOrWhiteSpace(request)) return;
        suggesting = true;
        suggestError = null;
        suggestions = [];
        try
        {
            // onHand still grounds the suggestions in real catalog items. We deliberately DON'T display a
            // have/grab verdict here — the model's self-reported availability is unreliable and accurate
            // ingredient↔product matching is Phase 2 (captured as an ingredient→product map at save time).
            suggestions = (await Advisor.SuggestAsync(request, onHand, excludedFoods.Select(f => f.Value).ToList())).ToList();
            if (suggestions.Count == 0) suggestError = "No ideas came back — try rephrasing.";
        }
        catch (Exception ex)
        {
            suggestError = $"Couldn't get ideas just now: {ex.Message}";
        }
        finally
        {
            suggesting = false;
        }
    }

    private async Task Save(RecipeSuggestion s)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        db.Recipes.Add(new Recipe
        {
            Name = s.Name,
            Blurb = s.Blurb,
            SavedAt = DateTimeOffset.Now,
            Ingredients = s.Ingredients.Select(i => new RecipeIngredient { Name = i.Name, IsMain = i.IsMain, MatchedProduct = i.MatchedProduct }).ToList(),
            Steps = s.Steps.Select((t, idx) => new RecipeStep { Order = idx + 1, Text = t }).ToList(),
            EstimatedCaloriesPerServing = s.CaloriesPerServing,
        });
        await db.SaveChangesAsync();
        await LoadAsync();
    }

    private async Task MarkEaten(Recipe r)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var rec = await db.Recipes.FindAsync(r.Id);
        if (rec is null) return;
        rec.TimesEaten++;
        await db.SaveChangesAsync();
        await LoadAsync();
    }

    // Send the main ingredients you don't currently have to the grocery list's manual "extras" section.
    private async Task AddMissingToList(Recipe r)
    {
        var missing = r.Ingredients
            .Where(i => i.IsMain && (i.MatchedProduct is null || !onHandSet.Contains(i.MatchedProduct)))
            .Select(i => i.Name).ToList();
        if (missing.Count == 0) { extraNote = "You already have everything for this."; return; }

        await using var db = await DbFactory.CreateDbContextAsync();
        var have = await db.GroceryExtras.Select(e => e.Name).ToListAsync();
        var added = 0;
        foreach (var name in missing)
        {
            if (!have.Any(h => string.Equals(h, name, StringComparison.OrdinalIgnoreCase)))
            {
                db.GroceryExtras.Add(new GroceryExtra { Name = name });
                have.Add(name);
                added++;
            }
        }
        await db.SaveChangesAsync();
        extraNote = added > 0
            ? $"Added {added} item{(added == 1 ? "" : "s")} to your grocery list."
            : "Those are already on your grocery list.";
    }

    private async Task DeleteSaved(Recipe r)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        db.Recipes.Remove(await db.Recipes.FindAsync(r.Id) ?? r);
        await db.SaveChangesAsync();
        await LoadAsync();
    }
}
