@page "/settings"
@implements IAsyncDisposable
@using ShelfAware.Core.Settings
@using ShelfAware.Core.Speech
@using ShelfAware.Core.Ingest
@using ShelfAware.Llm
@using ShelfAware.Web.Auth
@using Microsoft.Extensions.Options
@using System.Security.Claims
@using ShelfAware.Web.Ingest
@inject IAppSettings SettingsStore
@inject ReceiptFolderPolicy FolderPolicy
@inject IReceiptInbox Inbox
@inject IReceiptImporter Importer
@inject IHouseholdDbFactory DbFactory
@inject HouseholdService Households
@inject IJSRuntime JS
@inject CircuitAiSettings AiSettings
@inject AiUsageMeter UsageMeter
@inject IOptions<LlmOptions> LlmConfig
@inject ILogger<Settings> Logger
@inject UserDataService UserData

<PageTitle>Settings — Shelf Aware</PageTitle>

<div class="page-head">
    <h1>Settings</h1>
</div>

<section class="panel">
    <h2>Household</h2>
    @if (household is null)
    {
        <p class="muted">Loading…</p>
    }
    else
    {
        <p class="muted">
            Everyone in your household shares this pantry — products, receipts, recipes, and these settings.
            To bring someone in, generate an <strong>invite code</strong> and give it to them; they enter it
            when creating their account. There's no code until you make one, and it goes away once it's been
            used — so there's never a spare key lying around.
        </p>

        <label class="field"><span>Household name</span></label>
        <div class="tag-add">
            <input @bind="householdName" @bind:event="oninput" aria-label="Household name" size="30" />
            <button @onclick="RenameHousehold" disabled="@(renaming || !HouseholdNameChanged)">
                @(renaming ? "Saving…" : "Rename")
            </button>
        </div>

        <label class="field"><span>Invite code</span></label>
        @if (household.InviteCode is null)
        {
            <div class="review-actions invite-row">
                <code class="invite-code">—</code>
                <button @onclick="GenerateInvite" disabled="@inviteBusy">
                    @(inviteBusy ? "Generating…" : "Generate invite code")
                </button>
            </div>
            <p class="muted small">No invite code — nobody can join this household until you generate one.</p>
        }
        else
        {
            <div class="review-actions invite-row">
                <code class="invite-code">@household.InviteCode</code>
                <button @onclick="CopyInvite" disabled="@(!InviteUsable)">Copy</button>
                <button class="secondary" @onclick="GenerateInvite" disabled="@inviteBusy">
                    @(inviteBusy ? "Working…" : "Replace")
                </button>
                <button class="secondary" @onclick="ClearInvite" disabled="@inviteBusy">Clear code</button>
            </div>
            <p class="@(InviteUsable ? "muted small" : "error small")">@InviteStatus</p>
        }
        <label class="field">
            <input type="checkbox" @bind="inviteSingleUse" />
            <span>Single use — the next code works for one person only</span>
        </label>
        @if (inviteNote is not null)
        {
            <p class="chat-reply" role="status">@inviteNote</p>
        }
        <p class="muted small">
            Replacing or clearing invalidates the old code — anyone you already gave it to needs the new one.
            Neither removes anyone who already joined; use Remove for that.
        </p>

        <h3>Members</h3>
        <ul class="member-list">
            @foreach (var member in members)
            {
                <li>
                    <span>@member.Email</span>
                    @if (member.Id == currentUserId)
                    {
                        <span class="muted small">you</span>
                    }
                    else
                    {
                        <button class="secondary" @onclick="() => RemoveMember(member)"
                                disabled="@(removingId is not null)"
                                aria-label="Remove @member.Email from this household">
                            @(removingId == member.Id ? "Removing…" : "Remove")
                        </button>
                    }
                </li>
            }
        </ul>
        @if (memberNote is not null)
        {
            <p class="chat-reply" role="status">@memberNote</p>
        }
        @if (memberError is not null)
        {
            <p class="error" role="alert">@memberError</p>
        }
        <p class="muted small">
            Removing someone takes their access away within a few minutes, on every device they're signed
            in on. It doesn't touch the pantry — that belongs to the household, not the account — and they
            keep their account, they're just not in a household until they join or start one.
        </p>
        <p class="muted small">
            Forgot a password? There's no email reset yet — whoever runs this server can recreate the
            account. The pantry is untouched either way: it belongs to the household, not the account.
        </p>
    }
</section>

<section class="panel">
    <h2>AI provider &amp; keys</h2>
    @if (AiSettings.Managed)
    {
        <p class="muted">
            AI on this deployment runs on the host's own keys — there's nothing to set up here. (Your pantry
            data still lives only on this server.)
        </p>
        @if (todayUsage is not null)
        {
            <p class="muted small">
                Your household today: <strong>@todayUsage.Calls</strong> AI call(s)
                · <strong>@todayUsage.Tokens.ToString("N0")</strong> tokens@(todayUsage.VoiceSessionMints > 0
                    ? $" · {todayUsage.VoiceSessionMints} cook-along session(s)" : "")@UsageLimitSuffix
            </p>
        }
    }
    else
    {
    <p class="muted">
        Bring your own API keys. They're stored only in <strong>your browser</strong> — never on the server —
        and used only to call the provider you pick. This app's source is public, so you can verify that yourself.
    </p>

    @if (!aiLoaded)
    {
        <p>Loading…</p>
    }
    else
    {
        <div class="ai-settings">
            <label class="field">
                <span>Provider</span>
                <select @bind="provider" @bind:after="OnProviderChanged" aria-label="AI provider">
                    <option value="Anthropic">Anthropic (Claude)</option>
                    <option value="OpenAI">OpenAI (GPT)</option>
                    <option value="OpenAICompatible">Local / custom (OpenAI-compatible)</option>
                </select>
            </label>

            <label class="field">
                <span>@ProviderLabel API key</span>
                <input type="password" @bind="apiKey" autocomplete="off" spellcheck="false"
                       placeholder="@(IsLocal ? "Often unused — put anything, e.g. local" : $"Paste your {ProviderLabel} key")"
                       aria-label="@ProviderLabel API key" />
            </label>

            @if (IsLocal)
            {
                <label class="field">
                    <span>Base URL <span class="muted">— your local server's OpenAI endpoint</span></span>
                    <input @bind="baseUrl" autocomplete="off" spellcheck="false"
                           placeholder="http://localhost:11434/v1" aria-label="OpenAI-compatible base URL" />
                </label>
                <p class="muted">Runs a model on your own machine (Ollama, LM Studio, llama.cpp, …) — zero token
                    cost. Available when you self-host ShelfAware.</p>
            }

            <div class="model-fields">
                <label class="field">
                    <span>Extraction model <span class="muted">— reads receipts (needs vision)</span></span>
                    <input list="ai-models" @bind="extractionModel" aria-label="Extraction model" />
                </label>
                <label class="field">
                    <span>Chat model <span class="muted">— the assistant (needs tools)</span></span>
                    <input list="ai-models" @bind="chatModel" aria-label="Chat model" />
                </label>
            </div>
            <datalist id="ai-models">
                @foreach (var m in ModelsFor(provider))
                {
                    <option value="@m" />
                }
            </datalist>

            <h3>Voice <span class="muted">— optional (ElevenLabs)</span></h3>
            <label class="field">
                <span>ElevenLabs API key</span>
                <input type="password" @bind="elKey" autocomplete="off" spellcheck="false"
                       placeholder="For push-to-talk and read-aloud" aria-label="ElevenLabs API key" />
            </label>
            <label class="field">
                <span>
                    Cook-along agent id
                    <span class="muted">
                        — optional. Hands-free cook-along doesn't need this; it's only for the
                        “Live agent” option, which can be interrupted mid-sentence but bills per minute.
                    </span>
                </span>
                <input @bind="elAgentId" aria-label="ElevenLabs cook-along agent id" />
            </label>

            <label class="checkbox-field">
                <input type="checkbox" @bind="sessionOnly" />
                <span>Forget my keys when I close this tab <span class="muted">— safer on a shared computer</span></span>
            </label>

            <div class="review-actions">
                <button @onclick="SaveKeys" disabled="@savingKeys">@(savingKeys ? "Saving…" : "Save keys")</button>
                <button class="secondary" @onclick="ForgetKeys" disabled="@savingKeys">Forget my keys</button>
            </div>
            @if (keyNote is not null)
            {
                <p class="chat-reply" role="status">@keyNote</p>
            }
        </div>
    }
    }
</section>

@* Calibration is per DEVICE, not per household — two people in one kitchen still have different
   microphones, and one of them is on a phone. So this panel shows even on a managed deployment, where
   the keys panel is hidden: it isn't a key, it's what this room sounds like. *@
<section class="panel">
    <h2>Hands-free listening</h2>
    <p class="muted">
        How the cook-along hears you on <strong>this device</strong>. The defaults are guesses — a
        minute of calibration measures your microphone, your kitchen, and how you actually talk.
    </p>

    @if (calibrationError is not null)
    {
        <p class="error" role="status">@calibrationError</p>
    }

    @if (calibrationStage is not CalibrationStage.Idle)
    {
        <p class="calibrate-stage" role="status" aria-live="assertive">
            <span class="listen-dot listen-listening" aria-hidden="true"></span>
            <strong>@CalibrationPrompt</strong>
        </p>
    }
    else
    {
        @* Show what it MEASURED against what it would otherwise have guessed. Jordan ran the wizard and
           couldn't tell whether anything had changed — the panel showed the values but nothing to compare
           them to, so "it changed values… I think?" was the only honest reading available. A calibration
           you can't tell apart from a default hasn't reported its result. *@
        <dl class="listen-values">
            <dt>Waits for a pause of</dt>
            <dd>
                <strong>@listening.SilenceMs ms</strong> <span class="muted">before deciding you've finished</span>
                @if (Changed(listening.SilenceMs, ListeningSettings.Default.SilenceMs))
                {
                    <span class="listen-delta">was @ListeningSettings.Default.SilenceMs ms by default</span>
                }
            </dd>
            <dt>Ignores anything below</dt>
            <dd>
                <strong>@listening.FloorMultiple.ToString("0.0")× the room</strong> <span class="muted">— the noise gate</span>
                @if (Changed(listening.FloorMultiple, ListeningSettings.Default.FloorMultiple))
                {
                    <span class="listen-delta">was @ListeningSettings.Default.FloorMultiple.ToString("0.0")× by default</span>
                }
            </dd>
            <dt>Holds the mic open for</dt>
            <dd>
                <strong>@(listening.OpenMs / 1000.0)s</strong> <span class="muted">if you say nothing</span>
            </dd>
        </dl>

        @if (lastCalibration is { } m)
        {
            <p class="muted small">
                Measured just now: your room at @m.NoiseFloor.ToString("0.000"), your voice at
                @m.SpeechPeak.ToString("0.000") (@((m.SpeechPeak / Math.Max(m.NoiseFloor, 0.0001)).ToString("0"))× louder),
                and your longest mid-sentence pause was @m.LongestPauseMs ms — which is what the silence
                window is built from.
            </p>
        }
        else
        {
            <p class="muted small">@(calibrated ? "Calibrated on this device." : "Not calibrated — using defaults.")</p>
        }

        <div class="ra-controls">
            <button @onclick="CalibrateAsync">🎙 Calibrate listening</button>
            @if (calibrated)
            {
                <button class="secondary" @onclick="ResetCalibrationAsync">Reset to defaults</button>
            }
        </div>
    }
</section>

<section class="panel">
    <h2>AI usage</h2>
    <p class="muted">
        What this household's AI features have spent — every chat turn, receipt read, recipe call,
        and accuracy check counts here, whichever key it ran on. Bring-your-own-key usage is shown
        for your information but never limited.
    </p>
    @if (todayUsage is { } today)
    {
        <div class="portfolio">
            <div class="stat">
                <span class="stat-label">Today · AI calls</span>
                <span class="stat-value">@today.Calls</span>
            </div>
            <div class="stat">
                <span class="stat-label">Today · tokens</span>
                <span class="stat-value">@today.Tokens.ToString("N0")</span>
            </div>
            <div class="stat">
                <span class="stat-label">Today · voice sessions</span>
                <span class="stat-value">@today.VoiceSessionMints</span>
            </div>
        </div>
    }
    @if (usageHistory.Count > 0)
    {
        <div class="table-scroll">
            <table>
                <caption class="visually-hidden">Recent daily AI usage: calls, input and output tokens, and voice sessions per day.</caption>
                <thead>
                    <tr>
                        <th scope="col">Day</th>
                        <th scope="col">AI calls</th>
                        <th scope="col">Tokens in</th>
                        <th scope="col">Tokens out</th>
                        <th scope="col">Total tokens</th>
                        <th scope="col">Voice sessions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var day in usageHistory)
                    {
                        <tr>
                            <td>@day.Day.ToString("MMM d, yyyy")</td>
                            <td>@day.Calls</td>
                            <td>@day.InputTokens.ToString("N0")</td>
                            <td>@day.OutputTokens.ToString("N0")</td>
                            <td>@day.Tokens.ToString("N0")</td>
                            <td>@day.VoiceSessionMints</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="muted">Days with no AI activity aren't listed.</p>
    }
    else
    {
        <p class="muted">No AI usage recorded yet — it starts counting from your next chat, upload, or voice session.</p>
    }
</section>

<section class="panel">
    <h2>Receipt auto-import</h2>
    <p class="muted">
        Point this at a folder of receipt images or PDFs. The assistant imports new ones — on startup,
        when you press “Scan now”, or when you tell it <em>“import my receipts”</em>. The folder is a
        per-household setting; if two households point at the same folder, each imports its own copy.
    </p>

    <fieldset class="import-mode">
        <legend>When a receipt is imported</legend>
        <label>
            <input type="radio" name="import-mode" checked="@(mode == ImportMode.Smart)"
                   @onchange="() => SetMode(ImportMode.Smart)" />
            <span><strong>Smart</strong> <span class="muted">(recommended)</span> — confirm automatically only when
            every line matches a product you already have (a learned alias or a confident match); anything
            uncertain — a new product, a shaky read — waits for your review.</span>
        </label>
        <label>
            <input type="radio" name="import-mode" checked="@(mode == ImportMode.Review)"
                   @onchange="() => SetMode(ImportMode.Review)" />
            <span><strong>Review everything</strong> — every import waits as pending for you to review and
            approve (or fix) on the <a href="/receipt">Upload</a> page.</span>
        </label>
        <label>
            <input type="radio" name="import-mode" checked="@(mode == ImportMode.Auto)"
                   @onchange="() => SetMode(ImportMode.Auto)" />
            <span><strong>Confirm everything</strong> — imports go straight into your history, new products included.</span>
        </label>
    </fieldset>

    <div class="tag-add">
        <input @bind="folder" @bind:event="oninput" placeholder="e.g. C:\Users\you\Documents\Receipts"
               aria-label="Receipt folder path" size="48" aria-describedby="folder-limit" />
        <button @onclick="SaveFolder" disabled="@saving">@(saving ? "Saving…" : "Save")</button>
    </div>
    @if (FolderPolicy.IsConfined)
    {
        <p class="muted" id="folder-limit">On this deployment, receipt folders have to be inside <code>@FolderPolicy.AllowedRoot</code>.</p>
    }
    @if (folderError is not null)
    {
        <p class="error" role="alert">@folderError</p>
    }
    @if (savedNote is not null)
    {
        <p class="chat-reply" role="status">@savedNote</p>
    }

    <p class="@(configured ? "muted" : "error")">@FolderStatus</p>

    <div class="review-actions">
        <button @onclick="ScanNow" disabled="@(scanning || !configured)">@(scanning ? "Scanning…" : "Scan now")</button>
    </div>
    @if (scanning && scanProgress is not null)
    {
        <p class="muted" role="status" aria-live="polite">@scanProgress</p>
    }
    @if (scanResult is not null)
    {
        <p class="chat-reply" role="status">@scanResult</p>
    }
</section>

<section class="panel">
    <h2>Recipe ingredients → grocery list</h2>
    <p class="muted">
        When you ask the assistant to add a recipe's ingredients to your list (by voice or chat), it adds
        only what you don't already have — and never touches your out/low signals.
    </p>
    <label class="field">
        <span>Before adding</span>
        <select @bind="recipeAddConfirm" @bind:after="SaveRecipeAddConfirm"
                aria-label="Confirm before adding recipe ingredients to the list">
            <option value="Confirm">Ask me to confirm first</option>
            <option value="Auto">Add them automatically</option>
        </select>
    </label>
</section>

<section class="panel danger-zone">
    <h2>Your data</h2>
    <p class="muted">
        Everything ShelfAware knows lives only on this server — nothing is shared. Take a copy any time,
        or wipe the slate clean.
    </p>

    <p><a href="/api/data/export" download>⬇ Download my data (JSON)</a></p>

    @if (!confirmingDelete)
    {
        <div class="review-actions">
            <button class="danger" @onclick="StartDelete">Delete all my data…</button>
        </div>
    }
    else
    {
        <div class="danger-confirm">
            <p><strong>This permanently deletes</strong> your products, purchase history, out/low signals,
               receipts, recipes, substitutes, avoided foods, and grocery list. Your app settings and saved
               API keys are kept (use “Forget my key” above to clear a key).</p>
            <p class="muted">Consider <a href="/api/data/export" download>downloading a backup</a> first — this can’t be undone.</p>
            <label>
                Type <code>DELETE</code> to confirm
                <input type="text" @bind="deleteConfirmText" @bind:event="oninput" autocomplete="off" aria-label="Type DELETE to confirm" />
            </label>
            <div class="review-actions">
                <button class="danger" disabled="@(!DeleteArmed || deleting)" @onclick="DeleteEverything">
                    @(deleting ? "Deleting…" : "Permanently delete everything")
                </button>
                <button class="secondary" disabled="@deleting" @onclick="CancelDelete">Cancel</button>
            </div>
        </div>
    }
    @if (deleteResult is not null)
    {
        <p class="chat-reply" role="status">@deleteResult</p>
    }
</section>

@code {
    // ---- Household panel ----
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private Household? household;
    private IReadOnlyList<HouseholdMember> members = [];
    private string? currentUserId;
    private string householdName = "";
    private bool renaming;
    private bool inviteBusy;
    /// <summary>Checked by default: a code that admits one person is the one you almost always want, and
    /// the wider option should be the one you reach for deliberately.</summary>
    private bool inviteSingleUse = true;
    private string? inviteNote;
    private string? memberNote;
    private string? memberError;
    private string? removingId;
    private bool HouseholdNameChanged =>
        household is not null && householdName.Trim().Length > 0 && householdName.Trim() != household.Name;

    private bool InviteUsable => household?.InviteIsUsable(DateTimeOffset.Now) == true;

    /// <summary>What the code is good for, in the terms someone about to share it cares about: whether it
    /// works, for how long, and for how many people.</summary>
    private string InviteStatus
    {
        get
        {
            if (household?.InviteCode is null) return "";
            // Reachable only by expiry now — spending the last use retires the code itself, so a used-up
            // code isn't a code any more and the panel shows the no-code branch instead.
            if (!InviteUsable) return "This code can't be used any more — replace it to invite someone.";

            // Each clause carries its own verb so any combination reads as a sentence.
            var parts = new List<string>();
            if (household.InviteExpiresAt is { } expires)
            {
                var days = (int)Math.Ceiling((expires - DateTimeOffset.Now).TotalDays);
                parts.Add(days <= 1 ? "expires today" : $"expires in {days} days");
            }
            if (household.InviteUsesRemaining is { } left)
            {
                parts.Add(left == 1 ? "has one use left" : $"has {left} uses left");
            }
            return parts.Count == 0
                ? "This code doesn't expire and can be used any number of times."
                : "This code " + string.Join(" and ", parts) + ".";
        }
    }

    private string folder = "";
    private ImportMode mode = ImportMode.Smart;
    private string recipeAddConfirm = "Confirm";
    private bool configured;
    private int fileCount;
    private int newCount;
    private bool saving;
    private bool scanning;
    private string? savedNote;
    private string? folderError;
    private string? scanResult;
    private string? scanProgress;

    private bool confirmingDelete;
    private string deleteConfirmText = "";
    private bool deleting;
    private string? deleteResult;
    private bool DeleteArmed => string.Equals(deleteConfirmText.Trim(), "DELETE", StringComparison.Ordinal);

    // ---- BYOK: provider, keys, and models, held only in the visitor's browser ----
    private bool aiLoaded;
    private string provider = "Anthropic";
    private string apiKey = "";
    private string baseUrl = "";
    private string extractionModel = "";
    private string chatModel = "";
    private string elKey = "";
    private string elAgentId = "";
    private bool sessionOnly;
    private bool savingKeys;
    private string? keyNote;
    // ---- Hands-free listening calibration ------------------------------------------------------

    private enum CalibrationStage { Idle, Quiet, Command, Question, Working }

    private IJSObjectReference? earModule;
    private CalibrationStage calibrationStage = CalibrationStage.Idle;
    private string? calibrationError;
    private ListeningSettings listening = ListeningSettings.Default;
    private bool calibrated;

    /// <summary>What the last run in THIS visit actually measured, so the wizard can show its working
    /// rather than silently swapping numbers the user has no baseline for. Null until they run it.</summary>
    private CalibrationSample? lastCalibration;

    private static bool Changed(int value, int fallback) => value != fallback;
    private static bool Changed(double value, double fallback) => Math.Abs(value - fallback) > 0.05;

    // Generous on purpose: a calibration that gave up after the CURRENT silence window could never
    // observe a pause longer than it, which is exactly the speaker it most needs to measure. And the
    // provisional gate has to be loose — we don't yet know what this room sounds like, which is the
    // whole point of asking.
    private const int CalibrationEndSilenceMs = 2500;
    private const int CalibrationWaitMs = 10000;
    private const int CalibrationCapMs = 20000;
    private const double ProvisionalFloorMultiple = 2.5;

    private string CalibrationPrompt => calibrationStage switch
    {
        CalibrationStage.Quiet => "Listening to the room — stay quiet for a moment…",
        CalibrationStage.Command => "Now say “next”, the way you would while cooking.",
        CalibrationStage.Question => "Now ask a question — say “can I use butter instead of oil?”",
        CalibrationStage.Working => "Working it out…",
        _ => "",
    };

    private async Task<IJSObjectReference> EarAsync() =>
        earModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "/js/cooklisten.js");

    private async Task LoadListeningAsync()
    {
        try
        {
            var ear = await EarAsync();
            var stored = await ear.InvokeAsync<ListeningSettings?>("loadSettings");
            calibrated = stored is not null;
            listening = (stored ?? ListeningSettings.Default).Clamped();
        }
        catch (JSException ex)
        {
            // A browser that can't read its own storage isn't a reason to break the page.
            Logger.LogInformation(ex, "Couldn't read the listening calibration.");
        }
    }

    /// <summary>
    /// Measure the room, then a command, then a question. The question matters most: it's the only way to
    /// learn how long THIS person pauses mid-sentence, which is the number that decides whether we cut
    /// them off — and the one nobody can guess on their behalf.
    /// </summary>
    private async Task CalibrateAsync()
    {
        // The rendered UI hides the button once we leave Idle, but a second click can land before that
        // render does — and two calibrations would fight over one microphone: the module's stream and
        // analyser are single globals, so the second overwrites the first's, and the first's cleanup then
        // tears down the session the second is still measuring with.
        if (calibrationStage is not CalibrationStage.Idle) return;

        calibrationError = null;
        var ear = await EarAsync();

        if (!await ear.InvokeAsync<bool>("isSupported"))
        {
            calibrationError = "This browser can't listen.";
            return;
        }

        var session = await ear.InvokeAsync<MicSession>("startSession");
        if (!session.Ok)
        {
            calibrationError = session.Error == "NotAllowedError"
                ? "No microphone access — allow it and try again."
                : "Couldn't open the microphone.";
            return;
        }

        try
        {
            calibrationStage = CalibrationStage.Quiet;
            StateHasChanged();
            var floor = await ear.InvokeAsync<double>("measureFloor", 3000);

            var gate = Math.Max(floor * ProvisionalFloorMultiple, 0.01);

            calibrationStage = CalibrationStage.Command;
            StateHasChanged();
            await ear.InvokeVoidAsync("beep", true);
            var command = await MeasureAsync(ear, gate);

            calibrationStage = CalibrationStage.Question;
            StateHasChanged();
            await ear.InvokeVoidAsync("beep", true);
            var question = await MeasureAsync(ear, gate);

            calibrationStage = CalibrationStage.Working;
            StateHasChanged();
            await ear.InvokeVoidAsync("beep", false);

            // Both samples describe the same voice — take the widest of each, since the settings have to
            // accommodate their longest pause and wordiest question, not their average one.
            var sample = new CalibrationSample(
                NoiseFloor: floor,
                SpeechPeak: Math.Max(command.Peak, question.Peak),
                LongestPauseMs: Math.Max(command.LongestPauseMs, question.LongestPauseMs),
                LongestUtteranceMs: Math.Max(command.UtteranceMs, question.UtteranceMs));

            if (!ListeningSettings.TryFromCalibration(sample, out var tuned))
            {
                // Refusing to conclude is the honest outcome: a gate guessed from a mic that heard nothing
                // either never opens or never closes, and they'd have no idea why.
                calibrationError = "I didn't hear you clearly enough to calibrate — nothing changed. "
                                   + "Check the microphone and try again, a little closer.";
                return;
            }

            if (!await ear.InvokeAsync<bool>("saveSettings", tuned))
            {
                calibrationError = "Couldn't save the calibration — this browser is blocking storage.";
                return;
            }

            listening = tuned;
            calibrated = true;
            lastCalibration = sample;
            Logger.LogInformation(
                "Listening calibrated: floor {Floor}, peak {Peak}, longest pause {Pause}ms -> silence {Silence}ms, gate {Gate}x.",
                sample.NoiseFloor, sample.SpeechPeak, sample.LongestPauseMs, tuned.SilenceMs, tuned.FloorMultiple);
        }
        catch (JSException ex)
        {
            Logger.LogWarning(ex, "Listening calibration failed.");
            calibrationError = "The microphone stopped responding — nothing changed.";
        }
        finally
        {
            calibrationStage = CalibrationStage.Idle;
            try { await ear.InvokeVoidAsync("endSession"); }
            catch (JSException) { /* already gone */ }
            StateHasChanged();
        }
    }

    private static async Task<UtteranceSample> MeasureAsync(IJSObjectReference ear, double gate) =>
        await ear.InvokeAsync<UtteranceSample>(
            "measureUtterance", gate, CalibrationWaitMs, CalibrationEndSilenceMs, CalibrationCapMs);

    private async Task ResetCalibrationAsync()
    {
        try
        {
            await (await EarAsync()).InvokeVoidAsync("clearSettings");
            listening = ListeningSettings.Default;
            calibrated = false;
            calibrationError = null;
            lastCalibration = null;
        }
        catch (JSException ex)
        {
            Logger.LogInformation(ex, "Couldn't clear the listening calibration.");
        }
    }

    private sealed record MicSession(bool Ok, string? Error, double Floor);
    private sealed record UtteranceSample(bool Spoke, double Peak, int LongestPauseMs, int UtteranceMs);

    /// <summary>
    /// Put the microphone down when the page goes. Navigating away mid-calibration doesn't stop the wizard
    /// — it's a detached task — so without this the browser's recording indicator stays lit on whatever
    /// page they went to, until a measurement happens to time out. That's alarming, and rightly so; the
    /// reader gets this right and this page shouldn't be the exception. Also releases the JS references,
    /// which were leaking per visit.
    /// </summary>
    public async ValueTask DisposeAsync()
    {
        calibrationStage = CalibrationStage.Idle;

        if (earModule is not null)
        {
            try
            {
                await earModule.InvokeVoidAsync("endSession");
                await earModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { /* circuit gone — the browser released the mic with it */ }
            catch (JSException ex) { Logger.LogInformation(ex, "Couldn't close the calibration microphone."); }
        }

        if (aiModule is not null)
        {
            try { await aiModule.DisposeAsync(); }
            catch (JSDisconnectedException) { /* circuit gone */ }
        }
    }

    private IJSObjectReference? aiModule;

    // Each provider's config is remembered so switching providers doesn't wipe the other's key/models.
    private readonly Dictionary<string, ProviderConfig> providerConfigs = new(StringComparer.OrdinalIgnoreCase);

    private sealed class ProviderConfig
    {
        public string ApiKey { get; set; } = "";
        public string BaseUrl { get; set; } = "";
        public string ExtractionModel { get; set; } = "";
        public string ChatModel { get; set; } = "";
    }

    // Curated defaults, but the fields are editable (datalist) so a stale list never boxes you in.
    private static readonly string[] AnthropicModels = ["claude-haiku-4-5-20251001", "claude-sonnet-5", "claude-opus-4-8"];
    private static readonly string[] OpenAiModels = ["gpt-4o-mini", "gpt-4o"];
    private static readonly string[] LocalModels = ["llama3.1", "qwen2.5", "mistral", "phi3"];
    private static string[] ModelsFor(string p) => p switch
    {
        _ when string.Equals(p, "OpenAI", StringComparison.OrdinalIgnoreCase) => OpenAiModels,
        _ when string.Equals(p, "OpenAICompatible", StringComparison.OrdinalIgnoreCase) => LocalModels,
        _ => AnthropicModels,
    };
    private bool IsLocal => string.Equals(provider, "OpenAICompatible", StringComparison.OrdinalIgnoreCase);
    private string ProviderLabel => provider switch
    {
        _ when string.Equals(provider, "OpenAI", StringComparison.OrdinalIgnoreCase) => "OpenAI",
        _ when IsLocal => "Local",
        _ => "Anthropic",
    };

    // localStorage/interop shapes (mirror wwwroot/js/ai-settings.js).
    private sealed record StoredAi(string Provider, Dictionary<string, StoredProvider>? Providers, StoredEleven? ElevenLabs);
    private sealed record StoredProvider(string? ApiKey, string? ExtractionModel, string? ChatModel, string? BaseUrl);
    private sealed record StoredEleven(string? ApiKey, string? AgentId);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            aiModule = await JS.InvokeAsync<IJSObjectReference>("import", "/js/ai-settings.js");
            var stored = await aiModule.InvokeAsync<StoredAi?>("load");
            sessionOnly = await aiModule.InvokeAsync<bool>("isSessionOnly");
            if (stored is not null)
            {
                if (!string.IsNullOrWhiteSpace(stored.Provider)) provider = stored.Provider;
                if (stored.Providers is not null)
                {
                    foreach (var (name, cfg) in stored.Providers)
                        providerConfigs[name] = new ProviderConfig
                        {
                            ApiKey = cfg.ApiKey ?? "",
                            BaseUrl = cfg.BaseUrl ?? "",
                            ExtractionModel = cfg.ExtractionModel ?? "",
                            ChatModel = cfg.ChatModel ?? "",
                        };
                }
                if (stored.ElevenLabs is not null)
                {
                    elKey = stored.ElevenLabs.ApiKey ?? "";
                    elAgentId = stored.ElevenLabs.AgentId ?? "";
                }
            }
            LoadProviderFields();
        }
        catch (JSDisconnectedException) { /* circuit gone mid-load */ }
        catch (Exception ex) { Logger.LogWarning(ex, "Couldn't load BYOK settings on the Settings page."); }

        // Separate store, separate concern: this one is per-device and isn't a secret, so it survives a
        // Forget-my-key and the session-only toggle.
        await LoadListeningAsync();

        aiLoaded = true;
        StateHasChanged();
    }

    private void OnProviderChanged() => LoadProviderFields();

    // Show the selected provider's remembered config (or its default model when nothing's saved yet).
    private void LoadProviderFields()
    {
        var cfg = providerConfigs.GetValueOrDefault(provider) ?? new ProviderConfig();
        apiKey = cfg.ApiKey;
        baseUrl = cfg.BaseUrl;
        extractionModel = string.IsNullOrWhiteSpace(cfg.ExtractionModel) ? ModelsFor(provider)[0] : cfg.ExtractionModel;
        chatModel = string.IsNullOrWhiteSpace(cfg.ChatModel) ? ModelsFor(provider)[0] : cfg.ChatModel;
    }

    private async Task SaveKeys()
    {
        if (aiModule is null || savingKeys) return;
        savingKeys = true;
        keyNote = null;
        try
        {
            // Snapshot the current provider's fields into the remembered map, then persist everything.
            providerConfigs[provider] = new ProviderConfig
            {
                ApiKey = apiKey.Trim(),
                BaseUrl = baseUrl.Trim(),
                ExtractionModel = extractionModel.Trim(),
                ChatModel = chatModel.Trim(),
            };
            var payload = new StoredAi(
                provider,
                providerConfigs.ToDictionary(
                    kv => kv.Key,
                    kv => new StoredProvider(kv.Value.ApiKey, kv.Value.ExtractionModel, kv.Value.ChatModel, kv.Value.BaseUrl),
                    StringComparer.OrdinalIgnoreCase),
                new StoredEleven(elKey.Trim(), elAgentId.Trim()));

            var ok = await aiModule.InvokeAsync<bool>("save", payload, sessionOnly);
            if (!ok) { keyNote = "Your browser wouldn't save the settings (storage may be disabled)."; return; }

            // Apply to THIS circuit immediately so the assistant works without a reload.
            var p = Enum.TryParse<AiProvider>(provider, ignoreCase: true, out var parsed) ? parsed : AiProvider.Anthropic;
            AiSettings.Apply(p, apiKey.Trim(), extractionModel.Trim(), chatModel.Trim(), baseUrl.Trim());
            keyNote = string.IsNullOrWhiteSpace(apiKey)
                ? "Saved. Add a key to start using the assistant."
                : sessionOnly ? "Saved for this session — cleared when you close the tab." : "Saved in this browser.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Saving BYOK settings failed.");
            keyNote = "Couldn't save just now — please try again.";
        }
        finally { savingKeys = false; }
    }

    private async Task ForgetKeys()
    {
        if (aiModule is null || savingKeys) return;
        savingKeys = true;
        try
        {
            await aiModule.InvokeVoidAsync("clear");
            providerConfigs.Clear();
            apiKey = elKey = elAgentId = "";
            LoadProviderFields();
            AiSettings.Reset(); // this circuit falls back to the server config (empty on a public deploy)
            keyNote = "Cleared — your keys are no longer stored in this browser.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Forgetting BYOK settings failed.");
            keyNote = "Couldn't clear just now — please try again.";
        }
        finally { savingKeys = false; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadHouseholdAsync();
        // Usage is recorded in every key mode now (BYOK included), so the readouts always load.
        todayUsage = await UsageMeter.GetTodayAsync();
        usageHistory = await UsageMeter.GetRecentAsync(days: 14);
        folder = await SettingsStore.GetAsync(SettingKeys.ReceiptFolder) ?? "";
        mode = ImportModes.Parse(
            await SettingsStore.GetAsync(SettingKeys.ImportMode),
            await SettingsStore.GetAsync(SettingKeys.AutoConfirmImports)); // legacy toggle honored
        recipeAddConfirm = await SettingsStore.GetAsync(SettingKeys.RecipeAddConfirm) ?? "Confirm";
        await RefreshStatus();
    }

    // ---- AI usage readouts (recorded in every key mode; limits apply only in managed mode) ----
    private AiUsageMeter.TodayUsage? todayUsage;
    private IReadOnlyList<AiUsageMeter.DayUsage> usageHistory = [];
    private string UsageLimitSuffix => LlmConfig.Value.DailyCallLimit is int limit
        ? $" (daily allowance: {limit} calls)"
        : "";

    private async Task LoadHouseholdAsync()
    {
        if (AuthState is null) return;
        var user = (await AuthState).User;
        var householdId = user.FindFirst(HouseholdClaimsPrincipalFactory.HouseholdClaim)?.Value;
        if (householdId is null) return;
        currentUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        household = await Households.GetAsync(householdId);
        members = await Households.GetMembersAsync(householdId);
        householdName = household?.Name ?? "";
    }

    private async Task RemoveMember(HouseholdMember member)
    {
        if (household is null || currentUserId is null || removingId is not null) return;
        if (!await JS.InvokeAsync<bool>("confirm",
            $"Remove {member.Email} from this household? They'll lose access to the pantry within a few minutes."))
        {
            return;
        }

        removingId = member.Id;
        memberNote = null;
        memberError = null;
        try
        {
            var refused = await Households.RemoveMemberAsync(household.Id, member.Id, currentUserId);
            if (refused is not null)
            {
                memberError = refused;
            }
            else
            {
                memberNote = $"{member.Email} is no longer in this household.";
            }
            members = await Households.GetMembersAsync(household.Id);
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Removing a member from household {HouseholdId} failed.", household.Id);
            memberError = "Couldn't remove them just now — please try again.";
        }
        finally
        {
            removingId = null;
        }
    }

    private async Task RenameHousehold()
    {
        if (household is null || !HouseholdNameChanged || renaming) return;
        renaming = true;
        try
        {
            await Households.RenameAsync(household.Id, householdName);
            household.Name = householdName.Trim();
            inviteNote = "Household renamed.";
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Renaming the household failed.");
            inviteNote = "Couldn't rename just now — please try again.";
        }
        finally
        {
            renaming = false;
        }
    }

    private async Task CopyInvite()
    {
        if (household?.InviteCode is null) return;
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", household.InviteCode);
        inviteNote = "Invite code copied to the clipboard.";
    }

    private async Task GenerateInvite()
    {
        if (household is null || inviteBusy) return;
        var replacing = household.InviteCode is not null;
        inviteBusy = true;
        try
        {
            // Re-read rather than patching the code onto the local copy: generating sets the expiry and
            // resets the use count too, and the panel reports all three.
            household = await Households.GenerateInviteCodeAsync(household.Id, inviteSingleUse ? 1 : null);
            inviteNote = replacing
                ? "New invite code generated — the old one no longer works."
                : "Invite code generated — it works until it's used, or you clear it.";
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Generating an invite code failed.");
            inviteNote = "Couldn't generate a code just now — please try again.";
        }
        finally
        {
            inviteBusy = false;
        }
    }

    private async Task ClearInvite()
    {
        if (household?.InviteCode is null || inviteBusy) return;
        inviteBusy = true;
        try
        {
            household = await Households.ClearInviteCodeAsync(household.Id);
            inviteNote = "Invite code cleared — nobody can join until you generate a new one.";
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Clearing the invite code failed.");
            inviteNote = "Couldn't clear the code just now — please try again.";
        }
        finally
        {
            inviteBusy = false;
        }
    }

    private async Task SetMode(ImportMode m)
    {
        mode = m;
        await SettingsStore.SetAsync(SettingKeys.ImportMode, m.ToString());
    }

    private async Task SaveRecipeAddConfirm() =>
        await SettingsStore.SetAsync(SettingKeys.RecipeAddConfirm, recipeAddConfirm);

    private string FolderStatus => !configured
        ? (string.IsNullOrWhiteSpace(folder) ? "No folder set yet." : "That folder isn't set or doesn't exist yet.")
        : $"{fileCount} receipt file(s) in the folder · {newCount} not yet imported.";

    private async Task RefreshStatus()
    {
        configured = await Inbox.IsConfiguredAsync();
        if (!configured) { fileCount = 0; newCount = 0; return; }

        var items = await Inbox.ListAsync();
        fileCount = items.Count;
        await using var db = await DbFactory.CreateDbContextAsync();
        var imported = (await db.Receipts.Where(r => r.SourceFile != null).Select(r => r.SourceFile!).ToListAsync())
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        newCount = items.Count(i => !imported.Contains(i.Id));
    }

    private async Task SaveFolder()
    {
        saving = true;
        savedNote = null;
        folderError = null;
        scanResult = null;
        try
        {
            // Refused here so the user gets a sentence they can act on. The inbox refuses it again when it
            // actually reads — that's the boundary; this is the manners.
            if (FolderPolicy.Reject(folder) is { } why)
            {
                folderError = why;
                return;
            }
            await SettingsStore.SetAsync(SettingKeys.ReceiptFolder, folder.Trim());
            await RefreshStatus();
            savedNote = "Saved.";
        }
        finally
        {
            saving = false;
        }
    }

    private async Task ScanNow()
    {
        scanning = true;
        scanResult = null;
        scanProgress = null;
        try
        {
            // Blazor Server: Progress<T> marshals each report back onto the circuit's sync context, so the
            // live per-receipt line updates as the scan works through the folder rather than jumping from a
            // blank spinner straight to the summary.
            var progress = new Progress<ImportProgress>(p =>
            {
                scanProgress = p.Total > 1
                    ? $"Reading {p.CurrentFile} — {p.Current} of {p.Total}…"
                    : $"Reading {p.CurrentFile}…";
                InvokeAsync(StateHasChanged);
            });
            var summary = await Importer.ImportNewAsync(progress);
            scanResult = summary.Describe();
            await RefreshStatus();
        }
        finally
        {
            scanning = false;
            scanProgress = null;
        }
    }

    private void StartDelete()
    {
        confirmingDelete = true;
        deleteResult = null;
        deleteConfirmText = "";
    }

    private void CancelDelete()
    {
        confirmingDelete = false;
        deleteConfirmText = "";
    }

    private async Task DeleteEverything()
    {
        if (!DeleteArmed || deleting) return;
        deleting = true;
        deleteResult = null;
        try
        {
            await UserData.DeleteAllAsync();
            deleteResult = "Done — all your pantry data has been deleted.";
            confirmingDelete = false;
            deleteConfirmText = "";
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Delete-my-data failed.");
            deleteResult = "Something went wrong deleting your data — please try again.";
        }
        finally
        {
            deleting = false;
        }
    }
