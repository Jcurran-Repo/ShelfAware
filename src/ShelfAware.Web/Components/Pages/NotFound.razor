@page "/not-found"
@layout MainLayout
@* Anonymous: the status-code re-execute must not bounce a signed-out visitor's 404 into a login loop. *@
@attribute [AllowAnonymous]

<PageTitle>Not found — Shelf Aware</PageTitle>

<div class="page-head">
    <h1>Page not found</h1>
</div>
<p class="muted">Sorry — that page doesn't exist. It may have moved, or the link was mistyped.</p>
<p><a href="/">← Back to the dashboard</a></p>
