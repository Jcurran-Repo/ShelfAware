@page "/receipts"
@using ShelfAware.Core.Evaluation
@using ShelfAware.Core.Shopping
@implements IAsyncDisposable
@inject IHouseholdDbFactory DbFactory
@inject ReceiptStorage Storage
@inject ReceiptRemovalService Removal
@inject IJSRuntime JS
@inject ILogger<Receipts> Logger

<PageTitle>Receipts — Shelf Aware</PageTitle>

<div class="page-head">
    <h1>Receipts</h1>
    @if (receipts is not null)
    {
        <span class="muted">@receipts.Count receipt@(receipts.Count == 1 ? "" : "s")</span>
    }
</div>
<p class="muted">
    Every receipt the pantry has learned from — when it was, and what it cost. Totals are summed from
    the extracted line items (unit price × quantity), so a multi-quantity line can drift from the
    printed total by a cent or two.
</p>

@if (loadError is not null)
{
    <p class="error" role="alert">@loadError</p>
}
else if (receipts is null)
{
    <p>Loading…</p>
}
else if (receipts.Count == 0)
{
    <section class="panel">
        <p class="muted">No receipts yet. <a href="/receipt">Upload one</a> and it'll show up here.</p>
    </section>
}
else
{
    @foreach (var row in receipts)
    {
        <section class="panel receipt-card">
            <details>
                <summary>
                    <span class="receipt-date">@(row.Receipt.PurchasedAt is { } d ? d.ToString("MMM d, yyyy") : "Date unknown")</span>
                    <span class="muted">@(row.Receipt.Merchant is { Length: > 0 } m ? m : "Unknown merchant") · @row.Summary.LineCount item@(row.Summary.LineCount == 1 ? "" : "s")</span>
                    @if (row.Receipt.Status == ReceiptStatus.PendingReview)
                    {
                        <span class="chip chip-duesoon">Pending review</span>
                    }
                    @if (row.Receipt.VerifiedForEval)
                    {
                        <span class="chip chip-stocked" title="You verified every line — graded by the accuracy check">✓ Accuracy check</span>
                    }
                    <span class="receipt-total">@row.Summary.Total.ToString("C")</span>
                </summary>

                @if (row.Receipt.Status == ReceiptStatus.PendingReview)
                {
                    <p class="muted">This receipt is still awaiting review — confirm it on the
                    <a href="/receipt">Upload page</a> before its purchases count.</p>
                }
                <table>
                    <caption class="visually-hidden">Line items for the @(row.Receipt.PurchasedAt?.ToString("MMMM d, yyyy") ?? "undated") receipt: item, quantity, size, unit price, and line total.</caption>
                    <thead>
                        <tr>
                            <th scope="col">Item</th>
                            <th scope="col">Qty</th>
                            <th scope="col">Size</th>
                            <th scope="col">Unit price</th>
                            <th scope="col">Line total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in row.Receipt.Lines.OrderBy(l => l.Id))
                        {
                            <tr>
                                <td title="@line.RawText">
                                    @if (line.ProductId is { } pid)
                                    {
                                        <a href="/product/@pid">@line.NormalizedName</a>
                                    }
                                    else
                                    {
                                        @line.NormalizedName
                                    }
                                    @if (line.Brand is { Length: > 0 } brand)
                                    {
                                        <span class="muted"> · @brand</span>
                                    }
                                </td>
                                <td>@line.Quantity.ToString("0.##")</td>
                                <td>@(SizeFormat.Normalize(line.Size) is { Length: > 0 } size ? size : "—")</td>
                                <td>@(line.UnitPrice is { } up ? up.ToString("C") : "—")</td>
                                <td>@(ReceiptTotals.LineTotal(line) is { } lt ? lt.ToString("C") : "—")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="4" class="subtotal-label">Total@(row.Summary.UnpricedLines > 0 ? $" ({row.Summary.UnpricedLines} line{(row.Summary.UnpricedLines == 1 ? "" : "s")} without a price)" : "")</td>
                            <td class="subtotal">@row.Summary.Total.ToString("C")</td>
                        </tr>
                    </tfoot>
                </table>
                @if (row.Receipt.Status == ReceiptStatus.Confirmed)
                {
                    <div class="receipt-eval-actions">
                        @if (row.Receipt.VerifiedForEval)
                        {
                            <button class="secondary" @onclick="() => SetVerifiedAsync(row, false)">Stop using for accuracy checks</button>
                            <button class="secondary" @onclick="() => ExportFixtureAsync(row)">Export fixture labels</button>
                            <span class="muted">Graded by “Your receipts” on the <a href="/accuracy">Accuracy page</a>.</span>
                        }
                        else if (row.HasImage)
                        {
                            <button class="secondary" @onclick="() => SetVerifiedAsync(row, true)">✓ I checked every line — use for accuracy checks</button>
                            <span class="muted">Only mark it verified if you've actually read each line above.</span>
                        }
                        else
                        {
                            <span class="muted">No saved image for this receipt, so it can't be re-read for an accuracy check.</span>
                        }
                    </div>
                    <div class="receipt-remove-actions">
                        @if (!row.Removable)
                        {
                            <span class="muted">Recorded before ShelfAware tracked which purchases came from which
                            receipt, so it can't be removed as a unit — adjust its purchases from each product's page.</span>
                        }
                        else if (removingId != row.Receipt.Id)
                        {
                            <button class="secondary" @onclick="() => StartRemove(row.Receipt.Id)" disabled="@removeBusy">
                                Remove receipt…
                            </button>
                        }
                        else
                        {
                            <span class="error">Removes this receipt <strong>and everything it recorded</strong> —
                            its purchases, any products it introduced that gathered no other history, and the
                            merchant matches it taught. This can't be undone.</span>
                            <button @onclick="() => RemoveAsync(row)" disabled="@removeBusy">@(removeBusy ? "Removing…" : "Remove it")</button>
                            <button class="secondary" @onclick="CancelRemove" disabled="@removeBusy">Cancel</button>
                        }
                    </div>
                }
            </details>
        </section>
    }
    @if (removeResult is not null)
    {
        <p class="chat-reply" role="status">@removeResult</p>
    }
    @if (removeError is not null)
    {
        <p class="error" role="alert">@removeError</p>
    }
}

@code {
    private List<ReceiptRow>? receipts;
    private string? loadError;
    private IJSObjectReference? downloadModule;

    // Receipt is the tracked mutable entity so the verify toggle can flip in place; HasImage gates
    // verification — a receipt with no audit copy (e.g. demo data) can never be re-read for grading.
    // Removable = its purchases carry provenance (ReceiptId), so "remove everything it did" is safe.
    private sealed record ReceiptRow(Receipt Receipt, ReceiptTotal Summary, bool HasImage, bool Removable);

    private int? removingId;      // the row whose inline remove-confirm is open
    private bool removeBusy;
    private string? removeResult;
    private string? removeError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var loaded = await db.Receipts
                .AsNoTracking() // read-only list; the verify toggle writes via ExecuteUpdate
                .Where(r => r.Status != ReceiptStatus.Discarded)
                .Include(r => r.Lines)
                .ToListAsync();

            // One query answers "which receipts can be removed as a unit": those with provenance-
            // stamped purchases. Confirms before the stamp existed aren't traceable and say so.
            var traceable = (await db.PurchaseEvents
                    .Where(p => p.ReceiptId != null)
                    .Select(p => p.ReceiptId!.Value)
                    .Distinct()
                    .ToListAsync())
                .ToHashSet();

            receipts = loaded
                .Select(r => new ReceiptRow(r, ReceiptTotals.Summarize(r.Lines), HasAuditImage(r),
                    traceable.Contains(r.Id)))
                .OrderByDescending(row => row.Receipt.PurchasedAt ?? DateOnly.MinValue)
                .ThenByDescending(row => row.Receipt.Id)
                .ToList();
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load receipts");
            loadError = "Couldn't load receipts — try reloading the page.";
        }
    }

    private void StartRemove(int receiptId)
    {
        removingId = receiptId;
        removeResult = null;
        removeError = null;
    }

    private void CancelRemove() => removingId = null;

    private async Task RemoveAsync(ReceiptRow row)
    {
        if (removeBusy) return;
        removeBusy = true;
        removeError = null;
        try
        {
            var outcome = await Removal.RemoveAsync(row.Receipt.Id);
            if (!outcome.Found)
            {
                removeError = "That receipt no longer exists — reload the page.";
                return;
            }
            if (outcome.Untraceable)
            {
                removeError = "This receipt's purchases can't be safely identified, so nothing was removed.";
                return;
            }
            receipts?.Remove(row);
            removeResult = $"Removed the receipt and its {outcome.Purchases} purchase{(outcome.Purchases == 1 ? "" : "s")}" +
                (outcome.ProductsRemoved > 0 ? $", plus {outcome.ProductsRemoved} product{(outcome.ProductsRemoved == 1 ? "" : "s")} it introduced" : "") +
                (outcome.ProductsKept > 0 ? $" ({outcome.ProductsKept} kept — they have other history)" : "") +
                (outcome.AliasesRemoved > 0 ? $"; untaught {outcome.AliasesRemoved} merchant match{(outcome.AliasesRemoved == 1 ? "" : "es")}" : "") + ".";
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Removing receipt {ReceiptId} failed.", row.Receipt.Id);
            removeError = "Couldn't remove the receipt — nothing was changed. Try again.";
        }
        finally
        {
            removeBusy = false;
            removingId = null;
        }
    }

    private bool HasAuditImage(Receipt r) => Storage.HasPages(r.ImagePath);

    private async Task SetVerifiedAsync(ReceiptRow row, bool verified)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            await db.Receipts.Where(r => r.Id == row.Receipt.Id)
                .ExecuteUpdateAsync(s => s.SetProperty(r => r.VerifiedForEval, verified));
            row.Receipt.VerifiedForEval = verified;
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Toggling VerifiedForEval on receipt {ReceiptId} failed.", row.Receipt.Id);
            loadError = "Couldn't save the accuracy-check setting — try again.";
        }
    }

    // The confirmed lines ARE the labels — download them in the eval harness's expected.json shape
    // so a receipt can graduate into the committed fixture suite (the image stays private).
    private async Task ExportFixtureAsync(ReceiptRow row)
    {
        var labels = row.Receipt.Lines.OrderBy(l => l.Id).Select(l => new ExpectedLine
        {
            NormalizedName = l.NormalizedName,
            Quantity = l.Quantity,
            Category = l.Category.ToString(),
        }).ToList();
        var json = System.Text.Json.JsonSerializer.Serialize(labels,
            new System.Text.Json.JsonSerializerOptions { WriteIndented = true });

        downloadModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "/js/download.js");
        await downloadModule.InvokeVoidAsync("downloadText", $"{FixtureName(row.Receipt)}.expected.json", json);
    }

    private static string FixtureName(Receipt r)
    {
        var merchant = new string((r.Merchant ?? "receipt").ToLowerInvariant()
            .Select(c => char.IsLetterOrDigit(c) ? c : '-').ToArray()).Trim('-');
        return r.PurchasedAt is { } d ? $"{merchant}-{d:yyyy-MM-dd}" : $"{merchant}-{r.Id}";
    }

    public async ValueTask DisposeAsync()
    {
        if (downloadModule is not null)
        {
            try { await downloadModule.DisposeAsync(); }
            catch (JSDisconnectedException) { } // circuit already gone — nothing to release
        }
    }
}
