@inherits LayoutComponentBase

<header class="site-header @(navOpen ? "nav-open" : null)">
    <span class="brand">Shelf Aware</span>
    @* Mobile-only disclosure for the nav — eight links swamp a phone. display:none on desktop, so
       navOpen (and the nav-open class) can only take effect under the small-screen media query. *@
    <button type="button" class="nav-toggle" @onclick="() => navOpen = !navOpen"
            aria-expanded="@(navOpen ? "true" : "false")" aria-controls="primary-nav"
            aria-label="@(navOpen ? "Close menu" : "Open menu")">
        <span aria-hidden="true">@(navOpen ? "✕" : "☰")</span>
    </button>
    @* A tap on any link both navigates and (via bubbling) folds the mobile menu. *@
    <nav id="primary-nav" aria-label="Primary" @onclick="() => navOpen = false">
        <NavLink href="/" Match="NavLinkMatch.All">Dashboard</NavLink>
        <NavLink href="/list">Grocery List</NavLink>
        <NavLink href="/recipes">Recipes</NavLink>
        <NavLink href="/trends">Trends</NavLink>
        <NavLink href="/receipt">Upload</NavLink>
        <NavLink href="/products">Products</NavLink>
        <NavLink href="/accuracy">Accuracy</NavLink>
        <NavLink href="/settings">Settings</NavLink>
    </nav>
    <AuthorizeView>
        <div class="account-box">
            <a href="Account/Manage/ChangePassword" class="account-email" title="Signed in as @context.User.Identity?.Name">
                @context.User.Identity?.Name
            </a>
            @* A plain HTML POST, not an EditForm: signing out must clear the auth cookie, which only a
               real HTTP request (escaping the circuit) can do. *@
            <form method="post" action="Account/Logout" data-enhance="false">
                <AntiforgeryToken />
                <button type="submit" class="account-signout">Sign out</button>
            </form>
        </div>
    </AuthorizeView>
</header>

<main class="site-main">
    @Body
</main>

@* Pins this circuit's household so detached background work (the voice loop) resolves it without
   an out-of-context auth-state call. Headless; must run inside the authenticated layout. *@
<HouseholdInitializer />

@* Applies the visitor's own BYOK settings (from their browser) to this circuit's AI config. Headless. *@
<AiSettingsLoader />

@* Persistent, always-available voice assistant. In the layout (not a page) so it keeps listening
   across navigation — the key to hands-free command chaining. *@
<VoiceAgent />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool navOpen;
}
