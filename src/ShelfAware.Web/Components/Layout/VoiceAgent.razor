@* Persistent, hands-free voice assistant (v2.2). Lives in MainLayout — NOT in a page — so it survives
   navigation and keeps listening while you move around the app. That's what makes a hands-free chain
   work: "go to the chicken" → (navigates) → "recipes that use it" → (navigates) → "read me the second
   one". Same IPantryChat brain as the dashboard text box + push-to-talk; ElevenLabs is pure I/O.

   Two behaviours distinguish it from the old page-bound conversation:
   • It keeps listening AFTER an open_page navigation (so commands chain), and only stands down on a
     hand-off (read_recipe), where the recipe produces its own audio and the mic would echo it.
   • Because it's no longer a child of the dashboard, it can't call the page's OnApplied to refresh.
     Instead a voice data-change pings VoiceCoordinator.PantryChanged and whatever page is on screen
     reloads; the recipe reader's "Back to assistant" pings ResumeRequested to hand control back here. *@
@using ShelfAware.Core.Chat
@using ShelfAware.Core.Speech
@using ShelfAware.Web.Services
@implements IAsyncDisposable
@inject ISpeechToText Stt
@inject IPantryChat Chat
@inject ITextToSpeech Tts
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject VoiceCoordinator Coordinator
@inject ILogger<VoiceAgent> Log

<aside class="voice-agent @(active ? "is-active" : null)" aria-label="Voice assistant">
    @if (!active)
    {
        <button type="button" class="voice-agent-fab" @onclick="StartFresh"
                disabled="@(_checked && !_supported)"
                aria-label="Start the voice assistant" title="Talk to Shelf Aware — it keeps listening as you move around">
            <span aria-hidden="true">🎙</span><span class="fab-label">Assistant</span>
        </button>
        @if (_checked && !_supported)
        {
            <p class="muted voice-agent-note">Voice input isn't supported in this browser.</p>
        }
        @if (error is not null)
        {
            <p class="error voice-agent-note">@error</p>
        }
    }
    else
    {
        <div class="voice-agent-panel panel">
            <div class="convo-head">
                <strong>🎙 Assistant</strong>
                <button type="button" class="icon-btn" @onclick="End" aria-label="End the conversation" title="End">✕</button>
            </div>
            <div class="convo-log" role="log" aria-live="polite">
                @if (history.Count == 0 && pendingUser is null)
                {
                    <p class="muted">Just talk — it sends when you pause. Try “what am I low on?”, or “go to the chicken, then recipes that use it”.</p>
                }
                @foreach (var turn in history)
                {
                    <p class="convo-user"><span class="who">You</span> @turn.User</p>
                    <p class="convo-bot"><span class="who">Shelf&nbsp;Aware</span> @turn.Assistant</p>
                }
                @if (pendingUser is not null)
                {
                    <p class="convo-user"><span class="who">You</span> @pendingUser</p>
                }
                @if (error is not null)
                {
                    <p class="error">@error</p>
                }
            </div>
            <p class="convo-phase @PhaseClass" role="status" aria-live="polite">@PhaseText</p>
        </div>
    }
</aside>

@code {
    private enum Phase { Listening, Thinking, Speaking }
    private Phase phase = Phase.Listening;

    private IJSObjectReference? _module;
    private bool _supported;
    private bool _checked;
    private bool active;

    private readonly List<ChatTurn> history = [];
    private string? pendingUser;
    private string? error;

    private string PhaseText => phase switch
    {
        Phase.Listening => "🎤 Listening — go ahead",
        Phase.Thinking => "…working",
        Phase.Speaking => "🔊 Speaking…",
        _ => "",
    };

    private string PhaseClass => phase switch
    {
        Phase.Listening => "listening",
        Phase.Speaking => "speaking",
        _ => "muted",
    };

    protected override void OnInitialized() => Coordinator.ResumeRequested += ResumeAsync;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _module = await JS.InvokeAsync<IJSObjectReference>("import", "/js/conversation.js");
        _supported = await _module.InvokeAsync<bool>("isSupported");
        _checked = true;
        StateHasChanged();
    }

    // User tapped the launcher: a brand-new conversation (clear history).
    private Task StartFresh() => StartListeningAsync(resetHistory: true);

    // A surface handed control back ("Back to assistant"): resume WITHOUT wiping context, so a follow-up
    // like "read me another one" still resolves against what was just discussed.
    private Task ResumeAsync() => InvokeAsync(() => StartListeningAsync(resetHistory: false));

    private async Task StartListeningAsync(bool resetHistory)
    {
        if (_module is null || !_supported || active) return;
        if (resetHistory) history.Clear();
        pendingUser = null;
        error = null;
        phase = Phase.Listening;
        active = true;

        bool ok;
        try { ok = await _module.InvokeAsync<bool>("start"); }
        catch { ok = false; }
        if (!ok)
        {
            active = false;
            error = "Couldn't access the microphone — check the browser's mic permission.";
            StateHasChanged();
            return;
        }

        StateHasChanged();
        _ = RunLoopAsync(); // background turn loop; End (or no-speech) stops it
    }

    // Auto turn-taking: capture -> STT -> chat(history) -> TTS -> play -> repeat. Unlike the old
    // page-bound version, a navigation does NOT end the loop unless it's a hand-off (read_recipe) — so
    // the user can keep giving commands as the app navigates under the persistent agent.
    private async Task RunLoopAsync()
    {
        try
        {
            while (active && _module is not null)
            {
                phase = Phase.Listening;
                await InvokeAsync(StateHasChanged);

                VoiceCapture? capture;
                try { capture = await _module.InvokeAsync<VoiceCapture?>("captureTurn"); }
                catch { capture = null; }

                if (!active) break;
                if (capture is null || string.IsNullOrEmpty(capture.Audio))
                    break; // no speech within the window -> wind the conversation down

                phase = Phase.Thinking;
                await InvokeAsync(StateHasChanged);

                var heard = await Stt.TranscribeAsync(new AudioClip(Convert.FromBase64String(capture.Audio), capture.MimeType));
                if (!active) break;
                if (!heard.Success || string.IsNullOrWhiteSpace(heard.Text))
                    continue; // couldn't make it out -> just listen again

                // "Stop listening" ends the session in plain code — instant, free, deterministic; the
                // control phrase never reaches the LLM.
                if (VoiceCommands.IsStop(heard.Text))
                {
                    history.Add(new ChatTurn(heard.Text, "Okay — stopped listening."));
                    phase = Phase.Speaking;
                    await InvokeAsync(StateHasChanged);
                    var bye = await Tts.SynthesizeAsync("Okay — stopped listening.");
                    if (bye.Success)
                        await _module.InvokeVoidAsync("play", Convert.ToBase64String(bye.Audio), bye.MediaType);
                    break;
                }

                pendingUser = heard.Text;
                await InvokeAsync(StateHasChanged);

                // Pass what the user is currently looking at so "the second one"/"that one" resolve.
                var result = await Chat.HandleAsync(heard.Text, history, Coordinator.ScreenContext);
                history.Add(new ChatTurn(heard.Text, result.Reply));
                pendingUser = null;
                // A data change (mark out, add purchase) with no navigation: refresh whatever page is on
                // screen. On a navigation the destination page loads fresh, so no ping is needed.
                if (result.Success && result.NavigateTo is null)
                    await Coordinator.NotifyPantryChangedAsync();
                await InvokeAsync(StateHasChanged);
                if (!active) break;

                phase = Phase.Speaking;
                await InvokeAsync(StateHasChanged);
                var speech = await Tts.SynthesizeAsync(result.Reply);
                if (!active) break;
                if (speech.Success)
                    await _module.InvokeVoidAsync("play", Convert.ToBase64String(speech.Audio), speech.MediaType);

                if (result.Success && result.NavigateTo is { } url)
                {
                    Nav.NavigateTo(url);
                    // Hand-off (read_recipe): the reader speaks the recipe, so we stand down to avoid
                    // echoing it. Plain navigation (open_page): keep listening on the new page to chain.
                    if (result.HandsOff) break;
                }
            }
        }
        catch (Exception ex)
        {
            error = "The conversation hit a snag and ended — tap to start it again.";
            Log.LogError(ex, "Voice agent loop failed.");
        }
        finally
        {
            await EndInternal();
        }
    }

    private Task End() => EndInternal();

    private async Task EndInternal()
    {
        active = false;
        pendingUser = null;
        phase = Phase.Listening;
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("stop"); } catch { /* circuit gone */ }
        }
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        Coordinator.ResumeRequested -= ResumeAsync;
        active = false;
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("stop"); await _module.DisposeAsync(); }
            catch { /* circuit already gone */ }
        }
    }

    private sealed record VoiceCapture(string Audio, string MimeType);
}
