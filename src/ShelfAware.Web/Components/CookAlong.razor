@* Hands-free recipe cook-along (Phase 4b). Opens a realtime ElevenLabs agent conversation (via a
   server-minted signed URL) with the recipe injected as a dynamic variable. The agent reads steps and
   responds to spoken "next / back / repeat / stop" WHILE listening — native barge-in, no tap needed.
   This is the one surface where we hand the loop to ElevenLabs' agent on purpose; the pantry brain
   stays ours (the VoiceAgent / IPantryChat loop). *@
@using ShelfAware.Core.Domain
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject VoiceCoordinator Coordinator

<div class="cookalong panel">
    <div class="ra-head">
        <h3>🎙 Cook-along: @Recipe.Name</h3>
        <div class="ra-head-actions">
            <button class="secondary" @onclick="BackToAssistantAsync"
                    aria-label="End cook-along and hand back to the voice assistant" title="End cook-along and talk to the assistant">🎤 Back to assistant</button>
            <button class="icon-btn" @onclick="CloseAsync" aria-label="End cook-along" title="End cook-along">✕</button>
        </div>
    </div>

    <p class="cookalong-status @StatusClass" role="status" aria-live="polite">@StatusText</p>

    @if (transcript.Count > 0)
    {
        <div class="convo-log">
            @foreach (var line in transcript)
            {
                <p class="@(line.Source == "user" ? "convo-user" : "convo-bot")">
                    <span class="who">@(line.Source == "user" ? "You" : "Chef")</span> @line.Text
                </p>
            }
        </div>
    }

    <p class="muted small">Say “next”, “back”, “repeat”, “stop”, or “go to the assistant”. Just talk — it listens while it speaks.</p>
</div>

@code {
    [Parameter, EditorRequired] public Recipe Recipe { get; set; } = null!;
    [Parameter] public EventCallback OnClosed { get; set; }
    /// <summary>Raised when the live session can't start (misconfigured or couldn't connect), so the
    /// parent can recover — the voice chain falls back to the plain reader instead of dead-ending.</summary>
    [Parameter] public EventCallback OnUnavailable { get; set; }

    private IJSObjectReference? _module;
    private DotNetObjectReference<CookAlong>? _selfRef;

    private string status = "connecting";
    private string mode = "listening";
    private bool _notifiedUnavailable;
    private readonly List<(string Source, string Text)> transcript = [];

    private string StatusText => status switch
    {
        "connecting" => "Connecting…",
        "connected" => mode == "speaking" ? "Chef is speaking…" : "Listening — go ahead",
        "unconfigured" => "Hands-free cook-along isn't set up on the server.",
        "error" => "Couldn't start the cook-along — check your connection and mic permission.",
        "ended" => "Cook-along ended.",
        _ => "…",
    };

    private string StatusClass => status switch
    {
        "error" or "unconfigured" => "error",
        "connected" => mode == "speaking" ? "speaking" : "listening",
        _ => "muted",
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _module = await JS.InvokeAsync<IJSObjectReference>("import", "/js/cookalong.js");
        _selfRef = DotNetObjectReference.Create(this);
        await _module.InvokeAsync<bool>("start", RecipeText(), _selfRef);
    }

    // What the agent's {{recipe}} dynamic variable is filled with — name, blurb, and the ordered steps.
    private string RecipeText()
    {
        var steps = Recipe.Steps.OrderBy(s => s.Order).Select((s, i) => $"{i + 1}. {s.Text}");
        var intro = string.IsNullOrWhiteSpace(Recipe.Blurb) ? Recipe.Name : $"{Recipe.Name}. {Recipe.Blurb}";
        // Include the estimated calories so the agent can answer "how many calories?" from its context.
        var cals = Recipe.EstimatedCaloriesPerServing is { } c ? $"\nEstimated calories per serving: ~{c} (rough estimate)." : "";
        return intro + cals + "\n\nSteps:\n" + string.Join("\n", steps);
    }

    [JSInvokable]
    public async Task OnStatus(string s)
    {
        status = s;
        var couldNotStart = s is "error" or "unconfigured" && !_notifiedUnavailable;
        if (couldNotStart) _notifiedUnavailable = true;
        // Render the status first (so a manually-started cook-along still shows its error), then let the
        // parent decide whether to fall back — that may swap this component out, so it comes last.
        try { await InvokeAsync(StateHasChanged); } catch { /* may be mid-teardown */ }
        if (couldNotStart) await OnUnavailable.InvokeAsync();
    }

    [JSInvokable]
    public Task OnMode(string m)
    {
        mode = m;
        if (status == "connecting") status = "connected";
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnTranscript(string source, string text)
    {
        transcript.Add((source, text));
        return InvokeAsync(StateHasChanged);
    }

    // Spoken "go to the assistant" (detected in cookalong.js): same hand-back as the button — end this
    // session and resume the persistent voice agent.
    [JSInvokable]
    public Task OnHandOff() => BackToAssistantAsync();

    private async Task CloseAsync()
    {
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("stop"); } catch { /* already closed */ }
        }
        await OnClosed.InvokeAsync();
    }

    // Close the ElevenLabs session first (so its audio stops), then hand control back to our own
    // persistent voice assistant, which resumes listening.
    private async Task BackToAssistantAsync()
    {
        await CloseAsync();
        await Coordinator.RequestResumeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("stop"); await _module.DisposeAsync(); }
            catch { /* circuit already gone */ }
        }
        _selfRef?.Dispose();
    }
}
