{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",

      // The hands-free reader logs what it HEARD at Debug — a microphone in a kitchen shouldn't record
      // its owner's speech to disk on a real deployment, but in dev it's the only way to see why a
      // misheard phrase went the wrong way. Development only; production keeps it off.
      "ShelfAware.Web.Components.RecipeReadAloud": "Debug"
    }
  }
}
